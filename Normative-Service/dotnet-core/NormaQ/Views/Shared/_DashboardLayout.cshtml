@{
    var activeNav = ViewData["ActiveNav"]?.ToString() ?? "dashboard";
    var usuarioNombre = ViewData["UsuarioNombre"]?.ToString() ?? "Usuario";
    var rolActivoNombre = ViewData["RolActivoNombre"]?.ToString() ?? "string.Empty";
    var deptId = ViewData["DepartamentoActivoId"];
}
<!DOCTYPE html>
<html lang="es" class="dark antialiased">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — NormaQ</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap"
    rel="stylesheet">
    <script src="~/js/theme.js"></script>
    <script>
        tailwind.config = {
        darkMode: 'class',
        theme: {
        extend: {
        fontFamily: {
        sans: ['Plus Jakarta Sans', 'sans-serif'],
        display: ['Space Grotesk', 'sans-serif'],
        },
        animation: {
        'fade-in-up': 'fadeInUp 0.5s ease-out forwards',
        'spin-slow': 'spin 12s linear infinite',
        },
        keyframes: {
        fadeInUp: {
        '0%': { opacity: '0', transform: 'translateY(15px)' },
        '100%': { opacity: '1', transform: 'translateY(0)' },
        }
        }
        }
        }
        }
    </script>

    <style>
        * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        }

        body {
        width: 100vw;
        height: 100vh;
        background-color: #050508;
        transition: background-color 0.3s ease;
        overflow: hidden;
        }

        html:not(.dark) body {
        background-color: #f8fafc;
        }

        ::-webkit-scrollbar {
        display: none;
        }

        * {
        -ms-overflow-style: none;
        scrollbar-width: none;
        }

        ::view-transition-old(root),
        ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
        }

        ::view-transition-old(root) {
        z-index: 1;
        }

        ::view-transition-new(root) {
        z-index: 9999;
        }

        .app-container {
        position: relative;
        z-index: 10;
        width: 100vw;
        height: 100vh;
        display: flex;
        background: rgba(10, 10, 15, 0.6);
       backdrop-filter: blur(20px);
        }

        html:not(.dark) .app-container {
        background: rgba(255, 255, 255, 0.6);
        }

        /* NAV ITEMS */
        .nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 600;
        color: #64748b;
        transition: all 0.3s;
        text-decoration: none;
        }

        .dark .nav-item {
        color: #94a3b8;
        }

        .nav-item:hover {
        color: #4f46e5;
        background: rgba(79, 70, 229, 0.05);
        transform: translateX(6px);
        }

        .dark .nav-item:hover {
        color: #818cf8;
        background: rgba(99, 102, 241, 0.1);
        }

        .nav-item.active {
        color: #4f46e5;
        background: rgba(79, 70, 229, 0.1);
        border-left: 3px solid #4f46e5;
        }

        .dark .nav-item.active {
        color: white;
        background: rgba(99, 102, 241, 0.2);
        border-left: 3px solid #818cf8;
        }

        /* SIDEBAR OVERLAY (móvil) */
        .sidebar-overlay {
        /* keep in the flow so transitions work; control visibility via opacity/visibility/pointer-events */
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        /* avoid expensive backdrop blur on mobile by default; use only subtle opacity */
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
        z-index: 40;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity 0.22s ease, visibility 0s linear 0.22s;
        }

        .sidebar-overlay.active {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transition: opacity 0.22s ease, visibility 0s linear 0s;
        }

        /* On larger screens we can allow a light backdrop blur if desired */
        @@media (min-width: 1280px) {
        .sidebar-overlay {
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }
        }

        /* SIDEBAR IZQUIERDO */
        .sidebar-left {
        width: 260px;
        height: 100%;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        border-right: 1px solid rgba(226, 232, 240, 0.8);
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        z-index: 50;
        position: relative;
        padding: 1.25rem;
        transition: transform 0.3s ease;
        }

        .dark .sidebar-left {
        border-right-color: rgba(255, 255, 255, 0.05);
        background: rgba(0, 0, 0, 0.4);
        }

        /* SIDEBAR DERECHO */
        .sidebar-right {
        width: 300px;
        height: 100%;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        border-left: 1px solid rgba(226, 232, 240, 0.8);
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        z-index: 50;
        position: relative;
        padding: 1.5rem;
        transition: transform 0.3s ease;
        }

        .dark .sidebar-right {
        border-left-color: rgba(255, 255, 255, 0.05);
        background: rgba(0, 0, 0, 0.4);
        }

        /* MÓVIL — sidebars como drawers */
        @@media (max-width: 1023px) {
        .sidebar-left {
        position: fixed;
        left: 0;
        top: 0;
        transform: translateX(-100%);
        z-index: 60;
        height: 100vh;
        box-shadow: 4px 0 24px rgba(0, 0, 0, 0.2);
        }

        .sidebar-left.open {
        transform: translateX(0);
        }

        .sidebar-right {
        position: fixed;
        right: 0;
        top: 0;
        transform: translateX(100%);
        z-index: 60;
        height: 100vh;
        box-shadow: -4px 0 24px rgba(0, 0, 0, 0.2);
        }

        .sidebar-right.open {
        transform: translateX(0);
        }

        .main-content {
        width: 100vw !important;
        }
        }

        /* TABLET — solo ocultar sidebar derecho */
        @@media (min-width: 768px) and (max-width: 1023px) {
        .sidebar-left {
        position: relative;
        transform: none !important;
        width: 220px;
        }

        .sidebar-right {
        position: fixed;
        right: 0;
        top: 0;
        transform: translateX(100%);
        }

        .sidebar-right.open {
        transform: translateX(0);
        }

        .main-content {
        flex: 1;
        width: auto !important;
        }
        }

        /* CHARTS */
        .circular-chart {
        display: block;
        margin: 0 auto;
        max-width: 100%;
        max-height: 250px;
        }

        .circle-bg {
        fill: none;
        stroke: rgba(0, 0, 0, 0.1);
        stroke-width: 3.8;
        }

        .circle {
        fill: none;
        stroke-width: 3.5;
        stroke-linecap: round;
        animation: progress 1s ease-out forwards;
        }

        @@keyframes progress {
        0% {
        stroke-dasharray: 0 100;
        }
        }

        .dark .circle-bg {
        stroke: rgba(255, 255, 255, 0.05);
        }

        /* FOLDERS */
        details>summary {
        list-style: none;
        cursor: pointer;
        }

        details>summary::-webkit-details-marker {
        display: none;
        }

        details[open] .folder-icon {
        color: #4f46e5;
        }

        .dark details[open] .folder-icon {
        color: #818cf8;
        }

        details[open] .folder-arrow {
        transform: rotate(90deg);
        }

        .iso-folder {
        border-radius: 12px;
        margin-bottom: 0.75rem;
        border: 1px solid rgba(0, 0, 0, 0.05);
        background: rgba(255, 255, 255, 0.6);
        transition: all 0.3s;
        }

        .dark .iso-folder {
        border: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(255, 255, 255, 0.02);
        }

        .iso-folder:hover {
        border-color: rgba(99, 102, 241, 0.3);
        }

        .stagger-1 {
        animation-delay: 0.1s;
        }

        .stagger-2 {
        animation-delay: 0.2s;
        }

        /* BOTÓN HAMBURGUESA */
        .hamburger-btn {
        display: none;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(99, 102, 241, 0.08);
        border: 1px solid rgba(99, 102, 241, 0.15);
        color: #6366f1;
        cursor: pointer;
        transition: all 0.2s;
        flex-shrink: 0;
        }

        .hamburger-btn:hover {
        background: rgba(99, 102, 241, 0.15);
        }

        .hamburger-btn svg {
        width: 20px;
        height: 20px;
        }

        @@media (max-width: 1023px) {
        .hamburger-btn {
        display: flex;
        }
        }

        /* BOTÓN PANEL DERECHO MÓVIL */
        .right-panel-btn {
        display: none;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(99, 102, 241, 0.08);
        border: 1px solid rgba(99, 102, 241, 0.15);
        color: #6366f1;
        cursor: pointer;
        transition: all 0.2s;
        flex-shrink: 0;
        }

        .right-panel-btn:hover {
        background: rgba(99, 102, 241, 0.15);
        }

        .right-panel-btn svg {
        width: 20px;
        height: 20px;
        }

        @@media (max-width: 1279px) {
        .right-panel-btn {
        display: flex;
        }

        .sidebar-right {
        position: fixed;
        right: 0;
        top: 0;
        transform: translateX(100%);
        }

        .sidebar-right.open {
        transform: translateX(0);
        }
        }

        /* HEADER RESPONSIVO */
        .header-search {
        flex: 1;
        min-width: 0;
        }

        @@media (max-width: 640px) {
        .header-date {
        display: none;
        }

        .header-weather {
        display: none;
        }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>

<body class="text-slate-800 dark:text-slate-200 flex">

    <!-- Orbes de fondo -->
    <div
        class="fixed top-[-20%] left-[-10%] w-[500px] h-[500px] bg-indigo-500/20 rounded-full blur-[120px] pointer-events-none z-0 hidden dark:block">
    </div>
    <div
        class="fixed bottom-[-20%] right-[-10%] w-[400px] h-[400px] bg-purple-500/10 rounded-full blur-[120px] pointer-events-none z-0 hidden dark:block">
    </div>

    <div class="app-container">

        <!-- Overlay para móvil (moved inside app-container so sidebars stay clickable) -->
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeAllSidebars()"></div>

        <!-- SIDEBAR IZQUIERDO -->
        <aside class="sidebar-left" id="sidebarLeft">

            <!-- Botón cerrar en móvil -->
            <button onclick="toggleLeftSidebar()"
                    class="lg:hidden absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-lg bg-slate-100 dark:bg-white/10 text-slate-500 dark:text-slate-400">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>

            <div class="flex items-center gap-3 mb-10 pl-2">
                <svg class="w-8 h-8 text-indigo-600 dark:text-indigo-400 drop-shadow-md flex-shrink-0" fill="none"
                     stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2"
                          d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <div>
                    <h1 class="text-xl font-display font-bold tracking-tight text-slate-900 dark:text-white">NormaQ</h1>
                    <p class="text-[9px] font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-widest">ISO
                        Suite</p>
                    </div>
                </div>

                <nav class="space-y-1.5 mb-8">
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3 pl-3">Navegación</p>
                    <a href="/Dashboard/Index" class="nav-item @(activeNav == "dashboard" ? "active" : "")">
                        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M4 6h16M4 12h16M4 18h7" stroke-width="2" />
                        </svg>
                        Dashboard
                    </a>
                    @if (rolActivoNombre == "Administrador")
                    {
                        <a href="/Dashboard/Analiticas?departamentoId=@deptId"
                           class="nav-item @(activeNav == "analiticas" ? "active" : "")">
                            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                                stroke-width="2" />
                            </svg>
                            Analíticas
                        </a>
                        <a href="/Dashboard/GestionarSolicitudes?departamentoId=@deptId"
                           class="nav-item @(activeNav == "Aprobacion de Cuentas" ? "active" : "")">
                            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
                                stroke-width="2" />
                            </svg>
                            Aprobación de Cuentas
                        </a>
                    }
                </nav>

                <div class="mb-auto overflow-y-auto">
                    @RenderSection("SidebarExtra", required: false)
                </div>

                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-8">
                    <button type="submit"
                            class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-bold text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 hover:translate-x-2 transition-all">
                        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-width="2"
                                  d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                        Cerrar Sesión
                    </button>
                </form>
            </aside>

            <!-- MAIN -->
            <main class="main-content flex-1 h-full flex flex-col z-20 relative bg-transparent overflow-hidden min-w-0">

                <!-- HEADER -->
                <header
                    class="h-16 sm:h-20 border-b border-slate-200/60 dark:border-white/5 bg-white/40 dark:bg-black/20 backdrop-blur-md px-4 sm:px-8 flex items-center gap-3 justify-between shrink-0">

                    <div class="flex items-center gap-3 min-w-0">
                        <!-- Hamburguesa izquierda -->
                        <button class="hamburger-btn" onclick="toggleLeftSidebar()" aria-label="Menú">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M4 6h16M4 12h16M4 18h16" />
                            </svg>
                        </button>

                        <div class="header-search min-w-0">
                            @RenderSection("Busqueda", required: false)
                        </div>
                    </div>

                    <div class="flex items-center gap-2 sm:gap-4 flex-shrink-0">
                        <!-- Clima (oculto en móvil) -->
                        <div
                            class="header-weather hidden sm:flex items-center gap-2 px-3 py-2 rounded-xl bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 text-xs font-bold text-slate-600 dark:text-slate-300 shadow-sm">
                            <svg class="w-4 h-4 text-amber-500 animate-spin-slow" fill="none" stroke="currentColor"
                                 viewBox="0 0 24 24">
                                <path
                                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
                                stroke-width="2" />
                            </svg>
                            <span>32°C Monclova</span>
                        </div>

                        <!-- Fecha (oculto en móvil pequeño) -->
                        <div
                            class="header-date hidden sm:flex items-center gap-2 px-3 py-2 rounded-xl bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 text-xs font-bold text-slate-600 dark:text-slate-300 shadow-sm">
                            <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                stroke-width="2" />
                            </svg>
                            <span id="live-date">Cargando...</span>
                        </div>

                        <!-- Toggle tema -->
                        <button onclick="toggleTheme(event)"
                                class="w-9 h-9 sm:w-10 sm:h-10 rounded-full bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 flex items-center justify-center text-slate-500 hover:text-indigo-600 hover:rotate-12 transition-all shadow-sm">
                            <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
                                stroke-width="2" />
                            </svg>
                            <svg class="w-5 h-5 hidden dark:block text-amber-300" fill="none" stroke="currentColor"
                                 viewBox="0 0 24 24">
                                <path
                                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
                                stroke-width="2" />
                            </svg>
                        </button>

                        <!-- Botón panel derecho (móvil/tablet) -->
                        <button class="right-panel-btn" onclick="toggleRightSidebar()" aria-label="Perfil">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </button>
                    </div>
                </header>

                <!-- CONTENIDO -->
                <div class="flex-1 overflow-y-auto">
                    @RenderBody()
                </div>
            </main>

            <!-- SIDEBAR DERECHO -->
            <aside class="sidebar-right" id="sidebarRight">

                <!-- Botón cerrar en móvil -->
                <button onclick="toggleRightSidebar()"
                        class="xl:hidden absolute top-4 left-4 w-8 h-8 flex items-center justify-center rounded-lg bg-slate-100 dark:bg-white/10 text-slate-500 dark:text-slate-400">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>

                <!-- Perfil -->
                <div class="flex flex-col items-center mb-6 border-b border-slate-200/60 dark:border-white/5 pb-6 shrink-0">
                    <div
                        class="w-20 h-20 rounded-full bg-white dark:bg-white/10 flex items-center justify-center mb-3 shadow-xl border border-slate-100 dark:border-white/10 hover:scale-105 transition-transform">
                        <svg class="w-10 h-10 text-slate-400" fill="currentColor" viewBox="0 0 24 24">
                            <path
                            d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                        </svg>
                    </div>
                    <h3 class="text-sm font-bold text-slate-900 dark:text-white font-display">@usuarioNombre</h3>
                    <span
                        class="px-4 py-1 rounded-full bg-indigo-50 dark:bg-indigo-500/10 text-[9px] font-bold text-indigo-600 dark:text-indigo-400 uppercase mt-2 border border-indigo-100 dark:border-indigo-500/20 tracking-widest">
                        @rolActivoNombre
                    </span>
                </div>

                <!-- Contenido dinámico -->
                <div class="flex-1 flex flex-col gap-y-6 overflow-y-auto mb-6">
                    @RenderSection("SideDocCount", required: false)
                    @RenderSection("SideNotifications", required: false)
                </div>

                <!-- Selector departamento -->
                <div class="shrink-0 mt-auto">
                    @RenderSection("DeptSelector", required: false)
                </div>
            </aside>

        </div>

        <script>
            // Fecha en vivo
            function updateDate() {
            const now = new Date();
            const el = document.getElementById('live-date');
            if (el) el.innerText = now.toLocaleDateString('es-MX', { day: 'numeric', month: 'short', year: 'numeric' });
            }
            updateDate(); setInterval(updateDate, 60000);

            // Control sidebars
            function updateOverlayState() {
            const left = document.getElementById('sidebarLeft');
            const right = document.getElementById('sidebarRight');
            const overlay = document.getElementById('sidebarOverlay');
            const anyOpen = left.classList.contains('open') || right.classList.contains('open');
            overlay.classList.toggle('active', anyOpen);
            }

            function toggleLeftSidebar() {
            const sidebar = document.getElementById('sidebarLeft');
            // close right first
            document.getElementById('sidebarRight').classList.remove('open');
            sidebar.classList.toggle('open');
            updateOverlayState();
            }

            function toggleRightSidebar() {
            const sidebar = document.getElementById('sidebarRight');
            // close left first
            document.getElementById('sidebarLeft').classList.remove('open');
            sidebar.classList.toggle('open');
            updateOverlayState();
            }

            function closeAllSidebars() {
            document.getElementById('sidebarLeft').classList.remove('open');
            document.getElementById('sidebarRight').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('active');
            }

            // Cerrar sidebars al hacer resize a desktop
            window.addEventListener('resize', () => {
            if (window.innerWidth >= 1024) closeAllSidebars();
            });
        </script>

        @RenderSection("Scripts", required: false)

