<!DOCTYPE html>
<html lang="es" class="dark antialiased">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — NormaQ</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap"
    rel="stylesheet">
<script src="~/js/theme.js"></script> 
    <script>
        tailwind.config = {
        darkMode: 'class',
        theme: {
        extend: {
        fontFamily: {
        sans: ['Plus Jakarta Sans', 'sans-serif'],
        display: ['Space Grotesk', 'sans-serif'],
        },
        animation: {
        'fade-in-up': 'fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards',
        'pulse-glow': 'pulseGlow 2s infinite',
        'slide-in': 'slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards',
        },
        keyframes: {
        fadeInUp: {
        '0%': { opacity: '0', transform: 'translateY(30px) scale(0.95)' },
        '100%': { opacity: '1', transform: 'translateY(0) scale(1)' },
        },
        pulseGlow: {
        '0%, 100%': { boxShadow: '0 0 15px rgba(99,102,241,0.3)' },
        '50%': { boxShadow: '0 0 25px rgba(99,102,241,0.6)' },
        },
        slideIn: {
        '0%': { opacity: '0', transform: 'translateY(12px) scale(0.97)' },
        '100%': { opacity: '1', transform: 'translateY(0) scale(1)' },
        }
        }
        }
        }
        }

       
    </script>

    <style>
        * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        }

        body {
        overflow: hidden;
        width: 100vw;
        height: 100vh;
        background-color: #030305;
        transition: background-color 0.5s ease;
        }

        html:not(.dark) body {
        background-color: #f1f5f9;
        }

        ::view-transition-old(root),
        ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
        }

        ::view-transition-old(root) {
        z-index: 1;
        }

        ::view-transition-new(root) {
        z-index: 9999;
        }

        /* ── Input base ── */
        .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.6);
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 14px;
        padding: 0.75rem 1rem;
        overflow: hidden;
        transition: all 0.3s ease;
        }

        .dark .input-wrapper {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .input-wrapper:focus-within {
        border-color: #6366f1;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.2);
        background: rgba(255, 255, 255, 0.9);
        }

        .dark .input-wrapper:focus-within {
        background: rgba(15, 15, 20, 0.9);
        border-color: #818cf8;
        box-shadow: 0 10px 25px -5px rgba(129, 140, 248, 0.15);
        }

        .input-wrapper input,
        .input-wrapper select {
        width: 100%;
        background: transparent;
        border: none;
        outline: none;
        font-size: 14px;
        font-weight: 600;
        color: #1e293b;
        padding-left: 2.5rem;
        cursor: text;
        }

        .dark .input-wrapper input,
        .dark .input-wrapper select {
        color: #f8fafc;
        }

        .input-wrapper select {
        appearance: none;
        cursor: pointer;
        }

        .input-icon {
        position: absolute;
        left: 1.2rem;
        color: #94a3b8;
        transition: color 0.3s;
        pointer-events: none;
        width: 1.25rem;
        height: 1.25rem;
        }

        .input-wrapper:focus-within .input-icon {
        color: #6366f1;
        }

        .dark .input-wrapper:focus-within .input-icon {
        color: #818cf8;
        }

        .select-arrow {
        position: absolute;
        right: 1rem;
        pointer-events: none;
        width: 16px;
        height: 16px;
        stroke: #94a3b8;
        fill: none;
        stroke-width: 2.5;
        transition: transform 0.3s;
        }

        .input-wrapper:focus-within .select-arrow {
        transform: rotate(180deg);
        stroke: #6366f1;
        }

        .dark .input-wrapper:focus-within .select-arrow {
        stroke: #818cf8;
        }

        .dark option {
        background: #0f0f13;
        color: #f8fafc;
        }

        html:not(.dark) option {
        background: #ffffff;
        color: #1e293b;
        }

        .val-error {
        color: #ef4444;
        font-size: 11px;
        margin-top: 6px;
        display: block;
        font-weight: 700;
        margin-left: 6px;
        }

        /* ── Firma slot card ── */
        .firma-slot {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: rgba(255, 255, 255, 0.5);
        border: 1px solid rgba(0, 0, 0, 0.07);
        border-radius: 12px;
        padding: 0.6rem 0.75rem;
        animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        transition: box-shadow 0.2s;
        }

        .dark .firma-slot {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.07);
        }

        .firma-slot:hover {
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
        }

        .slot-badge {
        min-width: 26px;
        height: 26px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.02em;
        flex-shrink: 0;
        }

        .btn-remove-slot {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        cursor: pointer;
        border: none;
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        transition: all 0.2s;
        }

        .btn-remove-slot:hover {
        background: #ef4444;
        color: white;
        }

        /* Scrollable step2 area */
        #step2-scroll {
        max-height: calc(100vh - 340px);
        overflow-y: auto;
        padding-right: 4px;
        scrollbar-width: thin;
        scrollbar-color: rgba(99, 102, 241, 0.3) transparent;
        }

        #step2-scroll::-webkit-scrollbar {
        width: 4px;
        }

        #step2-scroll::-webkit-scrollbar-track {
        background: transparent;
        }

        #step2-scroll::-webkit-scrollbar-thumb {
        background: rgba(99, 102, 241, 0.3);
        border-radius: 4px;
        }
    </style>

    @RenderSection("Head", required: false)
</head>

<body class="flex items-center justify-center relative selection:bg-indigo-500 selection:text-white">

    <canvas id="particles" class="fixed inset-0 z-0 pointer-events-none"></canvas>

    <div
        class="fixed top-[-10%] left-[-5%] w-[500px] h-[500px] bg-indigo-600/20 rounded-full blur-[120px] pointer-events-none z-0 hidden dark:block">
    </div>
    <div
        class="fixed bottom-[-10%] right-[-5%] w-[400px] h-[400px] bg-purple-600/20 rounded-full blur-[120px] pointer-events-none z-0 hidden dark:block">
    </div>
    <div
        class="fixed top-[20%] right-[10%] w-[300px] h-[300px] bg-indigo-400/20 rounded-full blur-[100px] pointer-events-none z-0 block dark:hidden">
    </div>

    <div class="w-full max-w-4xl z-10 relative px-4 sm:px-6 animate-fade-in-up perspective-1000">
        @RenderBody()
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script
    src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

    <script>
        const canvas = document.getElementById('particles');
        const ctx = canvas.getContext('2d');
        let W, H, particles = [];
        const mouse = { x: null, y: null, radius: 150 };

        window.addEventListener('mousemove', e => { mouse.x = e.x; mouse.y = e.y; });

        function resize() { W = canvas.width = innerWidth; H = canvas.height = innerHeight; init(); }
        window.addEventListener('resize', resize);

        function init() {
        particles = [];
        const count = Math.floor((W * H) / 9000);
        for (let i = 0; i < count; i++) {
        particles.push({
        x: Math.random() * W, y: Math.random() * H,
        r: Math.random() * 2 + 0.5,
        vx: (Math.random() - .5) * 0.4, vy: (Math.random() - .5) * 0.4,
        opacity: Math.random() * 0.5 + 0.2
        });
        }
        }
        resize();

        function draw() {
        ctx.clearRect(0, 0, W, H);
        const isDark = document.documentElement.classList.contains('dark');
        const col = isDark ? '99,102,241' : '67,56,202';
        particles.forEach(p => {
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
        if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
        if (mouse.x != null) {
        const dx = mouse.x - p.x, dy = mouse.y - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < mouse.radius) { p.x -= (dx / dist) * 2; p.y -= (dy / dist) * 2; }
        }
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${col},${isDark ? p.opacity : p.opacity + 0.2})`; ctx.fill();
        });
        for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x, dy = particles[i].y - particles[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 120) {
        ctx.beginPath(); ctx.moveTo(particles[i].x, particles[i].y); ctx.lineTo(particles[j].x, particles[j].y);
        ctx.strokeStyle = `rgba(${col},${(isDark ? 0.15 : 0.25) * (1 - dist / 120)})`;
        ctx.lineWidth = 1; ctx.stroke();
        }
        }
        }
        requestAnimationFrame(draw);
        }
        draw();
    </script>

    @RenderSection("Scripts", required: false)
</body>

</html>
