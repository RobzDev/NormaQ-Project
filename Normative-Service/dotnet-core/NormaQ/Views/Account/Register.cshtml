@model NormaQ.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Registro de Usuario";
    ViewData["PageTitle"] = "Solicitar Acceso";
    ViewData["AuthType"] = "register";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<form asp-action="Register" method="post" id="registerForm" style="display:flex;flex-direction:column;gap:0.75rem">

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="val-summary"></div>
    }

    <div>
        <label asp-for="Nombre" class="field-label">Nombre Completo</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round"
                          stroke-linejoin="round" />
                </svg>
            </div>
            <input asp-for="Nombre" placeholder="Ej. Cristopher Cano" autocomplete="name">
        </div>
        <span asp-validation-for="Nombre" class="val-error"></span>
    </div>

    <div>
        <label asp-for="Email" class="field-label">Correo electrónico</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                    d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206"
                    stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <input asp-for="Email" type="email" placeholder="edwin@empresa.com" autocomplete="email">
        </div>
        <span asp-validation-for="Email" class="val-error"></span>
    </div>

    <div>
        <label asp-for="CompaniaId" class="field-label">Compañía</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
            </div>
            <select asp-for="CompaniaId" asp-items="Model.Companias" id="CompaniaSelect">
                <option value="">-- Seleccione una Compañía --</option>
            </select>
            <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>
        <span asp-validation-for="CompaniaId" class="val-error"></span>
    </div>

    <div>
        <label asp-for="DepartamentoId" class="field-label">Departamento</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1v1H9V7zm5 0h1v1h-1V7zm-5 4h1v1H9v-1zm5 0h1v1h-1v-1zm-5 4h1v1H9v-1zm5 0h1v1h-1v-1z"
                    stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <select asp-for="DepartamentoId" asp-items="Model.Departamentos" id="DepartamentoSelect">
                <option value="">-- Seleccione primero una Compañía --</option>
            </select>
            <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>
        <span asp-validation-for="DepartamentoId" class="val-error"></span>
    </div>

    <div>
        <label asp-for="RolId" class="field-label">Rol Inicial</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M10 14H5.236a2 2 0 01-1.789-2.894l3.5-7A2 2 0 018.736 3h4.018a2 2 0 01.485.06l3.76.94m-7 10v5a2 2 0 002 2h.096c.5 0 .905-.405.905-.904 0-.715.211-1.413.608-2.008L17 13V4m-7 10h2m5-10h2a2 2 0 012 2v6a2 2 0 01-2 2h-2.5" />
                </svg>
            </div>
            <select asp-for="RolId" asp-items="Model.Roles">
                <option value="">-- Seleccione un Rol --</option>
            </select>
            <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>
        <span asp-validation-for="RolId" class="val-error"></span>
    </div>

    <div>
        <label asp-for="Password" class="field-label">Contraseña</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                    stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <input asp-for="Password" type="password" placeholder="••••••••••••" autocomplete="new-password">
        </div>
        <span asp-validation-for="Password" class="val-error"></span>
    </div>

    <button type="submit" id="btnSubmitRegister" class="btn-main mt-2">
        <span class="btn-text">Crear Cuenta Operativa</span>
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
    </button>

    <div class="divider"><span>¿YA ESTÁS REGISTRADO?</span></div>

    <a asp-controller="Account" asp-action="Login" class="btn-sso">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"
                  stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Iniciar Sesión
    </a>

</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const companiaSelect = document.getElementById('CompaniaSelect');
            const departamentoSelect = document.getElementById('DepartamentoSelect');
            const registerForm = document.getElementById('registerForm');
            const btnSubmit = document.getElementById('btnSubmitRegister');
            const btnText = btnSubmit.querySelector('.btn-text');

            // ─── CONTROL DE TRÁFICO / EVITAR DOBLE ACCIÓN ───
            registerForm.addEventListener('submit', function (e) {
                // Comprobar si el validador unobtrusive de jQuery considera válido el formulario
                // Esto evita congelar el botón si el usuario dejó campos requeridos vacíos
                if ($(this).valid()) {
                    // Si ya fue cliqueado, cancelamos cualquier intento posterior
                    if (btnSubmit.classList.contains('pointer-events-none')) {
                        e.preventDefault();
                        return false;
                    }

                    // Mutación estética y funcional inmediata
                    btnSubmit.classList.add('pointer-events-none');
                    btnSubmit.style.opacity = '0.6';
                    btnSubmit.style.cursor = 'not-allowed';
                    btnText.textContent = 'Procesando alta e informes...';
                }
            });

            // ─── FILTRADO DE DEPARTAMENTOS EN CASCADA ───
            if (!companiaSelect.value) {
                departamentoSelect.disabled = true;
            }

            companiaSelect.addEventListener('change', async function () {
                const companiaId = this.value;
                departamentoSelect.innerHTML = '<option value="">-- Seleccione un Departamento --</option>';

                if (!companiaId) {
                    departamentoSelect.disabled = true;
                    return;
                }

                departamentoSelect.disabled = true;
                departamentoSelect.innerHTML = '<option value="">Cargando departamentos...</option>';

                try {
                    const response = await fetch(`/Account/GetDepartamentosPorCompania?companiaId=${companiaId}`);

                    if (response.ok) {
                        const departamentos = await response.json();
                        departamentoSelect.innerHTML = '<option value="">-- Seleccione un Departamento --</option>';

                        departamentos.forEach(depto => {
                            const option = document.createElement('option');
                            option.value = depto.value;
                            option.textContent = depto.text;
                            departamentoSelect.appendChild(option);
                        });

                        departamentoSelect.disabled = false;
                    } else {
                        console.error('Error del servidor al obtener departamentos.');
                        departamentoSelect.innerHTML = '<option value="">Error al cargar</option>';
                    }
                } catch (error) {
                    console.error('Error de conexión:', error);
                    departamentoSelect.innerHTML = '<option value="">Error de conexión</option>';
                }
            });
        });
    </script>
}