@model NormaQ.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
    ViewData["PageTitle"] = "Acceso Operativo";
    ViewData["AuthType"] = "login";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<form asp-action="Login" method="post" style="display:flex;flex-direction:column;gap:1rem">

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="val-summary"></div>
    }

    <div>
        <label asp-for="Email" class="field-label">Correo electrónico</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24">
                    <path
                    d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206"
                    stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <input asp-for="Email" type="email" placeholder="usuario@empresa.com" autocomplete="email">
        </div>
        <span asp-validation-for="Email" class="val-error"></span>
    </div>

    <div>
        <label asp-for="Password" class="field-label">Contraseña</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24">
                    <path
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                    stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <input asp-for="Password" type="password" placeholder="••••••••••••"
                   autocomplete="current-password">
        </div>
        <span asp-validation-for="Password" class="val-error"></span>
    </div>

    <div class="check-row">
        <label class="check-label">
            <input type="checkbox" name="RememberMe" class="custom-check">
            Recordar sesión
        </label>
        <a asp-controller="Account" asp-action="ForgotPassword"
           class="text-sm font-medium text-indigo-600 hover:text-indigo-500">
            ¿Olvidaste tu contraseña?
        </a>
    </div>

    <button type="submit" class="btn-main">
        Confirmar Identidad
        <svg viewBox="0 0 24 24">
            <path d="M14 5l7 7m0 0l-7 7m7-7H3" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
    </button>

    <div class="divider"><span>Seguridad ISO garantizada</span></div>

    <a asp-action="Register" class="btn-sso">
        <svg viewBox="0 0 24 24">
            <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                  stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Solicitar alta de sistema
    </a>

</form>