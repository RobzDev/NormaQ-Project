@using Microsoft.EntityFrameworkCore.Metadata.Internal
@model NormaQ.ViewModels.GestionarSolicitudesViewModel

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Gestionar Solicitudes";

    ViewData["RolActivoNombre"] = Model.RolActivoNombre;
    ViewData["UsuarioNombre"] = Model.UsuarioNombre;
    ViewData["DepartamentoActivoId"] = Model.DepartamentoActivoId;

    // Ajusta el ActiveNav según cómo manejes el menú lateral en tu Layout
    ViewData["ActiveNav"] = "Aprobacion de Cuentas";
}

<div class="flex-1 flex flex-col p-8 overflow-hidden gap-5">

    <div
        class="shrink-0 bg-gradient-to-br from-indigo-600 to-indigo-700 dark:from-indigo-600 dark:to-indigo-900 rounded-[20px] p-6 text-white flex justify-between items-center shadow-lg shadow-indigo-500/20 animate-fade-in-up">
        <div class="flex-1">
            <span
                class="inline-block px-2 py-0.5 bg-white/20 backdrop-blur-md rounded border border-white/20 text-[9px] font-bold tracking-widest uppercase mb-2">Panel
                de Administración</span>
                <h2 class="font-display text-2xl font-bold mb-1">Gestión de Accesos</h2>
                <p class="text-indigo-100 text-xs">Evaluación de solicitudes para el departamento de
                    <strong>@Model.DepartamentoActivoNombre</strong>.</p>
                </div>

                <div class="flex gap-6 pr-4 border-l border-white/10 pl-6">
                    <div class="text-center">
                        <p class="text-2xl font-bold font-display leading-none">@Model.Solicitudes.Count</p>
                        <p class="text-[9px] uppercase tracking-widest text-indigo-200 mt-1">Pendientes</p>
                    </div>
                </div>
            </div>

            <div class="flex-1 flex flex-col min-h-0 animate-fade-in-up stagger-1">

                @if (TempData["Exito"] != null)
                {
                    <div
                        class="mb-4 flex items-start gap-3 p-4 bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 rounded-xl shrink-0">
                        <svg class="h-5 w-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24"
                             stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <p class="text-sm text-emerald-800 dark:text-emerald-400">@TempData["Exito"]</p>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div
                        class="mb-4 flex items-start gap-3 p-4 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 rounded-xl shrink-0">
                        <svg class="h-5 w-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24"
                             stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <p class="text-sm text-red-800 dark:text-red-400">@TempData["Error"]</p>
                    </div>
                }

                <div class="flex-1 overflow-y-auto pr-2 pb-4">
                    <div
                        class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200/60 dark:border-white/10 shadow-sm overflow-hidden">

                        <div
                            class="flex items-center justify-between px-6 py-4 border-b border-slate-100 dark:border-white/5 bg-slate-50/50 dark:bg-black/20">
                            <div class="flex items-center gap-2">
                                <svg class="h-5 w-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                <span class="text-sm font-bold text-slate-700 dark:text-slate-200">Usuarios en espera</span>
                            </div>
                        </div>

                        @if (!Model.Solicitudes.Any())
                        {
                            <div class="flex flex-col items-center justify-center py-16 px-6 text-center">
                                <div
                                    class="h-14 w-14 rounded-full bg-slate-100 dark:bg-white/5 flex items-center justify-center mb-4">
                                    <svg class="h-7 w-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                </div>
                                <p class="text-sm font-bold text-slate-700 dark:text-slate-300">Sin solicitudes pendientes</p>
                                <p class="text-xs text-slate-400 mt-1">No hay usuarios esperando aprobación en este momento.</p>
                            </div>
                        }
                        else
                        {
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm">
                                    <thead>
                                        <tr
                                            class="bg-slate-50 dark:bg-black/40 text-left border-b border-slate-100 dark:border-white/5">
                                            <th class="px-6 py-3 text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                                                Usuario</th>
                                                <th class="px-6 py-3 text-[10px] font-bold text-slate-500 uppercase tracking-widest">Rol
                                                    Solicitado</th>
                                                    <th class="px-6 py-3 text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                                                        Fecha</th>
                                                        <th
                                                            class="px-6 py-3 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-right">
                                                            Acciones</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody class="divide-y divide-slate-50 dark:divide-white/5">
                                                        @foreach (var item in Model.Solicitudes)
                                                        {
                                                            <tr class="hover:bg-slate-50/50 dark:hover:bg-white/5 transition-colors duration-100">

                                                                <td class="px-6 py-4">
                                                                    <div class="flex items-center gap-3">
                                                                        <div
                                                                            class="h-9 w-9 rounded-full bg-indigo-100 dark:bg-indigo-500/20 flex items-center justify-center flex-shrink-0">
                                                                            <span class="text-xs font-bold text-indigo-700 dark:text-indigo-400">
                                                                                @(item.Nombre.Length >= 2 ? item.Nombre.Substring(0, 2).ToUpper() :
                                                                        item.Nombre.ToUpper())
                                                                            </span>
                                                                        </div>
                                                                        <div>
                                                                            <p class="font-bold text-slate-900 dark:text-white text-sm">@item.Nombre</p>
                                                                            <p class="text-xs font-medium text-slate-400">@item.Email</p>
                                                                        </div>
                                                                    </div>
                                                                </td>

                                                                <td class="px-6 py-4">
                                                                    <span
                                                                        class="inline-flex items-center px-2.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide bg-purple-50 dark:bg-purple-500/10 text-purple-700 dark:text-purple-400 border border-purple-200 dark:border-purple-500/20">
                                                                        @item.NombreRolSugerido
                                                                    </span>
                                                                </td>

                                                                <td class="px-6 py-4">
                                                                    <p class="text-slate-600 dark:text-slate-300 text-xs font-medium">
                                                                        @item.FechaSolicitud.ToString("dd MMM yyyy")</p>
                                                                        <span
                                                                        class="text-[10px] text-slate-400">@item.FechaSolicitud.ToString("HH:mm")</span>
                                                                    </td>

                                                                    <td class="px-6 py-4">
                                                                        <div class="flex items-center justify-end gap-2">
                                                                            <form asp-action="ProcesarSolicitud" method="post" class="inline">
                                                                                @Html.AntiForgeryToken()
                                                                                <input type="hidden" name="SolicitudId" value="@item.SolicitudId" />
                                                                                <input type="hidden" name="Accion" value="Aprobar" />
                                                                                <button type="submit"
                                                                                        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold transition-colors shadow-sm">
                                                                                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24"
                                                                                         stroke="currentColor">
                                                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                                                              stroke-width="2" d="M5 13l4 4L19 7" />
                                                                                    </svg>
                                                                                    Aprobar
                                                                                </button>
                                                                            </form>

                                                                            <form asp-action="ProcesarSolicitud" method="post" class="inline">
                                                                                @Html.AntiForgeryToken()
                                                                                <input type="hidden" name="SolicitudId" value="@item.SolicitudId" />
                                                                                <input type="hidden" name="Accion" value="Rechazar" />
                                                                                <button type="submit"
                                                                                        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-white dark:bg-slate-800 hover:bg-red-50 dark:hover:bg-red-500/10 border border-red-200 dark:border-red-500/30 text-red-600 dark:text-red-400 text-xs font-bold transition-colors shadow-sm">
                                                                                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24"
                                                                                         stroke="currentColor">
                                                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                                                              stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                                                                    </svg>
                                                                                    Rechazar
                                                                                </button>
                                                                            </form>
                                                                        </div>
                                                                    </td>

                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                        </div>

                                        <p class="text-center text-[10px] font-medium text-slate-400 mt-4 uppercase tracking-widest">
                                            <i class="bi bi-info-circle me-1"></i> Las acciones notifican automáticamente al usuario por correo
                                            electrónico.
                                        </p>
                                    </div>
                                </div>
                            </div>