                    </div>
                </div>
                <div class="p-5 space-y-4">
                    <div class="w-full h-12 rounded-xl bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 flex items-center px-3 gap-3">
