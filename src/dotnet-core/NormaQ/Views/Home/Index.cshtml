                            <div class="w-3 h-3 bg-emerald-500 rounded-full"></div>
                        </div>
                        <div>
                            <div class="w-32 h-2 bg-emerald-600 dark:bg-emerald-400 rounded mb-1.5"></div>
                            <div class="w-48 h-1.5 bg-emerald-600/50 dark:bg-emerald-400/50 rounded"></div>
                        </div>
                    </div>
                    <div class="flex gap-3 h-20">
                        <div class="flex-1 rounded-xl bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 p-3 flex flex-col justify-center gap-2">
