                    <div class="w-[160px] bg-slate-50/80 dark:bg-[#0f0f15]/80 border-r border-slate-200 dark:border-white/10 p-4 flex flex-col gap-4">
                        <div>
                            <div class="text-[9px] text-slate-400 mb-1">Identificador</div>
