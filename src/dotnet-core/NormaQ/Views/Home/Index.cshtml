            </div>
            <span class="text-sm font-extrabold font-display tracking-widest uppercase text-slate-800 dark:text-white">QualityDoc</span>
        </div>
        
        <div class="flex items-center gap-4 animate-fade-in" style="animation-delay: 0.1s;">
            <button onclick="toggleTheme(event)" class="w-10 h-10 rounded-xl bg-white/10 dark:bg-white/5 border border-slate-200 dark:border-white/10 flex items-center justify-center transition-all hover:scale-110 hover:bg-white/20 text-slate-600 dark:text-amber-300 shadow-sm backdrop-blur-md">
                <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            </button>
        </div>
    </nav>

    <main class="flex-1 flex flex-col items-center justify-start relative z-40 w-full px-6 pt-2 md:pt-4 pointer-events-none">
        
