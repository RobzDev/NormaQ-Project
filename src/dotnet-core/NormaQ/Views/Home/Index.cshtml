                        <div class="h-px bg-slate-300 dark:bg-white/10 w-24"></div>
                        <div class="w-5 h-5 rounded-full bg-slate-200 dark:bg-white/10 border border-slate-300 dark:border-white/20"></div>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <div class="w-20 h-2 bg-slate-300 dark:bg-slate-600 rounded mb-1.5"></div>
                            <div class="w-full h-8 rounded-lg bg-slate-100 dark:bg-black/30 border border-slate-200 dark:border-white/10 flex items-center px-2">
                                <div class="w-4 h-4 rounded bg-slate-200 dark:bg-white/10"></div>
