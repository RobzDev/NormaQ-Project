                </div>
            </div>

            <div class="mockup-window mockup-center w-[540px] h-[340px] absolute z-30 animate-float-medium bg-white/95 dark:bg-[#0a0a0f]/95">
                <div class="h-10 bg-white/80 dark:bg-[#0a0a0f]/80 border-b border-slate-200 dark:border-white/10 flex items-center px-4 justify-between">
                    <div class="flex items-center gap-3">
                        <div class="w-6 h-6 bg-slate-100 dark:bg-white/5 rounded-lg flex items-center justify-center text-slate-500"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg></div>
