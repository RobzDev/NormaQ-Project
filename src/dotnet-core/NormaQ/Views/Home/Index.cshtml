                            </div>
                        </div>
                    </div>
                    <div class="flex-1 bg-slate-200/50 dark:bg-[#151520]/50 p-4 flex flex-col items-center justify-center overflow-hidden">
                        <div class="w-[90%] h-[95%] bg-white dark:bg-[#111] dark:invert dark:hue-rotate-180 rounded-lg shadow-xl border border-slate-300 dark:border-white/5 p-6 flex flex-col relative overflow-hidden">
                            <div class="w-full h-10 bg-indigo-600/20 mb-8 rounded-sm"></div>
                            <div class="w-16 h-16 mx-auto rounded-full border-4 border-slate-200 mb-6 flex items-center justify-center">
                                <div class="w-8 h-8 rounded-full bg-slate-200"></div>
                            </div>
                            <div class="w-5/6 h-4 mx-auto bg-slate-800 rounded-sm mb-8"></div>
                            <div class="w-2/3 h-2 mx-auto bg-slate-400 rounded-sm mb-3"></div>
                            <div class="w-1/2 h-2 mx-auto bg-slate-400 rounded-sm mb-3"></div>
                            <div class="w-3/4 h-2 mx-auto bg-slate-300 rounded-sm"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-[#030305] to-transparent z-40 dark:block hidden"></div>
        <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-[#f1f5f9] to-transparent z-40 block dark:hidden"></div>
    </div>

    <footer class="h-16 px-8 flex items-center justify-center z-50 shrink-0 bg-white/10 dark:bg-black/40 backdrop-blur-md border-t border-slate-200/50 dark:border-white/5 w-full absolute bottom-0 shadow-[0_-10px_30px_rgba(0,0,0,0.1)]">
        <a asp-controller="Home" asp-action="Privacy" class="inline-flex items-center gap-2 text-sm font-bold text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all hover:scale-105 group">
            <svg class="w-5 h-5 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            Políticas de Privacidad
        </a>
    </footer>

    <script>
        const canvas = document.getElementById('particles');
        const ctx = canvas.getContext('2d');
        let W, H, particles = [];
        let mouse = { x: null, y: null, radius: 200 }; 

        window.addEventListener('mousemove', (e) => {
            mouse.x = e.x;
            mouse.y = e.y;
        });

        function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; init(); }

        class Particle {
            constructor() {
                this.x = Math.random() * W; this.y = Math.random() * H;
                this.r = Math.random() * 2 + 0.5; 
                this.opacity = Math.random() * 0.5 + 0.1;
                this.vx = (Math.random() - 0.5) * 0.4; this.vy = (Math.random() - 0.5) * 0.4;
            }
            draw(color) {
                ctx.beginPath(); ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(${color}, ${this.opacity})`; ctx.fill();
            }
            update() {
                this.x += this.vx; this.y += this.vy;
                if (this.x < 0 || this.x > W) this.vx *= -1;
                if (this.y < 0 || this.y > H) this.vy *= -1;
                
                let dx = mouse.x - this.x; let dy = mouse.y - this.y;
                let distance = Math.sqrt(dx*dx + dy*dy);
                if (distance < mouse.radius) {
                    const force = (mouse.radius - distance) / mouse.radius;
                    this.x -= (dx / distance) * force * 3; 
                    this.y -= (dy / distance) * force * 3;
                }
            }
        }

        function init() {
            particles = []; const count = Math.floor((W * H) / 9000);
            for (let i = 0; i < count; i++) particles.push(new Particle());
        }

        function animate() {
            ctx.clearRect(0, 0, W, H);
            const isDark = document.documentElement.classList.contains('dark');
            const rgbColor = isDark ? '255, 255, 255' : '99, 102, 241';
            
            particles.forEach(p => { p.update(); p.draw(rgbColor); });

            // Dibujar líneas de constelación
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    let dx = particles[i].x - particles[j].x;
                    let dy = particles[i].y - particles[j].y;
                    let dist = Math.sqrt(dx * dx + dy * dy);
                    
                    if (dist < 100) { 
                        ctx.beginPath();
                        ctx.strokeStyle = `rgba(${rgbColor}, ${0.15 * (1 - dist/100)})`;
                        ctx.lineWidth = 1;
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(animate);
        }

        window.addEventListener('resize', resize);
        resize(); animate();
    </script>
</body>
</html>