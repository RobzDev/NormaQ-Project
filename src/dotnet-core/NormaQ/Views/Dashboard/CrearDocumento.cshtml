@model NormaQ.ViewModels.CrearDocumentoViewModel

@{
    ViewData["Title"] = "Nuevo Documento Lógico";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es" class="dark antialiased">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — NormaQ</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap"
    rel="stylesheet">

    <script>
        tailwind.config = {
        darkMode: 'class',
        theme: {
        extend: {
        fontFamily: {
        sans: ['Plus Jakarta Sans', 'sans-serif'],
        display: ['Space Grotesk', 'sans-serif'],
        },
        animation: {
        'fade-in-up': 'fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards',
        'pulse-glow': 'pulseGlow 2s infinite',
        },
        keyframes: {
        fadeInUp: {
        '0%': { opacity: '0', transform: 'translateY(30px) scale(0.95)' },
        '100%': { opacity: '1', transform: 'translateY(0) scale(1)' },
        },
        pulseGlow: {
        '0%, 100%': { boxShadow: '0 0 15px rgba(99,102,241,0.3)' },
        '50%': { boxShadow: '0 0 25px rgba(99,102,241,0.6)' },
        }
        }
        }
        }
        }

        function toggleTheme(event) {
        const html = document.documentElement;
        if (!document.startViewTransition) { html.classList.toggle('dark'); return; }
        const x = event?.clientX ?? window.innerWidth / 2;
        const y = event?.clientY ?? window.innerHeight / 2;
        const r = Math.hypot(Math.max(x, window.innerWidth - x), Math.max(y, window.innerHeight - y));
        const transition = document.startViewTransition(() => { html.classList.toggle('dark'); });
        transition.ready.then(() => {
        document.documentElement.animate(
        { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${r}px at ${x}px ${y}px)`] },
        { duration: 600, easing: 'cubic-bezier(0.4,0,0.2,1)', pseudoElement: '::view-transition-new(root)' }
        );
        });
        }
    </script>

    <style>
        * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        }

        body {
        overflow: hidden;
        width: 100vw;
        height: 100vh;
        background-color: #030305;
        transition: background-color 0.5s ease;
        }

        html:not(.dark) body {
        background-color: #f1f5f9;
        }

        ::view-transition-old(root),
        ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
        }

        ::view-transition-old(root) {
        z-index: 1;
        }

        ::view-transition-new(root) {
        z-index: 9999;
        }

        /* Estilos Premium para Inputs */
        .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.6);
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 14px;
        padding: 0.75rem 1rem;
        overflow: hidden;
        transition: all 0.3s ease;
        }

        .dark .input-wrapper {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .input-wrapper:focus-within {
        border-color: #6366f1;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.2);
        background: rgba(255, 255, 255, 0.9);
        }

        .dark .input-wrapper:focus-within {
        background: rgba(15, 15, 20, 0.9);
        border-color: #818cf8;
        box-shadow: 0 10px 25px -5px rgba(129, 140, 248, 0.15);
        }

        .input-wrapper input,
        .input-wrapper select {
        width: 100%;
        background: transparent;
        border: none;
        outline: none;
        font-size: 14px;
        font-weight: 600;
        color: #1e293b;
        padding-left: 2.5rem;
        cursor: text;
        }

        .dark .input-wrapper input,
        .dark .input-wrapper select {
        color: #f8fafc;
        }

        .input-wrapper select {
        appearance: none;
        cursor: pointer;
        }

        .input-icon {
        position: absolute;
        left: 1.2rem;
        w-5;
        h-5;
        color: #94a3b8;
        transition: color 0.3s;
        pointer-events: none;
        }

        .input-wrapper:focus-within .input-icon {
        color: #6366f1;
        }

        .dark .input-wrapper:focus-within .input-icon {
        color: #818cf8;
        }

        .select-arrow {
        position: absolute;
        right: 1rem;
        pointer-events: none;
        width: 16px;
        height: 16px;
        stroke: #94a3b8;
        fill: none;
        stroke-width: 2.5;
        transition: transform 0.3s;
        }

        .input-wrapper:focus-within .select-arrow {
        transform: rotate(180deg);
        stroke: #6366f1;
        }

        .dark .input-wrapper:focus-within .select-arrow {
        stroke: #818cf8;
        }

        .dark option {
        background: #0f0f13;
        color: #f8fafc;
        padding: 10px;
        }

        html:not(.dark) option {
        background: #ffffff;
        color: #1e293b;
        padding: 10px;
        }

        .val-error {
        color: #ef4444;
        font-size: 11px;
        margin-top: 6px;
        display: block;
        font-weight: 700;
        margin-left: 6px;
        }
    </style>
</head>

<body class="flex items-center justify-center relative selection:bg-indigo-500 selection:text-white">

    <canvas id="particles" class="fixed inset-0 z-0 pointer-events-none"></canvas>

    <div
        class="fixed top-[-10%] left-[-5%] w-[500px] h-[500px] bg-indigo-600/20 rounded-full blur-[120px] pointer-events-none z-0 hidden dark:block">
    </div>
    <div
        class="fixed bottom-[-10%] right-[-5%] w-[400px] h-[400px] bg-purple-600/20 rounded-full blur-[120px] pointer-events-none z-0 hidden dark:block">
    </div>
    <div
        class="fixed top-[20%] right-[10%] w-[300px] h-[300px] bg-indigo-400/20 rounded-full blur-[100px] pointer-events-none z-0 block dark:hidden">
    </div>

    <div class="w-full max-w-4xl z-10 relative px-4 sm:px-6 animate-fade-in-up perspective-1000">

        <div
            class="bg-white/70 dark:bg-[#0a0a0f]/80 backdrop-blur-2xl border border-white/40 dark:border-white/10 rounded-[28px] shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] dark:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.5)] overflow-hidden ring-1 ring-white/50 dark:ring-white/5">

            <div
                class="bg-gradient-to-r from-indigo-600 via-indigo-700 to-indigo-800 dark:from-indigo-900 dark:via-indigo-800 dark:to-[#0f0f18] p-6 sm:p-8 text-white flex justify-between items-center relative overflow-hidden">
                <div
                    class="absolute right-0 top-0 w-[400px] h-[400px] bg-white/10 rounded-full blur-[80px] transform translate-x-1/3 -translate-y-1/2">
                </div>

                <div class="relative z-10 flex items-center gap-4">
                    <div
                        class="w-12 h-12 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 flex items-center justify-center shadow-inner">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                            </path>
                        </svg>
                    </div>
                    <div>
                        <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">Crear Documento Normativo
                        </h2>
                        <p class="text-indigo-200 text-xs sm:text-sm font-medium mt-1">Registrando en: <strong
                            class="text-white bg-white/10 px-2 py-0.5 rounded">@Model.DepartamentoNombre</strong>
                        </p>
                    </div>
                </div>

                <div class="relative z-10 flex items-center gap-3">
                    <button onclick="toggleTheme(event)"
                            class="w-10 h-10 rounded-full bg-black/20 hover:bg-black/40 border border-white/10 flex items-center justify-center transition-all hover:scale-105">
                        <svg class="w-4 h-4 text-white block dark:hidden" fill="none" stroke="currentColor"
                             viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                  d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z">
                            </path>
                        </svg>
                        <svg class="w-4 h-4 text-amber-300 hidden dark:block" fill="none" stroke="currentColor"
                             viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                  d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z">
                            </path>
                        </svg>
                    </button>
                    <a asp-controller="Home" asp-action="Index"
                       class="w-10 h-10 rounded-full bg-white/10 hover:bg-red-500 hover:text-white hover:border-red-500 border border-white/20 flex items-center justify-center transition-all hover:scale-105 text-white/80">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                  d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </a>
                </div>
            </div>

            <div class="p-8 sm:p-10">
                <form asp-action="CrearDocumento" method="post" id="wizardForm">
                    <input type="hidden" asp-for="DepartamentoId" />
                    <input type="hidden" asp-for="DepartamentoNombre" />

                    <div class="relative mb-12 mx-auto w-4/5 sm:w-2/3">
                        <div
                            class="absolute top-1/2 left-0 w-full h-1.5 bg-slate-200 dark:bg-white/5 -translate-y-1/2 rounded-full overflow-hidden shadow-inner">
                            <div id="progressBar"
                                 class="h-full bg-indigo-500 rounded-full transition-all duration-700 ease-out"
                                 style="width: 0%;"></div>
                        </div>
                        <div class="flex justify-between relative z-10">
                            <div class="flex flex-col items-center gap-2 -ml-4">
                                <div
                                    class="w-10 h-10 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm font-bold shadow-[0_0_15px_rgba(79,70,229,0.5)] ring-4 ring-indigo-600/20 transition-all duration-300">
                                    1</div>
                                    <span
                                    class="text-[10px] font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-widest absolute -bottom-6 whitespace-nowrap">Clasificación</span>
                                </div>
                                <div class="flex flex-col items-center gap-2 -mr-4">
                                    <div id="indStep2"
                                         class="w-10 h-10 rounded-full bg-white dark:bg-[#1a1a24] border-2 border-slate-200 dark:border-white/10 text-slate-400 flex items-center justify-center text-sm font-bold transition-all duration-700">
                                        2</div>
                                        <span id="textStep2"
                                              class="text-[10px] font-bold text-slate-400 uppercase tracking-widest absolute -bottom-6 whitespace-nowrap transition-colors duration-700">Firmas</span>
                                    </div>
                                </div>
                            </div>

                            <div asp-validation-summary="ModelOnly"
                                 class="text-red-500 text-sm font-bold mb-6 bg-red-50 dark:bg-red-500/10 p-4 rounded-xl border border-red-200 dark:border-red-500/20 flex items-center gap-3">
                                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                <span>Revisa los errores abajo.</span>
                            </div>

                            <div id="step1" class="transition-all duration-500">

                                <div class="space-y-6">
                                    <div>
                                        <label asp-for="Nombre"
                                               class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2 ml-1">Nombre
                                            Oficial del Documento</label>
                                            <div class="input-wrapper">
                                                <svg class="input-icon w-5 h-5" fill="none" stroke="currentColor"
                                                     viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                                                    </path>
                                                </svg>
                                                <input asp-for="Nombre" placeholder="Ej. Procedimiento de Auditoría Interna"
                                                       autocomplete="off" />
                                            </div>
                                            <span asp-validation-for="Nombre" class="val-error"></span>
                                        </div>

                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                            <div>
                                                <label asp-for="NivelId"
                                                       class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2 ml-1">Nivel
                                                    Estructural</label>
                                                    <div class="input-wrapper">
                                                        <svg class="input-icon w-5 h-5" fill="none" stroke="currentColor"
                                                             viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                  d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10">
                                                            </path>
                                                        </svg>
                                                        <select asp-for="NivelId" asp-items="Model.NivelesDisponibles">
                                                            <option value="">-- Seleccionar --</option>
                                                        </select>
                                                        <svg class="select-arrow" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                                        </svg>
                                                    </div>
                                                    <span asp-validation-for="NivelId" class="val-error"></span>
                                                </div>

                                                <div>
                                                    <label asp-for="NormaId"
                                                           class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2 ml-1">Normativa
                                                        Aplicable</label>
                                                        <div class="input-wrapper">
                                                            <svg class="input-icon w-5 h-5" fill="none" stroke="currentColor"
                                                                 viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                      d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z">
                                                                </path>
                                                            </svg>
                                                            <select asp-for="NormaId" asp-items="Model.NormasDisponibles">
                                                                <option value="">-- Seleccionar --</option>
                                                            </select>
                                                            <svg class="select-arrow" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                                            </svg>
                                                        </div>
                                                        <span asp-validation-for="NormaId" class="val-error"></span>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="mt-10 pt-6 border-t border-slate-200 dark:border-white/10 flex justify-end">
                                                <button type="button" onclick="nextStep()"
                                                        class="bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-3 rounded-xl text-sm font-bold shadow-[0_8px_20px_-6px_rgba(79,70,229,0.5)] transition-all hover:-translate-y-1 flex items-center gap-3 group">
                                                    Configurar Firmas <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                                                                       fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                          d="M9 5l7 7-7 7"></path>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>

                                    <div id="step2" class="hidden opacity-0 translate-y-8 transition-all duration-500">

                                        <div
                                            class="bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-100 dark:border-indigo-500/20 p-5 rounded-2xl mb-8 flex items-start gap-4">
                                            <div class="bg-indigo-100 dark:bg-indigo-500/20 p-2 rounded-lg shrink-0">
                                                <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none"
                                                     stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                </svg>
                                            </div>
                                            <div>
                                                <h4 class="text-sm font-bold text-indigo-900 dark:text-indigo-200 mb-1">Rutas de
                                                    Autorización</h4>
                                                    <p class="text-xs text-indigo-700 dark:text-indigo-300 font-medium">Solo se muestran los
                                                        roles que actualmente tienen usuarios asignados en <strong
                                                        class="text-indigo-900 dark:text-indigo-100">@Model.DepartamentoNombre</strong>.
                                                    </p>
                                                </div>
                                            </div>

                                            <div class="space-y-5">
                                                <div>
                                                    <label asp-for="RolElaboroId"
                                                           class="flex items-center gap-3 text-xs font-bold text-slate-700 dark:text-slate-300 mb-2 ml-1">
                                                        <span
                                                            class="bg-slate-200 dark:bg-white/10 text-slate-600 dark:text-slate-300 px-2 py-0.5 rounded text-[10px] uppercase tracking-widest border border-slate-300 dark:border-white/5">Fase
                                                            1</span>
                                                            ¿Quién elaborará los borradores?
                                                        </label>
                                                        <div class="input-wrapper">
                                                            <svg class="input-icon w-5 h-5" fill="none" stroke="currentColor"
                                                                 viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                      d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z">
                                                                </path>
                                                            </svg>
                                                            <select asp-for="RolElaboroId" asp-items="Model.RolesDisponibles">
                                                                <option value="">-- Seleccionar Rol --</option>
                                                            </select>
                                                            <svg class="select-arrow" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                                            </svg>
                                                        </div>
                                                        <span asp-validation-for="RolElaboroId" class="val-error"></span>
                                                    </div>

                                                    <div>
                                                        <label asp-for="RolRevisoId"
                                                               class="flex items-center gap-3 text-xs font-bold text-slate-700 dark:text-slate-300 mb-2 ml-1">
                                                            <span
                                                                class="bg-amber-100 dark:bg-amber-500/10 text-amber-700 dark:text-amber-400 px-2 py-0.5 rounded text-[10px] uppercase tracking-widest border border-amber-200 dark:border-amber-500/20">Fase
                                                                2</span>
                                                                ¿Quién realizará la revisión técnica?
                                                            </label>
                                                            <div class="input-wrapper focus-within:border-amber-500 focus-within:ring-amber-500">
                                                                <svg class="input-icon w-5 h-5" fill="none" stroke="currentColor"
                                                                     viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                          d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4">
                                                                    </path>
                                                                </svg>
                                                                <select asp-for="RolRevisoId" asp-items="Model.RolesDisponibles">
                                                                    <option value="">-- Seleccionar Rol --</option>
                                                                </select>
                                                                <svg class="select-arrow" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                                                </svg>
                                                            </div>
                                                            <span asp-validation-for="RolRevisoId" class="val-error"></span>
                                                        </div>

                                                        <div>
                                                            <label asp-for="RolAproboId"
                                                                   class="flex items-center gap-3 text-xs font-bold text-slate-700 dark:text-slate-300 mb-2 ml-1">
                                                                <span
                                                                    class="bg-emerald-100 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 px-2 py-0.5 rounded text-[10px] uppercase tracking-widest border border-emerald-200 dark:border-emerald-500/20">Fase
                                                                    3</span>
                                                                    ¿Quién dará la autorización final?
                                                                </label>
                                                                <div
                                                                    class="input-wrapper focus-within:border-emerald-500 focus-within:ring-emerald-500">
                                                                    <svg class="input-icon w-5 h-5" fill="none" stroke="currentColor"
                                                                         viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                                    </svg>
                                                                    <select asp-for="RolAproboId" asp-items="Model.RolesDisponibles">
                                                                        <option value="">-- Seleccionar Rol --</option>
                                                                    </select>
                                                                    <svg class="select-arrow" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                                                    </svg>
                                                                </div>
                                                                <span asp-validation-for="RolAproboId" class="val-error"></span>
                                                            </div>
                                                        </div>

                                                        <div
                                                            class="mt-10 pt-6 border-t border-slate-200 dark:border-white/10 flex justify-between items-center">
                                                            <button type="button" onclick="prevStep()"
                                                                    class="text-slate-500 hover:text-indigo-500 dark:hover:text-indigo-400 font-bold text-sm transition-colors flex items-center gap-2 group">
                                                                <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none"
                                                                     stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                                          d="M15 19l-7-7 7-7"></path>
                                                                </svg> Atrás
                                                            </button>
                                                            <button type="submit"
