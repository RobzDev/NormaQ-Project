                                    <script>
                                        const step1 = document.getElementById('step1');
                                        const step2 = document.getElementById('step2');
                                        const progressBar = document.getElementById('progressBar');
                                        const indStep2 = document.getElementById('indStep2');
                                        const textStep2 = document.getElementById('textStep2');

                                        function nextStep() {
                                        step1.classList.remove('opacity-100', 'translate-y-0');
                                        step1.classList.add('opacity-0', '-translate-y-8');

                                        setTimeout(() => {
                                        step1.classList.add('hidden');
                                        step2.classList.remove('hidden');

                                        void step2.offsetWidth;

                                        step2.classList.remove('opacity-0', 'translate-y-8');
                                        step2.classList.add('opacity-100', 'translate-y-0');

                                        progressBar.style.width = '100%';
                                        indStep2.className = 'w-10 h-10 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm font-bold shadow-[0_0_15px_rgba(79,70,229,0.5)] ring-4 ring-indigo-600/20 transition-all duration-700';
                                        textStep2.className = 'text-[10px] font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-widest absolute -bottom-6 whitespace-nowrap transition-colors duration-700';
                                        }, 500);
                                        }

                                        function prevStep() {
                                        step2.classList.remove('opacity-100', 'translate-y-0');
                                        step2.classList.add('opacity-0', 'translate-y-8');

                                        setTimeout(() => {
                                        step2.classList.add('hidden');
                                        step1.classList.remove('hidden');

                                        void step1.offsetWidth;

                                        step1.classList.remove('opacity-0', '-translate-y-8');
                                        step1.classList.add('opacity-100', 'translate-y-0');

                                        progressBar.style.width = '0%';
                                        indStep2.className = 'w-10 h-10 rounded-full bg-white dark:bg-[#1a1a24] border-2 border-slate-200 dark:border-white/10 text-slate-400 flex items-center justify-center text-sm font-bold transition-all duration-700';
                                        textStep2.className = 'text-[10px] font-bold text-slate-400 uppercase tracking-widest absolute -bottom-6 whitespace-nowrap transition-colors duration-700';
                                        }, 500);
                                        }
                                    </script>

                                    <script>
                                        const canvas = document.getElementById('particles');
                                        const ctx = canvas.getContext('2d');
                                        let W, H, particles = [];
                                        let mouse = { x: null, y: null, radius: 150 };

                                        window.addEventListener('mousemove', (e) => { mouse.x = e.x; mouse.y = e.y; });
                                        function resize() { W = canvas.width = innerWidth; H = canvas.height = innerHeight; init(); }
                                        window.addEventListener('resize', resize);

                                        function init() {
                                        particles = [];
                                        const count = Math.floor((W * H) / 9000);
                                        for (let i = 0; i < count; i++) {
                                        particles.push({
                                        x: Math.random() * W, y: Math.random() * H,
                                        r: Math.random() * 2 + 0.5,
                                        vx: (Math.random() - .5) * 0.4, vy: (Math.random() - .5) * 0.4,
                                        opacity: Math.random() * 0.5 + 0.2
                                        });
                                        }
                                        }
                                        resize();

                                        function draw() {
                                        ctx.clearRect(0, 0, W, H);
                                        const isDark = document.documentElement.classList.contains('dark');
                                        const col = isDark ? '99, 102, 241' : '67, 56, 202';

                                        particles.forEach(p => {
                                        p.x += p.vx; p.y += p.vy;
                                        if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
                                        if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;

                                        if (mouse.x != null) {
                                        let dx = mouse.x - p.x;
                                        let dy = mouse.y - p.y;
                                        let dist = Math.sqrt(dx * dx + dy * dy);
                                        if (dist < mouse.radius) { p.x -= (dx / dist) * 2; p.y -= (dy / dist) * 2; }
                                        }
                                        ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                                        let op = isDark ? p.opacity : p.opacity + 0.2;
                                        ctx.fillStyle = `rgba(${col}, ${op})`; ctx.fill();
                                        });

                                        for (let i = 0; i < particles.length; i++) {
                                        for (let j = i + 1; j < particles.length; j++) {
                                        const dx = particles[i].x - particles[j].x;
                                        const dy = particles[i].y - particles[j].y;
                                        const dist = Math.sqrt(dx * dx + dy * dy);
                                        if (dist < 120) {
                                        ctx.beginPath(); ctx.moveTo(particles[i].x, particles[i].y); ctx.lineTo(particles[j].x, particles[j].y);
                                        let lineOp = isDark ? 0.15 : 0.25;
                                        ctx.strokeStyle = `rgba(${col}, ${lineOp * (1 - dist / 120)})`;
                                        ctx.lineWidth = 1; ctx.stroke();
                                        }
                                        }
                                        }
                                        requestAnimationFrame(draw);
                                        }
                                        draw();
                                    </script>
                                </body>

