@model NormaQ.ViewModels.CrearDocumentoViewModel

@{
    ViewData["Title"] = "Nuevo Documento Lógico";
    Layout = "~/Views/Shared/_CrearDocumentoLayout.cshtml";
}

<div
    class="bg-white/70 dark:bg-[#0a0a0f]/80 backdrop-blur-2xl border border-white/40 dark:border-white/10 rounded-[28px] shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] dark:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.5)] overflow-hidden ring-1 ring-white/50 dark:ring-white/5">

    <div
        class="bg-gradient-to-r from-indigo-600 via-indigo-700 to-indigo-800 dark:from-indigo-900 dark:via-indigo-800 dark:to-[#0f0f18] p-6 sm:p-8 text-white flex justify-between items-center relative overflow-hidden">
        <div
            class="absolute right-0 top-0 w-[400px] h-[400px] bg-white/10 rounded-full blur-[80px] transform translate-x-1/3 -translate-y-1/2">
        </div>

        <div class="relative z-10 flex items-center gap-4">
            <div
                class="w-12 h-12 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 flex items-center justify-center shadow-inner">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            </div>
            <div>
                <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">Crear Documento Normativo</h2>
                <p class="text-indigo-200 text-xs sm:text-sm font-medium mt-1">
                    Registrando en: <strong
                    class="text-white bg-white/10 px-2 py-0.5 rounded">@Model.DepartamentoNombre</strong>
                </p>
            </div>
        </div>

        <div class="relative z-10 flex items-center gap-3">
            <button onclick="toggleTheme(event)"
                    class="w-10 h-10 rounded-full bg-black/20 hover:bg-black/40 border border-white/10 flex items-center justify-center transition-all hover:scale-105">
                <svg class="w-4 h-4 text-white block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                          d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                </svg>
                <svg class="w-4 h-4 text-amber-300 hidden dark:block" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                          d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
            </button>
            <a asp-controller="Home" asp-action="Index"
               class="w-10 h-10 rounded-full bg-white/10 hover:bg-red-500 border border-white/20 flex items-center justify-center transition-all hover:scale-105 text-white/80 hover:text-white hover:border-red-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </a>
        </div>
    </div>

    <div class="p-8 sm:p-10">

        <div class="relative mb-12 mx-auto w-4/5 sm:w-2/3">
            <div
                class="absolute top-1/2 left-0 w-full h-1.5 bg-slate-200 dark:bg-white/5 -translate-y-1/2 rounded-full overflow-hidden shadow-inner">
                <div id="progressBar" class="h-full bg-indigo-500 rounded-full transition-all duration-700 ease-out"
                     style="width: 0%;"></div>
            </div>
            <div class="flex justify-between relative z-10">
                <div class="flex flex-col items-center gap-2 -ml-4">
                    <div
                        class="w-10 h-10 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm font-bold shadow-[0_0_15px_rgba(79,70,229,0.5)] ring-4 ring-indigo-600/20 transition-all duration-300">
                        1</div>
                        <span
                        class="text-[10px] font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-widest absolute -bottom-6 whitespace-nowrap">Clasificación</span>
                    </div>
                    <div class="flex flex-col items-center gap-2 -mr-4">
                        <div id="indStep2"
                             class="w-10 h-10 rounded-full bg-white dark:bg-[#1a1a24] border-2 border-slate-200 dark:border-white/10 text-slate-400 flex items-center justify-center text-sm font-bold transition-all duration-700">
                            2</div>
                            <span id="textStep2"
                                  class="text-[10px] font-bold text-slate-400 uppercase tracking-widest absolute -bottom-6 whitespace-nowrap transition-colors duration-700">Firmas</span>
                        </div>
                    </div>
                </div>

                <form asp-action="CrearDocumento" method="post" id="wizardForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="DepartamentoId" />
                    <input type="hidden" asp-for="DepartamentoNombre" />
                    <input type="hidden" asp-for="TotalElaboradoresDisponibles" />
                    <input type="hidden" asp-for="TotalRevisoresDisponibles" />
                    <input type="hidden" asp-for="TotalAprobadoresDisponibles" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div
                            class="text-red-500 text-sm font-bold mb-6 bg-red-50 dark:bg-red-500/10 p-4 rounded-xl border border-red-200 dark:border-red-500/20 flex items-center gap-3">
                            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <div id="step1" class="transition-all duration-500 opacity-100 translate-y-0">
                        <div class="space-y-6">

                            <div>
                                <label asp-for="Nombre"
                                       class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2 ml-1">Nombre
                                    oficial del documento</label>
                                    <div class="input-wrapper">
                                        <svg class="input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                        </svg>
                                        <input asp-for="Nombre" placeholder="Ej. Procedimiento de Auditoría Interna"
                                               autocomplete="off" />
                                    </div>
                                    <span asp-validation-for="Nombre" class="val-error"></span>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div>
                                        <label asp-for="NivelId"
                                               class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2 ml-1">Nivel
                                            estructural</label>
                                            <div class="input-wrapper">
                                                <svg class="input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                                </svg>
                                                <select asp-for="NivelId" asp-items="Model.NivelesDisponibles">
                                                    <option value="">-- Seleccionar --</option>
                                                </select>
                                                <svg class="select-arrow" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                                </svg>
                                            </div>
                                            <span asp-validation-for="NivelId" class="val-error"></span>
                                        </div>

                                        <div>
                                            <label asp-for="NormaId"
                                                   class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2 ml-1">Normativa
                                                aplicable</label>
                                                <div class="input-wrapper">
                                                    <svg class="input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                                    </svg>
                                                    <select asp-for="NormaId" asp-items="Model.NormasDisponibles">
                                                        <option value="">-- Seleccionar --</option>
                                                    </select>
                                                    <svg class="select-arrow" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                                    </svg>
                                                </div>
                                                <span asp-validation-for="NormaId" class="val-error"></span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-10 pt-6 border-t border-slate-200 dark:border-white/10 flex justify-end">
                                        <button type="button" onclick="nextStep()"
                                                class="bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-3 rounded-xl text-sm font-bold shadow-[0_8px_20px_-6px_rgba(79,70,229,0.5)] transition-all hover:-translate-y-1 flex items-center gap-3 group">
                                            Configurar Firmas
                                            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none"
                                                 stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>

                                
                                <div id="step2" class="hidden opacity-0 translate-y-8 transition-all duration-500">

                                    <div
                                        class="bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-100 dark:border-indigo-500/20 p-4 rounded-2xl mb-6 flex items-start gap-4">
                                        <div class="bg-indigo-100 dark:bg-indigo-500/20 p-2 rounded-lg shrink-0">
                                            <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor"
                                                 viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                      d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                            </svg>
                                        </div>
                                        <div>
                                            <h4 class="text-sm font-bold text-indigo-900 dark:text-indigo-200 mb-0.5">Rutas de Autorización
                                            </h4>
                                            <p class="text-xs text-indigo-700 dark:text-indigo-300 font-medium">
                                                Define cuántas firmas necesita cada fase. El orden se construirá automáticamente:
                                                <strong class="text-indigo-900 dark:text-indigo-100">Elaboradores → Revisores →
                                                    Aprobadores</strong>.
                                                    Solo puedes añadir tantos slots como usuarios existan con ese rol en
                                                    <strong class="text-indigo-900 dark:text-indigo-100">@Model.DepartamentoNombre</strong>.
                                                </p>
                                            </div>
                                        </div>

                                        <div id="step2-scroll" class="space-y-6 pr-1">

                                            <div
                                                class="rounded-2xl border border-slate-200 dark:border-white/8 p-5 bg-white/40 dark:bg-white/[0.02]">
                                                <div class="flex items-center justify-between mb-4">
                                                    <div class="flex items-center gap-3">
                                                        <span
                                                            class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-white/10 flex items-center justify-center">
                                                            <svg class="w-4 h-4 text-slate-600 dark:text-slate-300" fill="none"
                                                                 stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                      d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                                            </svg>
                                                        </span>
                                                        <div>
                                                            <p class="text-sm font-bold text-slate-800 dark:text-slate-100">Elaboradores <span
                                                                class="text-[10px] font-semibold bg-slate-100 dark:bg-white/10 text-slate-500 dark:text-slate-400 px-2 py-0.5 rounded-full ml-1">Fase
                                                                1</span></p>
                                                                <p class="text-[11px] text-slate-500 dark:text-slate-400 font-medium mt-0.5">Crean y
                                                                    editan el borrador</p>
                                                                </div>
                                                            </div>
                                                            <div class="flex items-center gap-2">
                                                                <span class="text-[11px] text-slate-500 dark:text-slate-400 font-semibold"
                                                                      id="elaboradores-counter-label">
                                                                    <span id="elaboradores-remaining">@Model.TotalElaboradoresDisponibles</span>
                                                                    disponible(s)
                                                                </span>
                                                                <button type="button" onclick="addSlot('elaboradores', 4)" id="btn-add-elaborador"
                                                                        class="w-8 h-8 rounded-lg bg-indigo-600 hover:bg-indigo-500 disabled:opacity-30 disabled:cursor-not-allowed text-white flex items-center justify-center transition-all hover:scale-110 active:scale-95 shadow-sm"
                                                                    @(Model.TotalElaboradoresDisponibles <= 1 ? "disabled" : "")>
                                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                                              d="M12 4v16m8-8H4" />
                                                                    </svg>
                                                                </button>
                                                            </div>
                                                        </div>

                                                        <div id="slots-elaboradores" class="space-y-2">
                                                        </div>
                                                        <span class="val-error" id="err-elaboradores">
                                                            @Html.ValidationMessage("ElaboradoresSeleccionados")
                                                        </span>
                                                    </div>

                                                    <div
                                                        class="rounded-2xl border border-amber-200 dark:border-amber-500/20 p-5 bg-amber-50/40 dark:bg-amber-500/[0.03]">
                                                        <div class="flex items-center justify-between mb-4">
                                                            <div class="flex items-center gap-3">
                                                                <span
                                                                    class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-500/20 flex items-center justify-center">
                                                                    <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none"
                                                                         stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                                                                    </svg>
                                                                </span>
                                                                <div>
                                                                    <p class="text-sm font-bold text-slate-800 dark:text-slate-100">Revisores <span
                                                                        class="text-[10px] font-semibold bg-amber-100 dark:bg-amber-500/20 text-amber-600 dark:text-amber-400 px-2 py-0.5 rounded-full ml-1">Fase
                                                                        2</span></p>
                                                                        <p class="text-[11px] text-slate-500 dark:text-slate-400 font-medium mt-0.5">Validan
                                                                            técnicamente el documento</p>
                                                                        </div>
                                                                    </div>
                                                                    <div class="flex items-center gap-2">
                                                                        <span class="text-[11px] text-slate-500 dark:text-slate-400 font-semibold">
                                                                            <span id="revisores-remaining">@Model.TotalRevisoresDisponibles</span> disponible(s)
                                                                        </span>
                                                                        <button type="button" onclick="addSlot('revisores', 3)" id="btn-add-revisor"
                                                                                class="w-8 h-8 rounded-lg bg-amber-500 hover:bg-amber-400 disabled:opacity-30 disabled:cursor-not-allowed text-white flex items-center justify-center transition-all hover:scale-110 active:scale-95 shadow-sm"
                                                                            @(Model.TotalRevisoresDisponibles <= 1 ? "disabled" : "")>
                                                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                                                      d="M12 4v16m8-8H4" />
                                                                            </svg>
                                                                        </button>
                                                                    </div>
                                                                </div>
                                                                <div id="slots-revisores" class="space-y-2"></div>
                                                                <span class="val-error" id="err-revisores">
                                                                    @Html.ValidationMessage("RevisoresSeleccionados")
                                                                </span>
                                                            </div>

                                                            <div
                                                                class="rounded-2xl border border-emerald-200 dark:border-emerald-500/20 p-5 bg-emerald-50/40 dark:bg-emerald-500/[0.03]">
                                                                <div class="flex items-center justify-between mb-4">
                                                                    <div class="flex items-center gap-3">
                                                                        <span
                                                                            class="w-8 h-8 rounded-lg bg-emerald-100 dark:bg-emerald-500/20 flex items-center justify-center">
                                                                            <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none"
                                                                                 stroke="currentColor" viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                                      d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                                            </svg>
                                                                        </span>
                                                                        <div>
                                                                            <p class="text-sm font-bold text-slate-800 dark:text-slate-100">Aprobadores <span
                                                                                class="text-[10px] font-semibold bg-emerald-100 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 px-2 py-0.5 rounded-full ml-1">Fase
                                                                                3</span></p>
                                                                                <p class="text-[11px] text-slate-500 dark:text-slate-400 font-medium mt-0.5">Dan la
                                                                                    autorización final</p>
                                                                                </div>
                                                                            </div>
                                                                            <div class="flex items-center gap-2">
                                                                                <span class="text-[11px] text-slate-500 dark:text-slate-400 font-semibold">
                                                                                    <span id="aprobadores-remaining">@Model.TotalAprobadoresDisponibles</span>
                                                                                    disponible(s)
                                                                                </span>
                                                                                <button type="button" onclick="addSlot('aprobadores', 2)" id="btn-add-aprobador"
                                                                                        class="w-8 h-8 rounded-lg bg-emerald-500 hover:bg-emerald-400 disabled:opacity-30 disabled:cursor-not-allowed text-white flex items-center justify-center transition-all hover:scale-110 active:scale-95 shadow-sm"
                                                                                    @(Model.TotalAprobadoresDisponibles <= 1 ? "disabled" : "")>
                                                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                                                              d="M12 4v16m8-8H4" />
                                                                                    </svg>
                                                                                </button>
                                                                            </div>
                                                                        </div>
                                                                        <div id="slots-aprobadores" class="space-y-2"></div>
                                                                        <span class="val-error" id="err-aprobadores">
                                                                            @Html.ValidationMessage("AprobadoresSeleccionados")
                                                                        </span>
                                                                    </div>

                                                                    <div
                                                                        class="rounded-2xl border border-slate-200 dark:border-white/8 p-4 bg-white/40 dark:bg-white/[0.02]">
                                                                        <p
                                                                            class="text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-3">
                                                                            Vista previa del orden de firmas</p>
                                                                            <div id="sequence-preview" class="flex flex-wrap items-center gap-2 min-h-[36px]">
                                                                                <span class="text-xs text-slate-400 dark:text-slate-500 italic" id="preview-empty">Agrega al
                                                                                    menos un slot de cada fase para ver la secuencia.</span>
                                                                                </div>
                                                                            </div>

                                                                        </div>

                                                                        <div class="mt-6 pt-6 border-t border-slate-200 dark:border-white/10 flex justify-between items-center">
                                                                            <button type="button" onclick="prevStep()"
                                                                                    class="text-slate-500 hover:text-indigo-500 dark:hover:text-indigo-400 font-bold text-sm transition-colors flex items-center gap-2 group">
                                                                                <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none"
                                                                                     stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                                                          d="M15 19l-7-7 7-7" />
                                                                                </svg> Atrás
                                                                            </button>
                                                                            <button type="submit"
                                                                                    class="bg-emerald-500 hover:bg-emerald-400 text-white px-8 py-3 rounded-xl text-sm font-bold shadow-[0_8px_20px_-6px_rgba(16,185,129,0.5)] transition-all hover:-translate-y-1 flex items-center gap-3">
                                                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                                                          d="M5 13l4 4L19 7" />
                                                                                </svg> Finalizar Registro
                                                                            </button>
                                                                        </div>


                                                                </form>
                                                            </div>
                                                        </div>

                                                        @section Scripts {
                                                            <script>
                                                                // ══════════════════════════════════════════════════════════════
                                                                //  CONFIGURACIÓN GLOBAL
                                                                // ══════════════════════════════════════════════════════════════
                                                                const CONFIG = {
                                                                    elaboradores: {
                                                                        total:     @Model.TotalElaboradoresDisponibles,
                                                                        rolId: 4,
                                                                        color: 'slate',      // clase de color para el badge
                                                                        badgeCss: 'bg-slate-200 dark:bg-white/10 text-slate-700 dark:text-slate-300',
                                                                        addBtn: 'btn-add-elaborador',
                                                                        remaining: 'elaboradores-remaining',
                                                                        container: 'slots-elaboradores',
                                                                        inputName: 'ElaboradoresSeleccionados',
                                                                        label: 'Elaboró',
                                                                    },
                                                                    revisores: {
                                                                        total:     @Model.TotalRevisoresDisponibles,
                                                                        rolId: 3,
                                                                        badgeCss: 'bg-amber-100 dark:bg-amber-500/20 text-amber-700 dark:text-amber-400',
                                                                        addBtn: 'btn-add-revisor',
                                                                        remaining: 'revisores-remaining',
                                                                        container: 'slots-revisores',
                                                                        inputName: 'RevisoresSeleccionados',
                                                                        label: 'Revisó',
                                                                    },
                                                                    aprobadores: {
                                                                        total:     @Model.TotalAprobadoresDisponibles,
                                                                        rolId: 2,
                                                                        badgeCss: 'bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400',
                                                                        addBtn: 'btn-add-aprobador',
                                                                        remaining: 'aprobadores-remaining',
                                                                        container: 'slots-aprobadores',
                                                                        inputName: 'AprobadoresSeleccionados',
                                                                        label: 'Aprobó',
                                                                    }
                                                                };

                                                                // Contadores en tiempo real (cuántos slots hay activos de cada tipo)
                                                                const counts = { elaboradores: 0, revisores: 0, aprobadores: 0 };

                                                                // ══════════════════════════════════════════════════════════════
                                                                //  AÑADIR SLOT
                                                                // ══════════════════════════════════════════════════════════════
                                                                function addSlot(type, rolId) {
                                                                    const cfg = CONFIG[type];
                                                                    const limit = cfg.total;

                                                                    if (counts[type] >= limit) return;

                                                                    counts[type]++;
                                                                    const slotNumber = counts[type];

                                                                    const container = document.getElementById(cfg.container);
                                                                    const slot = document.createElement('div');
                                                                    slot.className = 'firma-slot';
                                                                    slot.dataset.type = type;
                                                                    slot.innerHTML = `
                                                                    <span class="slot-badge ${cfg.badgeCss}">${slotNumber}</span>
                                                                    <div class="flex-1 text-sm font-semibold text-slate-700 dark:text-slate-200 flex items-center gap-2">
                                                                        <svg class="w-3.5 h-3.5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                                                        </svg>
                                                                        <span>Cualquier usuario con rol <strong>${cfg.label.replace('ó', 'ador').replace('Revisó', 'Revisor').replace('Elaboró', 'Elaborador')}</strong></span>
                                                                    </div>
                                                                    <input type="hidden" name="${cfg.inputName}" value="${rolId}" />
                                                                    ${slotNumber > 1
                                                                            ? `<button type="button" class="btn-remove-slot" onclick="removeSlot(this, '${type}')">
                                                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                                                                            </svg>
                                                                           </button>`
                                                                            : '<span class="w-7"></span>'}
                                                                `;
                                                                    container.appendChild(slot);

                                                                    updateRemaining(type);
                                                                    updateSequencePreview();
                                                                }

                                                                // ══════════════════════════════════════════════════════════════
                                                                //  ELIMINAR SLOT
                                                                // ══════════════════════════════════════════════════════════════
                                                                function removeSlot(btn, type) {
                                                                    const slot = btn.closest('.firma-slot');
                                                                    slot.style.opacity = '0';
                                                                    slot.style.transform = 'scale(0.95)';
                                                                    slot.style.transition = 'all 0.2s ease';
                                                                    setTimeout(() => {
                                                                        slot.remove();
                                                                        counts[type]--;
                                                                        renumberSlots(type);
                                                                        updateRemaining(type);
                                                                        updateSequencePreview();
                                                                    }, 200);
                                                                }

                                                                // ══════════════════════════════════════════════════════════════
                                                                //  RE-NUMERAR BADGES tras eliminación
                                                                // ══════════════════════════════════════════════════════════════
                                                                function renumberSlots(type) {
                                                                    const container = document.getElementById(CONFIG[type].container);
                                                                    const slots = container.querySelectorAll('.firma-slot');
                                                                    slots.forEach((slot, i) => {
                                                                        slot.querySelector('.slot-badge').textContent = i + 1;
                                                                        // Si es el primer slot, eliminar el botón de quitar
                                                                        const removeBtn = slot.querySelector('.btn-remove-slot');
                                                                        if (i === 0 && removeBtn) removeBtn.remove();
                                                                        // Si es slot adicional y no tiene botón, añadirlo
                                                                        if (i > 0 && !slot.querySelector('.btn-remove-slot')) {
                                                                            const spacer = slot.querySelector('span.w-7');
                                                                            if (spacer) spacer.remove();
                                                                            const newBtn = document.createElement('button');
                                                                            newBtn.type = 'button';
                                                                            newBtn.className = 'btn-remove-slot';
                                                                            newBtn.onclick = function () { removeSlot(this, type); };
                                                                            newBtn.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>`;
                                                                            slot.appendChild(newBtn);
                                                                        }
                                                                    });
                                                                }

                                                                // ══════════════════════════════════════════════════════════════
                                                                //  ACTUALIZAR CONTADOR DE DISPONIBLES
                                                                // ══════════════════════════════════════════════════════════════
                                                                function updateRemaining(type) {
                                                                    const cfg = CONFIG[type];
                                                                    const rem = cfg.total - counts[type];
                                                                    document.getElementById(cfg.remaining).textContent = rem;
                                                                    const addBtn = document.getElementById(cfg.addBtn);
                                                                    if (rem <= 0) {
                                                                        addBtn.disabled = true;
                                                                    } else {
                                                                        addBtn.disabled = false;
                                                                    }
                                                                }

                                                                // ══════════════════════════════════════════════════════════════
                                                                //  PREVIEW DE SECUENCIA
                                                                // ══════════════════════════════════════════════════════════════
                                                                function updateSequencePreview() {
                                                                    const preview = document.getElementById('sequence-preview');
                                                                    const empty = document.getElementById('preview-empty');
                                                                    const total = counts.elaboradores + counts.revisores + counts.aprobadores;

                                                                    if (total === 0) {
                                                                        if (empty) empty.style.display = '';
                                                                        preview.querySelectorAll('.preview-chip').forEach(c => c.remove());
                                                                        return;
                                                                    }
                                                                    if (empty) empty.style.display = 'none';

                                                                    // Limpiar chips
                                                                    preview.querySelectorAll('.preview-chip').forEach(c => c.remove());

                                                                    let order = 1;
                                                                    const phases = [
                                                                        { type: 'elaboradores', label: 'Elaboró', css: 'bg-slate-100 dark:bg-white/10 text-slate-700 dark:text-slate-300 border-slate-200 dark:border-white/10' },
                                                                        { type: 'revisores', label: 'Revisó', css: 'bg-amber-100 dark:bg-amber-500/20 text-amber-700 dark:text-amber-400 border-amber-200 dark:border-amber-500/20' },
                                                                        { type: 'aprobadores', label: 'Aprobó', css: 'bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 border-emerald-200 dark:border-emerald-500/20' },
                                                                    ];

                                                                    phases.forEach(p => {
                                                                        for (let i = 0; i < counts[p.type]; i++) {
                                                                            const chip = document.createElement('div');
                                                                            chip.className = `preview-chip flex items-center gap-1.5 px-3 py-1.5 rounded-lg border text-[11px] font-bold ${p.css}`;
                                                                            chip.innerHTML = `<span class="opacity-60 font-mono">#${order}</span> ${p.label}`;
                                                                            preview.appendChild(chip);
                                                                            // Flecha separadora (no en el último)
                                                                            order++;
                                                                        }
                                                                    });

                                                                    // Añadir flechas entre chips
                                                                    const chips = preview.querySelectorAll('.preview-chip');
                                                                    chips.forEach((chip, i) => {
                                                                        if (i < chips.length - 1) {
                                                                            const arrow = document.createElement('span');
                                                                            arrow.className = 'preview-chip text-slate-300 dark:text-white/20 text-sm font-bold';
                                                                            arrow.textContent = '→';
                                                                            chip.after(arrow);
                                                                        }
                                                                    });
                                                                }

                                                                // ══════════════════════════════════════════════════════════════
                                                                //  WIZARD STEP NAVIGATION
                                                                // ══════════════════════════════════════════════════════════════
                                                                const step1 = document.getElementById('step1');
                                                                const step2 = document.getElementById('step2');
                                                                const progressBar = document.getElementById('progressBar');
                                                                const indStep2 = document.getElementById('indStep2');
                                                                const textStep2 = document.getElementById('textStep2');

                                                                function nextStep() {
                                                                    step1.classList.remove('opacity-100', 'translate-y-0');
                                                                    step1.classList.add('opacity-0', '-translate-y-8');
                                                                    setTimeout(() => {
                                                                        step1.classList.add('hidden');
                                                                        step2.classList.remove('hidden');
                                                                        void step2.offsetWidth;
                                                                        step2.classList.remove('opacity-0', 'translate-y-8');
                                                                        step2.classList.add('opacity-100', 'translate-y-0');
                                                                        progressBar.style.width = '100%';
                                                                        indStep2.className = 'w-10 h-10 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm font-bold shadow-[0_0_15px_rgba(79,70,229,0.5)] ring-4 ring-indigo-600/20 transition-all duration-700';
                                                                        textStep2.className = 'text-[10px] font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-widest absolute -bottom-6 whitespace-nowrap transition-colors duration-700';
                                                                        // Inicializar slots vacíos si es la primera vez
                                                                        initSlots();
                                                                    }, 500);
                                                                }

                                                                function prevStep() {
                                                                    step2.classList.remove('opacity-100', 'translate-y-0');
                                                                    step2.classList.add('opacity-0', 'translate-y-8');
                                                                    setTimeout(() => {
                                                                        step2.classList.add('hidden');
                                                                        step1.classList.remove('hidden');
                                                                        void step1.offsetWidth;
                                                                        step1.classList.remove('opacity-0', '-translate-y-8');
                                                                        step1.classList.add('opacity-100', 'translate-y-0');
                                                                        progressBar.style.width = '0%';
                                                                        indStep2.className = 'w-10 h-10 rounded-full bg-white dark:bg-[#1a1a24] border-2 border-slate-200 dark:border-white/10 text-slate-400 flex items-center justify-center text-sm font-bold transition-all duration-700';
                                                                        textStep2.className = 'text-[10px] font-bold text-slate-400 uppercase tracking-widest absolute -bottom-6 whitespace-nowrap transition-colors duration-700';
                                                                    }, 500);
                                                                }

                                                                // Inicializa los 3 slots mínimos obligatorios (1 por fase)
                                                                let slotsInitialized = false;
                                                                function initSlots() {
                                                                    if (slotsInitialized) return;
                                                                    slotsInitialized = true;
                                                                    addSlot('elaboradores', 4);
                                                                    addSlot('revisores', 3);
                                                                    addSlot('aprobadores', 2);
                                                                }
                                                            </script>
                                                        }
