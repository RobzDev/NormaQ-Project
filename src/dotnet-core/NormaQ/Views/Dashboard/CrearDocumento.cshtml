@model NormaQ.ViewModels.CrearDocumentoViewModel

@{
    ViewData["Title"] = "Nuevo Documento Lógico";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-dark text-white p-4">
                    <h4 class="mb-0"><i class="bi bi-file-earmark-plus me-2"></i>Crear Documento Normativo</h4>
                    <small class="text-light opacity-75">Departamento: @Model.DepartamentoNombre</small>
                </div>

                <div class="card-body p-5">
                    <form asp-action="CrearDocumento" method="post" id="wizardForm">
                        <input type="hidden" asp-for="DepartamentoId" />
                        <input type="hidden" asp-for="DepartamentoNombre" />

                        <!-- Indicadores de Progreso -->
                        <div class="d-flex justify-content-between mb-5 position-relative">
                            <div class="progress position-absolute top-50 start-0 w-100 translate-middle-y"
                                 style="height: 3px; z-index: 0;">
                                <div id="progressBar" class="progress-bar bg-primary" role="progressbar"
                                     style="width: 0%;"></div>
                            </div>
                            <button type="button"
                                    class="btn btn-primary rounded-circle position-relative z-1 fw-bold step-indicator"
                                    style="width: 40px; height: 40px;" id="indStep1">1</button>
                            <button type="button"
                                    class="btn btn-secondary rounded-circle position-relative z-1 fw-bold step-indicator"
                                    style="width: 40px; height: 40px;" id="indStep2">2</button>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- ========================================== -->
                        <!-- PASO 1: IDENTIDAD LÓGICA -->
                        <!-- ========================================== -->
                        <div id="step1">
                            <h5 class="fw-bold mb-4 text-primary">Paso 1: Identidad y Clasificación</h5>
                            
                            <div class="mb-4">
                                <label asp-for="Nombre" class="form-label fw-bold"></label>
                                <input asp-for="Nombre" class="form-control form-control-lg"
                                       placeholder="Ej. Control de Documentos" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label asp-for="NivelId" class="form-label fw-bold"></label>
                                    <select asp-for="NivelId" asp-items="Model.NivelesDisponibles" class="form-select">
                                        <option value="">-- Seleccione Nivel --</option>
                                    </select>
                                    <span asp-validation-for="NivelId" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label asp-for="NormaId" class="form-label fw-bold"></label>
                                    <select asp-for="NormaId" asp-items="Model.NormasDisponibles" class="form-select">
                                        <option value="">-- Seleccione Norma --</option>
                                    </select>
                                    <span asp-validation-for="NormaId" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="button" class="btn btn-primary px-4" onclick="nextStep()">Siguiente Paso
                                    <i class="bi bi-arrow-right ms-2"></i></button>
                                </div>
                            </div>

                            <!-- ========================================== -->
                            <!-- PASO 2: PLANTILLA DE FIRMAS -->
                            <!-- ========================================== -->
                            <div id="step2" class="d-none">
                                <h5 class="fw-bold mb-4 text-primary">Paso 2: Secuencia de Autorización</h5>
                            
                                <div class="alert alert-info border-0 shadow-sm mb-4">
                                    <i class="bi bi-info-circle-fill me-2"></i>
                                    Solo se muestran los roles que actualmente tienen usuarios asignados en
                                    <strong>@Model.DepartamentoNombre</strong>.
                                </div>

                                <div class="mb-3 border p-3 rounded bg-light">
                                    <label asp-for="RolElaboroId" class="form-label fw-bold"><span
                                        class="badge bg-secondary me-2">Orden 1</span> ¿Quién elaborará las
                                        versiones?</label>
                                        <select asp-for="RolElaboroId" asp-items="Model.RolesDisponibles" class="form-select">
                                            <option value="">-- Seleccione Rol Elaborador --</option>
                                        </select>
                                        <span asp-validation-for="RolElaboroId" class="text-danger small"></span>
                                    </div>

                                    <div class="mb-3 border p-3 rounded bg-light">
                                        <label asp-for="RolRevisoId" class="form-label fw-bold"><span
                                            class="badge bg-secondary me-2">Orden 2</span> ¿Quién realizará la revisión
                                            técnica?</label>
                                            <select asp-for="RolRevisoId" asp-items="Model.RolesDisponibles" class="form-select">
                                                <option value="">-- Seleccione Rol Revisor --</option>
                                            </select>
                                            <span asp-validation-for="RolRevisoId" class="text-danger small"></span>
                                        </div>

                                        <div class="mb-4 border p-3 rounded bg-light">
                                            <label asp-for="RolAproboId" class="form-label fw-bold"><span
                                                class="badge bg-secondary me-2">Orden 3</span> ¿Quién dará la aprobación
                                                final?</label>
                                                <select asp-for="RolAproboId" asp-items="Model.RolesDisponibles" class="form-select">
                                                    <option value="">-- Seleccione Rol Aprobador --</option>
                                                </select>
                                                <span asp-validation-for="RolAproboId" class="text-danger small"></span>
                                            </div>

                                            <div class="d-flex justify-content-between">
                                                <button type="button" class="btn btn-outline-secondary px-4" onclick="prevStep()"><i
                                                    class="bi bi-arrow-left me-2"></i> Atrás</button>
                                                    <button type="submit" class="btn btn-success px-4"><i
                                                        class="bi bi-check-circle me-2"></i> Crear Documento Lógico</button>
                                                    </div>
                                                </div>

                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @section Scripts {
                            <partial name="_ValidationScriptsPartial" />
                            <script>
                                function nextStep() {
                                    // Lógica simple de Wizard
                                    document.getElementById('step1').classList.add('d-none');
                                    document.getElementById('step2').classList.remove('d-none');
            
                                    document.getElementById('progressBar').style.width = '100%';
                                    document.getElementById('indStep2').classList.replace('btn-secondary', 'btn-primary');
                                }

                                function prevStep() {
                                    document.getElementById('step2').classList.add('d-none');
                                    document.getElementById('step1').classList.remove('d-none');
            
                                    document.getElementById('progressBar').style.width = '0%';
                                    document.getElementById('indStep2').classList.replace('btn-primary', 'btn-secondary');
                                }
                            </script>
                        }