@model NormaQ.Models.Documento

@{
    ViewData["Title"] = "Nueva Versión";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index"
                                                       asp-route-selectedDeptId="@Model.DepartamentoId">Dashboard</a></li>
                        <li class="breadcrumb-item active">Nueva Versión</li>
                    </ol>
                </nav>

                <div class="card shadow-sm border-0">
                    <div class="card-header bg-success text-white p-4">
                        <h4 class="mb-0"><i class="bi bi-cloud-arrow-up-fill me-2"></i>Preparando Nueva Versión</h4>
                    </div>
                    <div class="card-body p-4">
                        <div class="alert alert-secondary border-0">
                            <h5 class="fw-bold text-dark">Contexto del Documento Lógico:</h5>
                            <hr />
                            <div class="row">
                                <div class="col-sm-4 text-muted small text-uppercase fw-bold">ID Interno:</div>
                                <div class="col-sm-8 mb-2"><span class="badge bg-dark">@Model.Id</span></div>

                                <div class="col-sm-4 text-muted small text-uppercase fw-bold">Código ISO:</div>
                                <div class="col-sm-8 mb-2 fw-bold text-primary">@Model.Codigo</div>

                                <div class="col-sm-4 text-muted small text-uppercase fw-bold">Nombre:</div>
                                <div class="col-sm-8 mb-2">@Model.Nombre</div>

                                <div class="col-sm-4 text-muted small text-uppercase fw-bold">Departamento:</div>
                                <div class="col-sm-8 mb-2">@Model.Departamento?.Nombre</div>
                            </div>
                        </div>

                        <div class="text-center py-5 border border-dashed rounded mt-4">
                            <i class="bi bi-file-earmark-pdf text-muted display-1"></i>
                            <h4 class="mt-3">Zona de Carga (Placeholder)</h4>
                            <p class="text-muted">Aquí implementaremos la integración con <strong>MinIO</strong> y el
                                formulario para definir si es una versión mayor (1.0) o menor (0.1).</p>
                        
                                <div class="mt-4">
                                    <button class="btn btn-secondary disabled">
                                        <i class="bi bi-lock-fill me-1"></i> Esperando implementación de almacenamiento
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-light d-flex justify-content-between">
                            <a asp-action="Index" asp-route-selectedDeptId="@Model.DepartamentoId"
                                   class="btn btn-outline-secondary">
                                Cancelar
                            </a>
                            <span class="text-muted small align-self-center">Preparado para @User.Identity?.Name</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>