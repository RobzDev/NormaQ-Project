@model NormaQ.Models.VersionesDocumento

@{
    ViewData["Title"] = $"v{Model.VersionMayor}.{Model.VersionMenor} - {Model.Documento.Nombre}";
    Layout = null;

    bool esEditable = ViewBag.Editable == true;
    bool intervencion = ViewBag.RequiereMiIntervencion == true;
    string extension = System.IO.Path.GetExtension(Model.MinioIdentifier ?? "").ToLower();

    bool esPdf = extension == ".pdf";
    bool esImagen = new[] { ".png", ".jpg", ".jpeg", ".gif", ".webp" }.Contains(extension);
    bool esTexto = new[] { ".txt", ".md", ".csv", ".log", ".json", ".xml", ".yaml", ".yml" }.Contains(extension);
    bool esWord = new[] { ".doc", ".docx" }.Contains(extension);
    bool esExcel = new[] { ".xls", ".xlsx" }.Contains(extension);

    string urlInline = Url.Action("DescargarArchivo", new { versionId = Model.Id, inline = true })!;
    string urlDescarga = Url.Action("DescargarArchivo", new { versionId = Model.Id })!;

    string labelTipo = extension switch
    {
        ".docx" or ".doc" => "Documento Word",
        ".xlsx" or ".xls" => "Hoja de cálculo Excel",
        ".dwg" or ".dxf" => "Archivo CAD",
        ".zip" or ".rar" => "Archivo comprimido",
        _ => "Archivo binario"
    };

    string formatBgColor = extension switch
    {
        ".pdf" => "bg-red-100 text-red-700 border-red-200 dark:bg-red-500/20 dark:text-red-400 dark:border-red-500/30 shadow-[0_0_10px_rgba(239,68,68,0.2)]",
        ".doc" or ".docx" => "bg-blue-100 text-blue-700 border-blue-200 dark:bg-blue-500/20 dark:text-blue-400 dark:border-blue-500/30 shadow-[0_0_10px_rgba(59,130,246,0.2)]",
        ".xls" or ".xlsx" => "bg-emerald-100 text-emerald-700 border-emerald-200 dark:bg-emerald-500/20 dark:text-emerald-400 dark:border-emerald-500/30 shadow-[0_0_10px_rgba(16,185,129,0.2)]",
        ".zip" or ".rar" => "bg-amber-100 text-amber-700 border-amber-200 dark:bg-amber-500/20 dark:text-amber-400 dark:border-amber-500/30",
        _ => "bg-slate-200 text-slate-700 border-slate-300 dark:bg-white/10 dark:text-slate-300 dark:border-white/20"
    };

    string formatIconColor = extension switch
    {
        ".pdf" => "text-red-500",
        ".doc" or ".docx" => "text-blue-500",
        ".xls" or ".xlsx" => "text-emerald-500",
        _ => "text-slate-500 dark:text-slate-400"
    };

    string badgeColor = Model.Estado switch
    {
        "Aprobado" => "bg-emerald-100 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400 border-emerald-200 dark:border-emerald-400/20",
        "Revision" => "bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border-amber-200 dark:border-amber-400/20",
        "Borrador" => "bg-slate-200 text-slate-700 dark:bg-white/10 dark:text-slate-300 border-slate-300 dark:border-slate-400/20",
        "Obsoleto" => "bg-red-100 text-red-700 dark:bg-red-500/10 dark:text-red-400 border-red-200 dark:border-red-400/20",
        _ => "bg-slate-100 text-slate-700 dark:bg-white/5 dark:text-slate-400"
    };
    string dotColor = Model.Estado switch
    {
        "Aprobado" => "bg-emerald-500",
        "Revision" => "bg-amber-500",
        "Borrador" => "bg-slate-500",
        "Obsoleto" => "bg-red-500",
        _ => "bg-slate-500"
    };
}

<!DOCTYPE html>
<html lang="es" class="dark antialiased">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet">

    <script>
        tailwind.config = {
        darkMode: 'class',
        theme: {
        extend: {
        fontFamily: {
        sans: ['Plus Jakarta Sans', 'sans-serif'],
        display: ['Space Grotesk', 'sans-serif'],
        mono: ['JetBrains Mono', 'monospace'],
        },
        animation: {
        'fade-in': 'fadeIn 0.6s ease-out forwards',
        'slide-in-right': 'slideInRight 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards',
        'pulse-glow': 'pulseGlow 2s infinite',
        },
        keyframes: {
        fadeIn: { '0%': { opacity: '0', transform: 'translateY(10px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } },
        slideInRight: { '0%': { opacity: '0', transform: 'translateX(40px) scale(0.98)' }, '100%': { opacity: '1', transform: 'translateX(0) scale(1)' } },
        pulseGlow: { '0%, 100%': { boxShadow: '0 0 15px rgba(245,158,11,0.2)' }, '50%': { boxShadow: '0 0 25px rgba(245,158,11,0.5)' } },
        }
        }
        }
        }

        function toggleTheme(event) {
        const html = document.documentElement;
        if (!document.startViewTransition) { html.classList.toggle('dark'); return; }
        const x = event?.clientX ?? window.innerWidth / 2;
        const y = event?.clientY ?? window.innerHeight / 2;
        const r = Math.hypot(Math.max(x, window.innerWidth - x), Math.max(y, window.innerHeight - y));
        const transition = document.startViewTransition(() => { html.classList.toggle('dark'); });
        transition.ready.then(() => {
        document.documentElement.animate(
        { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${r}px at ${x}px ${y}px)`] },
        { duration: 600, easing: 'cubic-bezier(0.4,0,0.2,1)', pseudoElement: '::view-transition-new(root)' }
        );
        });
        }
    </script>

    <style>
        * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        }

        body {
        overflow: hidden;
        width: 100vw;
        height: 100vh;
        background-color: #050508;
        transition: background-color 0.3s ease;
        }

        html:not(.dark) body {
        background-color: #f8fafc;
        }

        ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
        }

        ::-webkit-scrollbar-track {
        background: transparent;
        }

        ::-webkit-scrollbar-thumb {
        background-color: rgba(99, 102, 241, 0.3);
        border-radius: 10px;
        }

        .dark ::-webkit-scrollbar-thumb {
        background-color: rgba(255, 255, 255, 0.15);
        }

        .hidden-scrollbar::-webkit-scrollbar {
        display: none;
        }

        ::view-transition-old(root),
        ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
        }

        ::view-transition-old(root) {
        z-index: 1;
        }

        ::view-transition-new(root) {
        z-index: 9999;
        }

        .input-glass {
        background: rgba(255, 255, 255, 0.6);
        border: 1px solid rgba(0, 0, 0, 0.1);
        color: #1e293b;
        transition: all 0.3s;
        outline: none;
        }

        .dark .input-glass {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #f1f5f9;
        }

        .input-glass:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
        }

        .pdf-viewer {
        transition: filter 0.5s ease;
        background-color: #ffffff;
        }

        .dark .pdf-viewer {
        filter: invert(95%) hue-rotate(210deg) brightness(95%) contrast(85%);
        }

        /* DETONADOR ANTI-BORROSO PARA MÓVILES */
        .no-blur-mobile .bg-indigo-500\/10,
        .no-blur-mobile .bg-purple-500\/10 {
        display: none !important;
        filter: none !important;
        }

        html.no-blur-mobile header,
        html.no-blur-mobile .viewer-aside,
        html.no-blur-mobile .aside-overlay {
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        }

        @@media (max-width: 1023.98px) {
        .viewer-aside {
        position: fixed !important;
        top: 0;
        left: 0;
        bottom: 0;
        height: 100vh;
        z-index: 50 !important;
        transform: translateX(-100%);
        transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        background-color: rgba(255, 255, 255, 0.98) !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        }

        .dark .viewer-aside {
        background-color: rgba(10, 10, 15, 0.98) !important;
        }

        .viewer-aside.aside-open {
        transform: translateX(0);
        box-shadow: 20px 0 25px -5px rgba(0, 0, 0, 0.4);
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        }

        .aside-overlay {
        position: fixed;
        inset: 0;
        background-color: rgba(0, 0, 0, 0.58);
        z-index: 40;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s ease;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        }

        .aside-overlay.overlay-open {
        opacity: 1;
        pointer-events: auto;
        }

        /* En móvil ocultamos el iframe de PDF problemático y activamos la tarjeta nativa */
        .desktop-pdf {
        display: none !important;
        }

        .mobile-pdf {
        display: flex !important;
        }
        }

        @@media (min-width: 1024px) {
        .mobile-pdf {
        display: none !important;
        }

        .desktop-pdf {
        display: block !important;
        width: 100%;
        height: 100%;
        }
        }
    </style>
</head>

<body class="flex flex-col text-slate-800 dark:text-slate-200">

    <div
        class="fixed top-[-20%] right-[-10%] w-[500px] h-[500px] bg-indigo-500/10 rounded-full blur-[120px] pointer-events-none z-0">
    </div>
    <div
        class="fixed bottom-[-20%] left-[-10%] w-[400px] h-[400px] bg-purple-500/10 rounded-full blur-[120px] pointer-events-none z-0 hidden dark:block">
    </div>

    <div class="aside-overlay" id="asideOverlay" onclick="cerrarAside()"></div>

    <header
        class="h-16 border-b border-slate-200/60 dark:border-white/5 bg-white/80 dark:bg-[#050508]/80 backdrop-blur-md px-4 sm:px-6 flex items-center justify-between shrink-0 relative z-20">
        <div class="flex items-center gap-2 sm:gap-4 overflow-hidden mr-2">
            <button onclick="abrirAside()"
                    class="lg:hidden w-9 h-9 rounded-xl bg-slate-200/50 hover:bg-slate-300 dark:bg-white/5 dark:hover:bg-white/10 flex items-center justify-center shrink-0 text-slate-600 dark:text-slate-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16">
                    </path>
                </svg>
            </button>
            <a asp-controller="Dashboard" asp-action="Index" asp-route-selectedDeptId="@Model.Documento.DepartamentoId"
               class="w-8 h-8 rounded-full bg-slate-200/50 hover:bg-slate-300 dark:bg-white/5 dark:hover:bg-white/10 flex items-center justify-center transition-transform hover:-translate-x-1 text-slate-600 dark:text-slate-300 shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
                </svg>
            </a>
            <div class="h-6 w-px bg-slate-300 dark:bg-white/10 shrink-0"></div>
            <div class="overflow-hidden min-w-0">
                <h1 class="text-xs sm:text-sm font-bold font-display flex items-center gap-1.5 truncate">
                    <span class="text-indigo-600 dark:text-indigo-400 shrink-0">@Model.Documento.Codigo</span>
                    <span class="text-slate-400 dark:text-slate-600 shrink-0">/</span>
                    <span class="truncate">@Model.Documento.Nombre</span>
                </h1>
            </div>
        </div>

        <div class="flex items-center gap-2 sm:gap-4 shrink-0">
            <span
                class="inline-flex items-center gap-1.5 px-2.5 py-1 sm:px-3 sm:py-1 rounded-full text-[9px] sm:text-[10px] font-bold uppercase tracking-widest border @badgeColor shadow-sm">
                <span class="w-1.5 h-1.5 rounded-full @dotColor animate-pulse"></span> @Model.Estado
            </span>
            <button onclick="toggleTheme(event)"
                    class="w-9 h-9 rounded-full bg-slate-200/50 hover:bg-slate-300 dark:bg-white/5 dark:hover:bg-white/10 flex items-center justify-center transition-all hover:rotate-12 text-slate-600 dark:text-amber-300">
                <svg class="w-4 h-4 block dark:hidden transition-all duration-300" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                          d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z">
                    </path>
                </svg>
                <svg class="w-4 h-4 hidden dark:block transition-all duration-300" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                          d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z">
                    </path>
                </svg>
            </button>
        </div>
    </header>

    <main class="flex-1 flex overflow-hidden relative z-10">

        <aside id="viewerAside"
               class="viewer-aside w-[320px] sm:w-[380px] lg:w-[380px] shrink-0 border-r border-slate-200/60 dark:border-white/5 bg-white/30 dark:bg-[#0a0a0f]/60 backdrop-blur-xl flex flex-col p-5 sm:p-6 overflow-y-auto hidden-scrollbar lg:flex z-20">
            <div
                class="flex lg:hidden items-center justify-between mb-4 pb-2 border-b border-slate-200/60 dark:border-white/5">
                <span class="text-xs font-bold font-display uppercase tracking-wider text-slate-400">Controles</span>
                <button onclick="cerrarAside()"
                        class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-white/5 flex items-center justify-center text-slate-500">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                </button>
            </div>

            @if (TempData["ErrorFirma"] != null)
            {
                <div
                    class="bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-600 dark:text-red-400 px-4 py-3 rounded-xl text-xs font-bold mb-4 flex items-start gap-2 shadow-sm animate-fade-in">
                    <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span>@TempData["ErrorFirma"]</span>
                </div>
            }

            <div
                class="bg-white/70 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 rounded-2xl p-5 mb-6 shadow-sm animate-fade-in relative overflow-hidden">
                <svg class="absolute -right-4 -bottom-4 w-32 h-32 opacity-5 @formatIconColor" fill="currentColor"
                     viewBox="0 0 24 24">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6z" />
                </svg>

                <div class="relative z-10">
                    <p
                        class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-4 flex items-center gap-2">
                        <svg class="w-3.5 h-3.5 @formatIconColor" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                            </path>
                        </svg>
                        Gestión de la Versión
                    </p>
                    <div class="flex justify-between items-end">
                        <div>
                            <p class="text-[10px] text-slate-500 dark:text-slate-400 mb-1 font-medium">Identificador
                                Actual</p>
                                <h2 class="text-4xl font-display font-bold text-slate-800 dark:text-white tracking-tight">
                                    v@(Model.VersionMayor).@(Model.VersionMenor)</h2>
                                </div>
                                <div class="text-right">
                                    <p class="text-[9px] uppercase font-bold text-slate-400 mb-1.5">Formato</p>
                                    <span class="px-2.5 py-1 rounded-lg text-[10px] font-bold font-mono border @formatBgColor">
                                        @extension.ToUpper()
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (intervencion)
                    {
                        <div
                            class="bg-amber-50/50 dark:bg-amber-500/5 border border-amber-200/60 dark:border-amber-500/20 rounded-2xl p-5 mb-6 shadow-sm relative overflow-hidden animate-fade-in animate-pulse-glow group">
                            <div class="absolute top-0 left-0 w-1.5 h-full bg-amber-400 dark:bg-amber-500"></div>

                            <div class="flex items-center gap-2 mb-2">
                                <div
                                    class="w-6 h-6 rounded-full bg-amber-100 dark:bg-amber-500/20 flex items-center justify-center">
                                    <svg class="w-3.5 h-3.5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                              d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z">
                                        </path>
                                    </svg>
                                </div>
                                <h3 class="text-sm font-bold text-amber-800 dark:text-amber-400">Acción Pendiente</h3>
                            </div>
                            <p class="text-xs text-amber-700/80 dark:text-amber-300/70 mb-4 ml-0 sm:ml-8">Verifique el documento y
                                seleccione un veredicto.</p>

                                <form asp-action="FirmarDocumento" method="post" id="formFirma" class="ml-0 sm:ml-8">
                                    <input type="hidden" name="VersionId" value="@Model.Id" />
                                    <input type="hidden" id="inputAccion" name="Accion" value="" />

                                    <div class="mb-4">
                                        <label
                                            class="block text-[9px] font-bold text-amber-700 dark:text-amber-500 uppercase tracking-widest mb-1.5">Comentarios
                                            (Req. si rechaza)</label>
                                            <textarea name="Comentarios" rows="3"
                                                      class="w-full bg-white/60 dark:bg-black/30 border border-amber-200 dark:border-amber-500/30 rounded-xl p-3 text-xs text-slate-700 dark:text-slate-300 focus:outline-none focus:ring-2 focus:ring-amber-500 resize-none transition-all"
                                                      placeholder="Observaciones técnicas o de calidad..."></textarea>
                                        </div>

                                        <div class="flex gap-3">
                                            <button type="button" onclick="enviarFirma('Rechazado')"
                                                    class="flex-1 bg-rose-50 hover:bg-rose-100 dark:bg-rose-500/10 dark:hover:bg-rose-500/20 text-rose-600 dark:text-rose-400 border border-rose-200 dark:border-rose-500/30 py-2.5 rounded-xl text-xs font-bold transition-transform hover:-translate-y-0.5 flex items-center justify-center gap-1.5">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                          d="M6 18L18 6M6 6l12 12"></path>
                                                </svg> Rechazar
                                            </button>
                                            <button type="button" onclick="enviarFirma('Aprobado')"
                                                    class="flex-1 bg-emerald-500 hover:bg-emerald-400 text-white py-2.5 rounded-xl text-xs font-bold shadow-[0_4px_15px_-3px_rgba(16,185,129,0.4)] transition-transform hover:-translate-y-0.5 flex items-center justify-center gap-1.5 active:scale-95">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                          d="M5 13l4 4L19 7"></path>
                                                </svg> Aprobar
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            }
            else
                            {
                                <div
                                    class="bg-slate-100/50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-2xl p-5 mb-6 flex items-center gap-3 animate-fade-in">
                                    <div
                                        class="w-10 h-10 rounded-full bg-slate-200 dark:bg-black/30 flex items-center justify-center text-slate-500">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z">
                                            </path>
                                        </svg>
                                    </div>
                                    <div>
                                        <h4 class="text-sm font-bold text-slate-800 dark:text-white">Modo Lectura</h4>
                                        <p class="text-[10px] text-slate-500 leading-tight mt-0.5">Sin privilegios de edición actuales.</p>
                                    </div>
                                </div>
                            }

                            @if (esEditable)
                            {
                                <div class="mt-6 pt-5 border-t border-amber-200/50 dark:border-white/5 ml-0 sm:ml-8">
                                    <button onclick="abrirModal()"
                                            class="w-full bg-white dark:bg-white/5 hover:bg-slate-50 dark:hover:bg-white/10 border border-slate-200 dark:border-white/10 text-slate-700 dark:text-slate-300 py-2.5 rounded-xl text-xs font-bold transition-all flex items-center justify-center gap-2 group hover:-translate-y-0.5">
                                        <svg class="w-4 h-4 text-indigo-500 group-hover:animate-bounce" fill="none" stroke="currentColor"
                                             viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
                                        </svg>
                                        Subir Corrección (v@(Model.VersionMayor).@(Model.VersionMenor + 1))
                                    </button>
                                </div>
                            }

                            <div class="mt-auto pt-6 border-t border-slate-200/60 dark:border-white/5 animate-fade-in">
                                <a href="@urlDescarga"
                                   class="w-full bg-indigo-50 dark:bg-indigo-500/10 hover:bg-indigo-100 dark:hover:bg-indigo-500/20 text-indigo-700 dark:text-indigo-400 border border-indigo-200 dark:border-indigo-500/20 py-3 rounded-xl text-xs font-bold transition-all hover:-translate-y-0.5 flex items-center justify-center gap-2 shadow-sm">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
                                    </svg>
                                    Descargar Archivo Original
                                </a>
                            </div>
                        </aside>

                        <section
                            class="flex-1 bg-slate-100/80 dark:bg-[#08080c] relative z-10 flex flex-col p-3 sm:p-6 overflow-hidden">
                            <div
                                class="w-full h-full bg-white dark:bg-[#0b0b10] border border-slate-200 dark:border-white/10 rounded-[24px] shadow-2xl flex flex-col overflow-hidden relative animate-slide-in-right ring-1 ring-slate-200/50 dark:ring-white/5">

                                @if (esTexto)
                                {
                                    <div
                                        class="h-12 bg-slate-50 dark:bg-[#151520] border-b border-slate-200 dark:border-white/5 px-4 flex items-center justify-between shrink-0">
                                        <div class="flex items-center gap-2 text-[11px] uppercase tracking-widest font-bold text-slate-500">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                      d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                                                </path>
                                            </svg> Editor de Texto Plano
                                        </div>
                                        <div class="flex items-center gap-3">
                                            <select id="selectFontSize"
                                                    class="input-glass py-1 px-2 text-xs rounded-lg !w-auto cursor-pointer">
                                                <option value="12">12px</option>
                                                <option value="14" selected>14px</option>
                                                <option value="16">16px</option>
                                            </select>
                                            <button id="btnWrap"
                                                    class="w-7 h-7 rounded-lg bg-slate-200 dark:bg-white/10 hover:bg-indigo-500 hover:text-white flex items-center justify-center transition-colors text-slate-600 dark:text-slate-300"
                                                    title="Ajuste de línea">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M4 6h16M4 12h16M4 18h7"></path>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                }

                                <div
                                    class="flex-1 w-full h-full relative overflow-hidden bg-slate-100/50 dark:bg-[#08080c] flex flex-col justify-center">

                                    @if (esPdf)
                                    {
                                        <div class="desktop-pdf">
                                            <iframe src="@urlInline" class="pdf-viewer w-full h-full border-0" title="Visor PDF"></iframe>
                                        </div>

                                        <div
                                            class="mobile-pdf hidden w-full h-full flex-col items-center justify-center p-6 text-center bg-slate-50/50 dark:bg-[#08080c]">
                                            <div
                                                class="w-20 h-20 rounded-3xl bg-red-500/10 border border-red-500/20 shadow-xl flex items-center justify-center mb-4">
                                                <svg class="w-10 h-10 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                                          d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z">
                                                    </path>
                                                </svg>
                                            </div>
                                            <h3 class="text-base font-bold text-slate-800 dark:text-white mb-2 font-display">Visor de PDF
                                                Seguro</h3>
                                                <p class="text-xs text-slate-500 max-w-xs mb-6">Para garantizar la protección de la sesión e
                                                    integridad de los datos en Android, abre el archivo directamente.</p>

                                                    <a href="@urlInline" target="_blank"
                                                       class="w-full max-w-xs bg-indigo-600 hover:bg-indigo-500 text-white py-3 rounded-xl text-xs font-bold shadow-[0_4px_15px_rgba(79,70,229,0.4)] flex items-center justify-center gap-2">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14">
                                                            </path>
                                                        </svg> Visualizar en Pestaña Nueva
                                                    </a>
                                                </div>
                                            }
                    else if (esImagen)
                                            {
                                                <div class="w-full h-full flex items-center justify-center p-4 sm:p-8 overflow-auto">
                                                    <img src="@urlInline" alt="Vista previa"
                                                         class="max-w-full max-h-full object-contain drop-shadow-2xl rounded" />
                                                </div>
                                            }
                                            else if (esTexto)
                                            {
                                                <div id="visorTexto"
                                                     class="w-full h-full p-4 sm:p-6 overflow-auto font-mono text-slate-800 dark:text-slate-300 text-sm whitespace-pre">
                                                    <div class="flex flex-col items-center justify-center h-full text-slate-400 gap-3">
                                                        <svg class="w-6 h-6 animate-spin text-indigo-500" fill="none" viewBox="0 0 24 24">
                                                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor"
                                                                    stroke-width="4"></circle>
                                                            <path class="opacity-75" fill="currentColor"
                                                                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                                                            </path>
                                                        </svg>
                                                        <span class="text-xs font-bold tracking-widest uppercase">Cargando Código...</span>
                                                    </div>
                                                </div>
                                                <div
                                                    class="h-8 bg-slate-50 dark:bg-[#151520] border-t border-slate-200 dark:border-white/5 flex items-center px-4 shrink-0 shadow-inner">
                                                    <span class="text-[10px] font-mono text-slate-500 font-bold" id="infoTexto">Obteniendo
                                                        metadata...</span>
                                                    </div>

                                                    <script>
                                                        (function () {
                                                        const url = '@Html.Raw(urlInline)';
                                                        const visor = document.getElementById('visorTexto');
                                                        const info = document.getElementById('infoTexto');

                                                        fetch(url).then(r => { if (!r.ok) throw new Error(`Error ${r.status}`); return r.text(); })
                                                        .then(texto => {
                                                        const escaped = texto.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                                                        visor.innerHTML = escaped;
                                                        info.textContent = `${texto.split('\n').length.toLocaleString()} líneas · ${texto.length.toLocaleString()} caracteres`;
                                                        })
                                                        .catch(err => {
                                                        visor.innerHTML = `<div class="bg-red-500/10 text-red-500 p-4 rounded-xl text-xs font-bold flex items-center gap-2"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Error: ${err.message}</div>`;
                                                        });

                                                        document.getElementById('selectFontSize')?.addEventListener('change', function () { visor.style.fontSize = this.value + 'px'; });
                                                        document.getElementById('btnWrap')?.addEventListener('click', function () {
                                                        this.dataset.wrap = this.dataset.wrap === 'true' ? 'false' : 'true';
                                                        visor.style.whiteSpace = this.dataset.wrap === 'true' ? 'pre-wrap' : 'pre';
                                                        this.classList.toggle('bg-indigo-500'); this.classList.toggle('text-white');
                                                        });
                                                        })();
                                                    </script>
                                                }
                    else
                                                {
                                                    <div
                                                        class="w-full h-full flex flex-col items-center justify-center p-4 sm:p-8 text-center bg-slate-50/50 dark:bg-[#08080c]">
                                                        <div
                                                            class="w-20 h-20 sm:w-24 sm:h-24 rounded-3xl bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 shadow-xl flex items-center justify-center mb-4 sm:mb-6 shrink-0">
                                                            <svg class="w-8 h-8 sm:w-10 sm:h-10 @formatIconColor" fill="none" stroke="currentColor"
                                                                 viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                                                      d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                                                                </path>
                                                            </svg>
                                                        </div>
                                                        <h3 class="text-base sm:text-lg font-bold text-slate-800 dark:text-white mb-2 font-display">
                                                            @labelTipo</h3>
                                                            <p
                                                                class="text-[11px] sm:text-xs font-mono font-bold @formatIconColor bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 px-2.5 py-1 rounded-lg mb-4 inline-block shadow-sm max-w-full truncate">
                                                                @System.IO.Path.GetFileName(Model.MinioIdentifier)
                                                            </p>
                                                            <p class="text-xs text-slate-500 max-w-xs mb-6 sm:mb-8 px-4">El formato <strong
                                                                class="uppercase text-slate-700 dark:text-slate-300">@extension</strong> no soporta
                                                                previsualización web. Descárgalo de forma segura.</p>
                                                                <a href="@urlDescarga"
                                                                   class="bg-indigo-600 hover:bg-indigo-500 text-white px-6 py-2.5 sm:px-8 sm:py-3 rounded-xl text-xs sm:text-sm font-bold shadow-[0_8px_20px_-6px_rgba(79,70,229,0.5)] transition-all hover:-translate-y-1 flex items-center gap-3">
                                                                    <svg class="w-4 h-4 sm:w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                                              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
                                                                    </svg> Descargar Seguro
                                                                </a>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </section>
                                        </main>

                                        <div id="modalEditar" class="fixed inset-0 z-50 hidden p-4 flex items-center justify-center">
                                            <div class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity" onclick="cerrarModal()"></div>

                                            <div id="modalContent"
                                                 class="w-full max-w-md bg-white dark:bg-[#101018] rounded-[24px] border border-slate-200 dark:border-white/10 shadow-[0_0_50px_rgba(0,0,0,0.5)] overflow-hidden opacity-0 scale-95 transition-all duration-300 relative z-10">
                                                <div
                                                    class="bg-gradient-to-r from-indigo-600 to-purple-600 p-5 sm:p-6 text-white flex justify-between items-center relative overflow-hidden">
                                                    <div
                                                        class="absolute right-0 top-0 w-32 h-32 bg-white/20 rounded-full blur-2xl transform translate-x-1/2 -translate-y-1/2">
                                                    </div>
                                                    <h3 class="text-base sm:text-lg font-bold font-display relative z-10 flex items-center gap-2">
                                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
                                                        </svg> Inyectar Corrección
                                                    </h3>
                                                    <button onclick="cerrarModal()"
                                                            class="relative z-10 w-8 h-8 rounded-full bg-white/10 hover:bg-red-500 hover:border-red-500 border border-white/20 flex items-center justify-center transition-all text-white hover:scale-105">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                                                            </path>
                                                        </svg>
                                                    </button>
                                                </div>

                                                <form asp-action="EditarVersion" method="post" enctype="multipart/form-data" id="formEditar">
                                                    <div class="p-5 sm:p-8">
                                                        <input type="hidden" name="VersionActualId" value="@Model.Id" />

                                                        <div
                                                            class="bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/20 p-4 rounded-xl mb-5 sm:mb-6 flex items-start gap-3">
                                                            <svg class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5" fill="none" stroke="currentColor"
                                                                 viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                                      d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                            </svg>
                                                            <p class="text-xs text-indigo-800 dark:text-indigo-300 font-medium">
                                                                Se reemplazará con la versión
                                                                <strong
                                                                    class="text-indigo-900 dark:text-white bg-indigo-200/50 dark:bg-indigo-500/30 px-1 rounded">v@(Model.VersionMayor).@(Model.VersionMenor
                                                                                                    + 1)</strong>
                                                                    y se reiniciará el flujo de firmas.
                                                                </p>
                                                            </div>

                                                            <label
                                                                class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2 ml-1">Seleccione
                                                                archivo nuevo</label>
                                                                <input type="file" name="ArchivoNuevo"
                                                                       class="w-full text-sm text-slate-500 dark:text-slate-400 file:mr-4 file:py-2 file:px-3 sm:file:py-2.5 sm:file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-indigo-600 file:text-white dark:file:bg-indigo-500 dark:file:text-white hover:file:bg-indigo-500 hover:file:scale-105 file:transition-all cursor-pointer border border-slate-200 dark:border-white/10 rounded-2xl p-2 bg-slate-50 dark:bg-black/20 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
                                                                       required accept=".pdf,.doc,.docx,.xls,.xlsx,.dwg" />
                                                            </div>

                                                            <div
                                                                class="p-4 sm:p-5 border-t border-slate-200 dark:border-white/10 flex justify-end gap-3 bg-slate-50/50 dark:bg-black/20 rounded-b-[24px]">
                                                                <button type="button" onclick="cerrarModal()"
                                                                        class="px-4 py-2 sm:px-5 sm:py-2.5 rounded-xl text-xs font-bold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-white hover:bg-slate-200 dark:hover:bg-white/10 transition-colors">Cancelar</button>
                                                                <button type="submit"
                                                                        onclick="this.disabled=true; this.innerHTML='<svg class=\'w-4 h-4 animate-spin\' fill=\'none\' viewBox=\'0 0 24 24\'><circle class=\'opacity-25\' cx=\'12\' cy=\'12\' r=\'10\' stroke=\'currentColor\' stroke-width=\'4\'></circle><path class=\'opacity-75\' fill=\'currentColor\' d=\'M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\'></path></svg> Subiendo...'; document.getElementById('formEditar').submit();"
                                                                        class="bg-emerald-500 hover:bg-emerald-400 text-white px-5 py-2 sm:px-6 sm:py-2.5 rounded-xl text-xs font-bold shadow-[0_4px_15px_-3px_rgba(16,185,129,0.4)] transition-all hover:-translate-y-0.5 flex items-center gap-2">
                                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7">
                                                                        </path>
                                                                    </svg> Subir y Notificar
                                                                </button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>

                                                <script>
                                                    function enviarFirma(decision) {
                                                    document.getElementById('inputAccion').value = decision;
                                                    if (decision === 'Rechazado') {
                                                    const comentarios = document.querySelector('textarea[name="Comentarios"]').value;
                                                    if (!comentarios.trim()) {
                                                    alert('Por favor justifique el rechazo en la caja de comentarios.');
                                                    document.querySelector('textarea[name="Comentarios"]').focus();
                                                    return;
                                                    }
                                                    }
                                                    document.getElementById('formFirma').submit();
                                                    }

                                                    const modal = document.getElementById('modalEditar');
                                                    const modalContent = document.getElementById('modalContent');

                                                    function abrirModal() {
                                                    modal.classList.remove('hidden');
                                                    setTimeout(() => {
                                                    modalContent.classList.remove('opacity-0', 'scale-95');
                                                    modalContent.classList.add('opacity-100', 'scale-100');
                                                    }, 10);
                                                    }

                                                    function cerrarModal() {
                                                    modalContent.classList.remove('opacity-100', 'scale-100');
                                                    modalContent.classList.add('opacity-0', 'scale-95');
                                                    setTimeout(() => { modal.classList.add('hidden'); }, 300);
                                                    }

                                                    const aside = document.getElementById('viewerAside');
                                                    const overlay = document.getElementById('asideOverlay');
                                                    const htmlElement = document.documentElement;

                                                    function abrirAside() {
                                                    // Se añade la clase al HTML para apagar filtros borrosos inmediatamente
                                                    htmlElement.classList.add('no-blur-mobile');
                                                    aside.classList.add('aside-open');
                                                    overlay.classList.add('overlay-open');
                                                    }

                                                    function cerrarAside() {
                                                    aside.classList.remove('aside-open');
                                                    overlay.classList.remove('overlay-open');
                                                    // Al terminar la transición se restauran los efectos en desktop de forma limpia
                                                    setTimeout(() => {
                                                    if (!aside.classList.contains('aside-open')) {
                                                    htmlElement.classList.remove('no-blur-mobile');
                                                    }
                                                    }, 250);
                                                    }

                                                    document.addEventListener('keydown', function (event) {
                                                    if (event.key === 'Escape') {
                                                    cerrarAside();
                                                    cerrarModal();
                                                    }
                                                    });
                                                </script>
                                            </body>

                                        </html>