@model NormaQ.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard Documental";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="es" class="dark antialiased">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — NormaQ</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { 
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                        display: ['Space Grotesk', 'sans-serif'],
                    },
                    animation: {
                        'fade-in-up': 'fadeInUp 0.5s ease-out forwards',
                        'spin-slow': 'spin 12s linear infinite',
                    },
                    keyframes: {
                        fadeInUp: {
                            '0%': { opacity: '0', transform: 'translateY(15px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        }
                    }
                }
            }
        }

        function toggleTheme(event) {
            const html = document.documentElement;
            if (!document.startViewTransition) { html.classList.toggle('dark'); return; }
            const x = event?.clientX ?? window.innerWidth / 2;
            const y = event?.clientY ?? window.innerHeight / 2;
            const r = Math.hypot(Math.max(x, window.innerWidth - x), Math.max(y, window.innerHeight - y));
            const transition = document.startViewTransition(() => { html.classList.toggle('dark'); });
            transition.ready.then(() => {
                document.documentElement.animate(
                    { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${r}px at ${x}px ${y}px)`] },
                    { duration: 600, easing: 'cubic-bezier(0.4,0,0.2,1)', pseudoElement: '::view-transition-new(root)' }
                );
            });
        }
    </script>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            overflow: hidden; 
            width: 100vw; height: 100vh;
            background-color: #050508; 
            transition: background-color 0.3s ease;
        }
        html:not(.dark) body { background-color: #f8fafc; }

        /* Ocultar barras de scroll visualmente */
        ::-webkit-scrollbar { display: none; }
        * { -ms-overflow-style: none; scrollbar-width: none; }

        ::view-transition-old(root), ::view-transition-new(root) { animation: none; mix-blend-mode: normal; }
        ::view-transition-old(root) { z-index: 1; } ::view-transition-new(root) { z-index: 9999; }

        .app-container {
            position: relative; z-index: 10;
            width: 100vw; height: 100vh; display: flex;
            background: rgba(10, 10, 15, 0.6); backdrop-filter: blur(20px);
        }
        html:not(.dark) .app-container { background: rgba(255, 255, 255, 0.6); }

        .nav-item {
            display: flex; align-items: center; gap: 0.75rem;
            padding: 0.75rem 1rem; border-radius: 12px;
            font-size: 13px; font-weight: 600; color: #64748b; transition: all 0.3s; text-decoration: none;
        }
        .dark .nav-item { color: #94a3b8; }
        .nav-item:hover { color: #4f46e5; background: rgba(79,70,229,0.05); transform: translateX(6px); }
        .dark .nav-item:hover { color: #818cf8; background: rgba(99,102,241,0.1); }
        .nav-item.active { color: #4f46e5; background: rgba(79,70,229,0.1); border-left: 3px solid #4f46e5; }
        .dark .nav-item.active { color: white; background: rgba(99,102,241,0.2); border-left: 3px solid #818cf8; }

        .circular-chart { display: block; margin: 0 auto; max-width: 100%; max-height: 250px; }
        .circle-bg { fill: none; stroke: rgba(0,0,0,0.1); stroke-width: 3.8; }
        .circle { fill: none; stroke-width: 3.5; stroke-linecap: round; animation: progress 1s ease-out forwards; }
        @@keyframes progress { 0% { stroke-dasharray: 0 100; } }
        .dark .circle-bg { stroke: rgba(255,255,255,0.05); }

        details > summary { list-style: none; cursor: pointer; }
        details > summary::-webkit-details-marker { display: none; }
        details[open] .folder-icon { color: #4f46e5; }
        .dark details[open] .folder-icon { color: #818cf8; }
        details[open] .folder-arrow { transform: rotate(90deg); }

        .iso-folder {
            border-radius: 12px; margin-bottom: 0.75rem;
            border: 1px solid rgba(0,0,0,0.05); background: rgba(255,255,255,0.6); transition: all 0.3s;
        }
        .dark .iso-folder { border: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02); }
        .iso-folder:hover { border-color: rgba(99,102,241,0.3); }

        .stagger-1 { animation-delay: 0.1s; }
        .stagger-2 { animation-delay: 0.2s; }
    </style>
</head>
<body class="text-slate-800 dark:text-slate-200 flex">

    <div class="fixed top-[-20%] left-[-10%] w-[500px] h-[500px] bg-indigo-500/20 rounded-full blur-[120px] pointer-events-none z-0 hidden dark:block"></div>
    <div class="fixed bottom-[-20%] right-[-10%] w-[400px] h-[400px] bg-purple-500/10 rounded-full blur-[120px] pointer-events-none z-0 hidden dark:block"></div>

    <div class="app-container">

        <aside class="w-[260px] h-full flex-shrink-0 flex flex-col border-r border-slate-200/80 dark:border-white/5 bg-white/70 dark:bg-black/40 backdrop-blur-xl z-20 relative p-5">
            <div class="flex items-center gap-3 mb-10 pl-2">
                <svg class="w-8 h-8 text-indigo-600 dark:text-indigo-400 drop-shadow-md" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
                <div>
                    <h1 class="text-xl font-display font-bold tracking-tight text-slate-900 dark:text-white">NormaQ</h1>
                    <p class="text-[9px] font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-widest">ISO Suite</p>
                </div>
            </div>

            <nav class="space-y-1.5 mb-8">
                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3 pl-3">Navegación</p>
                <a href="#" class="nav-item active"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h7" stroke-width="2"></path></svg>Dashboard</a>
                <a href="#" class="nav-item"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7" stroke-width="2"></path></svg>Visor de Documentos</a>
                <a href="#" class="nav-item"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke-width="2"></path></svg>Mis Tareas</a>
                <a href="#" class="nav-item"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" stroke-width="2"></path></svg>Directorio</a>
            </nav>

            <div class="mb-auto">
                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3 pl-3">Filtros de Estado</p>
                <div class="space-y-1">
                    <a href="#" class="nav-item group"><span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)] group-hover:scale-125 transition-transform"></span> Aprobados</a>
                    <a href="#" class="nav-item group"><span class="w-2 h-2 rounded-full bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.6)] group-hover:scale-125 transition-transform"></span> En Revisión</a>
                    <a href="#" class="nav-item group"><span class="w-2 h-2 rounded-full bg-slate-400 group-hover:scale-125 transition-transform"></span> Borradores</a>
                    <a href="#" class="nav-item group"><span class="w-2 h-2 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.6)] group-hover:scale-125 transition-transform"></span> Obsoletos</a>
                </div>
            </div>

            <form asp-controller="Account" asp-action="Logout" method="post" class="mt-8">
                <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-bold text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 hover:translate-x-2 transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg> Cerrar Sesión
                </button>
            </form>
        </aside>

        <main class="flex-1 h-full flex flex-col z-20 relative bg-transparent overflow-hidden">
            
            <header class="h-20 border-b border-slate-200/60 dark:border-white/5 bg-white/40 dark:bg-black/20 backdrop-blur-md px-8 flex items-center justify-between shrink-0">
                <div class="relative w-full max-w-md group">
                    <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 group-focus-within:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" stroke-width="2"></path></svg>
                    <input type="text" placeholder="Búsqueda rápida en repositorios..." class="w-full pl-11 pr-4 py-2.5 rounded-xl bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 text-sm outline-none focus:border-indigo-500 focus:bg-white dark:focus:bg-black/20 transition-all shadow-sm">
                </div>

                <div class="flex items-center gap-4">
                    <div class="group flex items-center gap-2 px-3 py-2 rounded-xl bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 text-xs font-bold text-slate-600 dark:text-slate-300 shadow-sm hover:scale-105 transition-transform cursor-default">
                        <svg class="w-4 h-4 text-amber-500 animate-spin-slow drop-shadow-[0_0_4px_rgba(245,158,11,0.6)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" stroke-width="2"></path></svg>
                        <span>32°C Monclova</span>
                    </div>
                    
                    <div class="group flex items-center gap-2 px-3 py-2 rounded-xl bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 text-xs font-bold text-slate-600 dark:text-slate-300 shadow-sm hover:scale-105 transition-transform cursor-default">
                        <svg class="w-4 h-4 text-indigo-500 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-width="2"></path></svg>
                        <span id="live-date">Cargando...</span>
                    </div>

                    <button onclick="toggleTheme(event)" class="w-10 h-10 rounded-full bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 flex items-center justify-center text-slate-500 hover:text-indigo-600 hover:rotate-12 transition-all shadow-sm">
                        <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" stroke-width="2"></path></svg>
                        <svg class="w-5 h-5 hidden dark:block text-amber-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" stroke-width="2"></path></svg>
                    </button>
                </div>
            </header>

            <div class="flex-1 flex flex-col p-8 overflow-hidden gap-5">
                
                <div class="shrink-0 bg-gradient-to-br from-indigo-600 to-indigo-700 dark:from-indigo-600 dark:to-indigo-900 rounded-[20px] p-6 text-white flex justify-between items-center shadow-lg shadow-indigo-500/20 animate-fade-in-up">
                    <div class="flex-1">
                        <span class="inline-block px-2 py-0.5 bg-white/20 backdrop-blur-md rounded border border-white/20 text-[9px] font-bold tracking-widest uppercase mb-2">Contexto Operativo</span>
                        <h2 class="font-display text-2xl font-bold mb-1">¡Hola, @Model.UsuarioNombre!</h2>
                        <p class="text-indigo-100 text-xs">Repositorio documental oficial de <strong>@Model.DepartamentoActivoNombre</strong>.</p>
                    </div>

                    <div class="flex gap-6 pr-4 border-l border-white/10 pl-6">
                        <div class="text-center">
                            <p class="text-2xl font-bold font-display leading-none">@(Model.ArbolDocumental?.Count ?? 0)</p>
                            <p class="text-[9px] uppercase tracking-widest text-indigo-200 mt-1">Niveles ISO</p>
                        </div>
                        <div class="text-center">
                            <p class="text-2xl font-bold font-display leading-none">0</p>
                            <p class="text-[9px] uppercase tracking-widest text-indigo-200 mt-1">Alertas</p>
                        </div>
                    </div>
                </div>

                <div class="flex-1 flex flex-col min-h-0 animate-fade-in-up stagger-1">
                    <div class="flex justify-between items-end mb-3 shrink-0">
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Estructura Documental ISO 9001</p>
                    </div>

                    <div class="flex-1 overflow-y-auto pr-2 pb-4">
                        @if (Model.ArbolDocumental != null)
                        {
                            @foreach (var nivel in Model.ArbolDocumental)
                            {
                                <details class="iso-folder group shadow-sm">
                                    <summary class="flex items-center justify-between p-3.5 px-5 select-none hover:bg-slate-50/50 dark:hover:bg-white/5 transition-colors rounded-xl">
                                        <div class="flex items-center gap-4">
                                            <svg class="folder-arrow w-4 h-4 text-slate-400 dark:text-slate-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
                                            <div class="w-9 h-9 rounded-lg bg-white dark:bg-black/20 flex items-center justify-center border border-slate-200 dark:border-white/5 shadow-sm">
                                                <svg class="folder-icon w-4 h-4 text-slate-400 transition-colors duration-200" fill="currentColor" viewBox="0 0 24 24"><path d="M3 7a2 2 0 012-2h4.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293h6.586a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"></path></svg>
                                            </div>
                                            <div>
                                                <h4 class="text-sm font-bold text-slate-800 dark:text-white">0@(nivel.Numero) - @nivel.Nombre</h4>
                                                <p class="text-[10px] font-medium text-slate-500">@(nivel.DocumentosLogicos?.Count ?? 0) documentos</p>
                                            </div>
                                        </div>
                                    </summary>

                                    <div class="p-5 pt-3 border-t border-slate-200/60 dark:border-white/5 ml-4 bg-slate-50/50 dark:bg-black/10 rounded-b-xl">
                                        
                                        @if (Model.RolActivoNombre == "Administrador")
                                        {
                                            <div class="mb-4 pb-4 border-b border-slate-200/60 dark:border-white/5 flex justify-between items-center">
                                                <span class="text-[10px] text-slate-500 uppercase tracking-widest">Contenido del Nivel</span>
                                                <a asp-action="CrearDocumento" asp-route-departamentoId="@Model.DepartamentoActivoId" class="px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-bold shadow-md transition-transform hover:scale-105 flex items-center gap-1.5">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg> Añadir Documento
                                                </a>
                                            </div>
                                        }

                                        @if (nivel.DocumentosLogicos == null || !nivel.DocumentosLogicos.Any())
                                        {
                                            <div class="py-6 text-center bg-white/50 dark:bg-white/5 rounded-xl border border-dashed border-slate-300 dark:border-white/10">
                                                <p class="text-xs font-medium text-slate-500">No hay documentos en este nivel.</p>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="space-y-3">
                                                @foreach (var doc in nivel.DocumentosLogicos)
                                                {
                                                    <div class="bg-white/80 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 rounded-xl p-4 shadow-sm">
                                                        
                                                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-3">
                                                            <div class="flex items-start gap-3">
                                                                <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shrink-0">
                                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                                                </div>
                                                                <div>
                                                                    <h4 class="text-sm font-bold text-slate-900 dark:text-white">@doc.Nombre</h4>
                                                                    <span class="text-[9px] font-mono font-bold text-indigo-500 bg-indigo-50 dark:bg-indigo-500/10 px-2 py-0.5 rounded">@doc.Codigo</span>
                                                                </div>
                                                            </div>

                                                            @if (Model.RolActivoNombre == "Elaborador")
                                                            {
                                                                <a asp-action="SubirVersion" asp-route-documentoId="@doc.Id" class="w-full sm:w-auto px-3 py-1.5 bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20 rounded-lg text-xs font-bold hover:bg-emerald-100 dark:hover:bg-emerald-500/20 transition-colors flex items-center justify-center gap-1.5">
                                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg> Subir Versión
                                                                </a>
                                                            }
                                                        </div>

                                                        @if (doc.VersionesFisicas.Any())
                                                        {
                                                            <div class="bg-slate-50/50 dark:bg-black/20 rounded-lg p-3 border border-slate-100 dark:border-white/5">
                                                                <div class="space-y-2">
                                                                    @foreach (var version in doc.VersionesFisicas)
                                                                    {
                                                                        string badgeColors = version.Estado switch {
                                                                            "Aprobado" => "bg-emerald-100 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400 border-emerald-200 dark:border-emerald-400/20",
                                                                            "Revision" => "bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border-amber-200 dark:border-amber-400/20",
                                                                            "Borrador" => "bg-slate-200 text-slate-700 dark:bg-white/10 dark:text-slate-300 border-slate-300 dark:border-slate-400/20",
                                                                            "Obsoleto" => "bg-red-100 text-red-700 dark:bg-red-500/10 dark:text-red-400 border-red-200 dark:border-red-400/20",
                                                                            _ => "bg-slate-100 text-slate-700 dark:bg-white/5 dark:text-slate-400"
                                                                        };
                                                                        string dotColor = version.Estado switch { "Aprobado" => "bg-emerald-500", "Revision" => "bg-amber-500", "Borrador" => "bg-slate-500", "Obsoleto" => "bg-red-500", _ => "bg-slate-500" };

                                                                        string rowClasses = version.RequiereMiIntervencion 
                                                                            ? "bg-amber-50/50 dark:bg-amber-500/5 border-amber-300/50 dark:border-amber-500/30 shadow-[0_0_8px_rgba(245,158,11,0.05)]" 
                                                                            : "bg-white dark:bg-white/5 border-slate-200/60 dark:border-white/5";

                                                                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center p-2.5 rounded-lg border @rowClasses gap-3 transition-colors">
                                                                            <div class="flex items-center gap-3">
                                                                                <span class="text-xs font-bold font-mono text-slate-700 dark:text-slate-200">v@(version.VersionMayor).@(version.VersionMenor)</span>
                                                                                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-wide border @badgeColors">
                                                                                    <span class="w-1.5 h-1.5 rounded-full @dotColor"></span> @version.Estado
                                                                                </span>
                                                                            </div>
                                                                            <div class="flex items-center gap-2 w-full sm:w-auto">
                                                                                <a asp-action="VisualizarVersion" asp-route-versionId="@version.Id" asp-route-intervencion="@version.RequiereMiIntervencion" class="flex-1 sm:flex-none px-3 py-1.5 bg-slate-100 hover:bg-slate-200 dark:bg-white/5 dark:hover:bg-white/10 text-slate-700 dark:text-slate-300 rounded-lg text-[10px] font-bold transition-colors flex items-center justify-center gap-1.5">
                                                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg> Abrir
                                                                                </a>

                                                                                @if ((Model.RolActivoNombre == "Revisor" || Model.RolActivoNombre == "Aprobador") && version.RequiereMiIntervencion)
                                                                                {
                                                                                    <a asp-action="VisualizarVersion" asp-route-versionId="@version.Id" asp-route-intervencion="@version.RequiereMiIntervencion" class="flex-1 sm:flex-none px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-white rounded-lg text-[10px] font-bold shadow-md shadow-amber-500/20 transition-colors flex items-center justify-center gap-1.5">
                                                                                        Acción Requerida
                                                                                    </a>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </details>
                            }
                        }
                    </div>
                </div>
            </div>
        </main>

        <aside class="w-[300px] h-full flex-shrink-0 flex flex-col border-l border-slate-200/80 dark:border-white/5 bg-white/70 dark:bg-black/40 backdrop-blur-xl z-20 p-6 relative">
            <div class="flex flex-col items-center mb-6 border-b border-slate-200/60 dark:border-white/5 pb-6 shrink-0">
                <div class="w-20 h-20 rounded-full bg-white dark:bg-white/10 flex items-center justify-center mb-3 shadow-xl border border-slate-100 dark:border-white/10 transform hover:scale-105 transition-transform">
                    <svg class="w-10 h-10 text-slate-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                </div>
                <h3 class="text-sm font-bold text-slate-900 dark:text-white font-display">@Model.UsuarioNombre</h3>
                <span class="px-4 py-1 rounded-full bg-indigo-50 dark:bg-indigo-500/10 text-[9px] font-bold text-indigo-600 dark:text-indigo-400 uppercase mt-2 border border-indigo-100 dark:border-indigo-500/20 tracking-widest">
                    @Model.RolActivoNombre
                </span>
            </div>

            <p class="text-[10px] font-bold text-slate-500 uppercase mb-3 tracking-widest pl-1 shrink-0">Estado Global</p>
            <div class="bg-white/60 dark:bg-black/20 p-5 rounded-2xl border border-slate-200/60 dark:border-white/10 flex flex-col gap-4 shadow-sm mb-6 shrink-0 animate-fade-in-up stagger-1">
                <div class="w-[100px] h-[100px] relative mx-auto">
                    <svg viewBox="0 0 36 36" class="circular-chart w-full h-full transform -rotate-90">
                        <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                        <path class="circle" stroke-dasharray="0, 100" stroke="#10b981" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-xs font-bold text-slate-800 dark:text-white">0</span>
                    </div>
                </div>
                <div class="text-[10px] space-y-1.5 font-medium text-slate-600 dark:text-slate-400">
                    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-emerald-500"></span> 0 Aprobados</div>
                    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-amber-500"></span> 0 En Revisión</div>
                    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-slate-400"></span> 0 Borradores</div>
                    <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-red-500"></span> 0 Obsoletos</div>
                </div>
            </div>

            <p class="text-[10px] font-bold text-slate-500 uppercase mb-3 tracking-widest pl-1 shrink-0">Notificaciones</p>
            <div class="flex-1 overflow-y-auto pr-2">
                <div class="p-6 border border-dashed border-slate-300 dark:border-white/10 bg-white/30 dark:bg-white/5 rounded-2xl text-center flex flex-col items-center animate-fade-in-up stagger-2">
                    <div class="w-8 h-8 rounded-full bg-slate-100 dark:bg-black/20 flex items-center justify-center mb-2">
                        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <p class="text-[11px] font-semibold text-slate-600 dark:text-slate-400">Sin actividad reciente</p>
                </div>
            </div>

            @if (Model.ContextosDisponibles != null && Model.ContextosDisponibles.Count > 1)
            {
                <div class="mt-4 pt-5 border-t border-slate-200/60 dark:border-white/5 shrink-0">
                    <form method="get" asp-action="Index" id="deptSwitchForm" class="relative group">
                        <select name="selectedDeptId" class="w-full appearance-none bg-white/60 dark:bg-black/20 border border-slate-200/60 dark:border-white/10 rounded-xl px-4 py-3 text-[11px] font-bold text-slate-700 dark:text-slate-200 outline-none cursor-pointer hover:border-indigo-500 focus:border-indigo-500 transition-all shadow-sm" onchange="document.getElementById('deptSwitchForm').submit();">
                            @foreach (var ctx in Model.ContextosDisponibles)
                            {
                                if (ctx.DepartamentoId == Model.DepartamentoActivoId)
                                {
                                    <option value="@ctx.DepartamentoId" selected>@ctx.NombreDepartamento</option>
                                }
                                else
                                {
                                    <option value="@ctx.DepartamentoId">@ctx.NombreDepartamento</option>
                                }
                            }
                        </select>
                        <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-indigo-500 pointer-events-none group-hover:translate-y-[-30%] transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2.5"></path></svg>
                    </form>
                </div>
            }
        </aside>
    </div>

    <script>
        function updateDate() {
            const now = new Date();
            const options = { day: 'numeric', month: 'short', year: 'numeric' };
            document.getElementById('live-date').innerText = now.toLocaleDateString('es-MX', options);
        }
        updateDate(); setInterval(updateDate, 60000);
    </script>
</body>
</html>