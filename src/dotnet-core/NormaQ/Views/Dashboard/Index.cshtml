@{
    ViewData["Title"] = "Panel de Control - Diagnóstico";
}

<div class="container mt-4">
    <div class="alert alert-success d-flex align-items-center shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill fs-4 me-3"></i>
        <div>
            <h4 class="alert-heading mb-0">¡Autenticación Exitosa!</h4>
            <p class="mb-0 small">El ticket de seguridad ha sido validado por el servidor.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-dark text-white">
                    <h6 class="mb-0">Identidad del Usuario</h6>
                </div>
                <div class="card-body">
                    <p class="mb-1 text-muted small">Nombre Completo:</p>
                    <h5 class="fw-bold">@User.Identity?.Name</h5>
                    <hr />
                    <p class="mb-1 text-muted small">Correo Electrónico:</p>
                    <p class="fw-bold">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</p>
                    <hr />
                    <p class="mb-1 text-muted small">ID de Usuario:</p>
                    <span class="badge bg-secondary">@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value</span>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Matriz de Permisos (Malla de Roles)</h6>
                    <span class="badge bg-light text-primary">Claims Totales: @User.Claims.Count()</span>
                </div>
                <div class="card-body">
                    <p class="small text-muted">Estos son los permisos <strong>DeptRole</strong> (DeptoID : RolID) detectados en tu sesión:</p>
                    
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Tipo de Claim</th>
                                    <th>Valor (Matriz)</th>
                                    <th>Interpretación</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var claim in User.Claims)
                                {
                                    <tr>
                                        <td><code>@claim.Type.Split('/').Last()</code></td>
                                        <td><span class="badge @(claim.Type == "DeptRole" ? "bg-info text-dark" : "bg-light text-muted")">@claim.Value</span></td>
                                        <td>
                                            @if (claim.Type == "DeptRole")
                                            {
                                                var parts = claim.Value.Split(':');
                                                <small class="text-success fw-bold">
                                                    Acceso al Depto #@parts[0] con Rol #@parts[1]
                                                </small>
                                            }
                                            else
                                            {
                                                <small class="text-muted">Información de Perfil</small>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 p-3 bg-white border rounded shadow-sm">
        <h6><i class="bi bi-info-circle me-2"></i>¿Cómo funciona esto?</h6>
        <p class="small text-muted mb-0">
            Cada vez que navegas, el navegador envía la cookie <code>NormaQ_AuthTicket</code>. El servidor la desencripta y llena el objeto <code>User.Claims</code>. No necesitamos volver a consultar SQL Server para saber quién eres o qué roles tienes en cada departamento; los datos ya viajan contigo de forma segura.
        </p>
    </div>
</div>