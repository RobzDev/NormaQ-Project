@model NormaQ.ViewModels.DashboardViewModel

@{
   
    ViewData["Title"] = "Dashboard Documental";
    ViewData["ActiveNav"] = "dashboard";
    ViewData["UsuarioNombre"] = Model.UsuarioNombre;
    ViewData["RolActivoNombre"] = Model.RolActivoNombre;
    ViewData["DepartamentoActivoId"] = Model.DepartamentoActivoId; // <- ¿está esto?
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="flex-1 flex flex-col p-8 overflow-hidden gap-5">
    <div class="shrink-0 bg-gradient-to-br from-indigo-600 to-indigo-700 dark:from-indigo-600 dark:to-indigo-900 rounded-[20px] p-6 text-white flex justify-between items-center shadow-lg shadow-indigo-500/20 animate-fade-in-up">
        <div class="flex-1">
            <span class="inline-block px-2 py-0.5 bg-white/20 backdrop-blur-md rounded border border-white/20 text-[9px] font-bold tracking-widest uppercase mb-2"><strong>@Model.CompaniaNombre</strong></span>
            <h2 class="font-display text-2xl font-bold mb-1">¡Hola, @Model.UsuarioNombre!</h2>
            <p class="text-indigo-100 text-xs">Repositorio documental oficial de <strong>@Model.DepartamentoActivoNombre</strong>.</p>
        </div>

        <div class="flex gap-6 pr-4 border-l border-white/10 pl-6">
            <div class="text-center">
                <p class="text-2xl font-bold font-display leading-none">@(Model.ArbolDocumental?.Count ?? 0)</p>
                <p class="text-[9px] uppercase tracking-widest text-indigo-200 mt-1">Niveles ISO</p>
            </div>
           
        </div>
    </div>

    <div class="flex-1 flex flex-col min-h-0 animate-fade-in-up stagger-1">
        <div class="flex justify-between items-end mb-3 shrink-0">
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Estructura Documental ISO 9001</p>
        </div>

        <div class="flex-1 overflow-y-auto pr-2 pb-4">
            @if (Model.ArbolDocumental != null)
            {
                @foreach (var nivel in Model.ArbolDocumental)
                {
                    <details class="iso-folder group shadow-sm">
                        <summary class="flex items-center justify-between p-3.5 px-5 select-none hover:bg-slate-50/50 dark:hover:bg-white/5 transition-colors rounded-xl">
                            <div class="flex items-center gap-4">
                                <svg class="folder-arrow w-4 h-4 text-slate-400 dark:text-slate-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
                                <div class="w-9 h-9 rounded-lg bg-white dark:bg-black/20 flex items-center justify-center border border-slate-200 dark:border-white/5 shadow-sm">
                                    <svg class="folder-icon w-4 h-4 text-slate-400 transition-colors duration-200" fill="currentColor" viewBox="0 0 24 24"><path d="M3 7a2 2 0 012-2h4.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293h6.586a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"></path></svg>
                                </div>
                                <div>
                                    <h4 class="text-sm font-bold text-slate-800 dark:text-white">0@(nivel.Numero) - @nivel.Nombre</h4>
                                    <p class="text-[10px] font-medium text-slate-500">@(nivel.DocumentosLogicos?.Count ?? 0) documentos</p>
                                </div>
                            </div>
                        </summary>

                        <div class="p-5 pt-3 border-t border-slate-200/60 dark:border-white/5 ml-4 bg-slate-50/50 dark:bg-black/10 rounded-b-xl">
                            @if (Model.RolActivoNombre == "Administrador")
                            {
                                <div class="mb-4 pb-4 border-b border-slate-200/60 dark:border-white/5 flex justify-between items-center">
                                    <span class="text-[10px] text-slate-500 uppercase tracking-widest">Contenido del Nivel</span>
                                    <a asp-action="CrearDocumento" asp-route-departamentoId="@Model.DepartamentoActivoId" class="px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-bold shadow-md transition-transform hover:scale-105 flex items-center gap-1.5">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg> Añadir Documento
                                    </a>
                                </div>
                            }

                            @if (nivel.DocumentosLogicos == null || !nivel.DocumentosLogicos.Any())
                            {
                                <div class="py-6 text-center bg-white/50 dark:bg-white/5 rounded-xl border border-dashed border-slate-300 dark:border-white/10">
                                    <p class="text-xs font-medium text-slate-500">No hay documentos en este nivel.</p>
                                </div>
                            }
                            else
                            {
                                <div class="space-y-3">
                                    @foreach (var doc in nivel.DocumentosLogicos)
                                    {
                                        <div class="bg-white/80 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 rounded-xl p-4 shadow-sm">
                                            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-3">
                                                <div class="flex items-start gap-3">
                                                    <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shrink-0">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                                    </div>
                                                    <div>
                                                        <h4 class="text-sm font-bold text-slate-900 dark:text-white">@doc.Nombre</h4>
                                                        <span class="text-[9px] font-mono font-bold text-indigo-500 bg-indigo-50 dark:bg-indigo-500/10 px-2 py-0.5 rounded">@doc.Codigo</span>
                                                    </div>
                                                </div>

                                                @if (Model.RolActivoNombre == "Elaborador")
                                                {
                                                    <a asp-action="SubirVersion" asp-route-documentoId="@doc.Id" class="w-full sm:w-auto px-3 py-1.5 bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20 rounded-lg text-xs font-bold hover:bg-emerald-100 dark:hover:bg-emerald-500/20 transition-colors flex items-center justify-center gap-1.5">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg> Subir Versión
                                                    </a>
                                                }
                                            </div>

                                            @if (doc.VersionesFisicas.Any())
                                            {
                                                <div class="bg-slate-50/50 dark:bg-black/20 rounded-lg p-3 border border-slate-100 dark:border-white/5">
                                                    <div class="space-y-2">
                                                        @foreach (var version in doc.VersionesFisicas)
                                                        {
                                                            string badgeColors = version.Estado switch {
                                                                "Aprobado" => "bg-emerald-100 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400 border-emerald-200 dark:border-emerald-400/20",
                                                                "Revision" => "bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border-amber-200 dark:border-amber-400/20",
                                                                "Borrador" => "bg-slate-200 text-slate-700 dark:bg-white/10 dark:text-slate-300 border-slate-300 dark:border-slate-400/20",
                                                                "Obsoleto" => "bg-red-100 text-red-700 dark:bg-red-500/10 dark:text-red-400 border-red-200 dark:border-red-400/20",
                                                                _ => "bg-slate-100 text-slate-700 dark:bg-white/5 dark:text-slate-400"
                                                            };
                                                            string dotColor = version.Estado switch { "Aprobado" => "bg-emerald-500", "Revision" => "bg-amber-500", "Borrador" => "bg-slate-500", "Obsoleto" => "bg-red-500", _ => "bg-slate-500" };
                                                             
                                                            string rowClasses = "";
                                                            if (version.EstaRechazado)
                                                            {
                                                                rowClasses = "bg-red-100/50 dark:bg-red-500/5 border-red-300/50 dark:border-red-500/30 shadow-[0_0_8px_rgba(239,68,68,0.05)]";
                                                            }
                                                            else if (version.RequiereMiIntervencion)
                                                            {  rowClasses = "bg-amber-50/50 dark:bg-amber-500/5 border-amber-300/50 dark:border-amber-500/30 shadow-[0_0_8px_rgba(245,158,11,0.05)]" 
                                                                ;}
                                                            else { rowClasses = "bg-white dark:bg-white/5 border-slate-200/60 dark:border-white/5"; }    

                                                                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center p-2.5 rounded-lg border @rowClasses gap-3 transition-colors"
                                                                    data-estado="@version.Estado"
                                                                    data-nombre="@doc.Nombre.ToLower()"
                                                                    data-version="@version.VersionMayor.@version.VersionMenor">
                                                                        <div class="flex items-center gap-4">
                                                                        <div class="flex items-center gap-3">
                                                                            <span class="text-xs font-bold font-mono text-slate-700 dark:text-slate-200">v@(version.VersionMayor).@(version.VersionMenor)</span>
                                                                            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-wide border @badgeColors">
                                                                                <span class="w-1.5 h-1.5 rounded-full @dotColor"></span> @version.Estado
                                                                            </span>
                                                                        </div>

                                                                        <div class="flex items-center gap-3 text-[10px] text-slate-500 dark:text-slate-400">
                                                                            <div class="inline-flex items-center gap-2 bg-white/50 dark:bg-black/5 px-2 py-1 rounded-md border border-slate-200/60 dark:border-white/5">
                                                                                <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3M3 11h18M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                                                                <span class="text-[11px]">Subida el <span class="font-medium text-slate-700 dark:text-slate-200">@version.FechaSubida.ToString("dd MMM yyyy")</span></span>
                                                                            </div>

                                                                            <div class="inline-flex items-center gap-2 bg-white/50 dark:bg-black/5 px-2 py-1 rounded-md border border-slate-200/60 dark:border-white/5">
                                                                                <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 15c2.5 0 4.847.676 6.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                                                                @if (!string.IsNullOrEmpty(version.CreadoPor) && version.CreadoPor.Equals(Model.UsuarioNombre, System.StringComparison.OrdinalIgnoreCase))
                                                                                {
                                                                                    <span class="text-[11px] text-emerald-700 font-medium">Creado por ti</span>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <span class="text-[11px]">Por <span class="font-medium text-slate-700 dark:text-slate-200">@version.CreadoPor</span></span>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                
                                                                

                                                                <div class="flex items-center gap-2 w-full sm:w-auto">

                                                                    @if (version.RequiereMiIntervencion == true)
                                                                    {
                                                                        <a asp-action="VisualizarVersion" asp-route-versionId="@version.Id" class="flex-1 sm:flex-none px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-white rounded-lg text-[10px] font-bold shadow-md shadow-amber-500/20 transition-colors flex items-center justify-center gap-1.5">
                                                                            Acción Requerida
                                                                        </a>
                                                                    }
                                                                    else{

                                                                        <a asp-action="VisualizarVersion" asp-route-versionId="@version.Id" class="flex-1 sm:flex-none px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-[10px] font-bold shadow-md shadow-indigo-500/20 transition-colors flex items-center justify-center gap-1.5">
                                                                            
                                                                         <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg> Abrir

                                                                        </a>
                                                                    }
                                                                   
                                                                    
                                                                </div>

                                                               
                                                                   

                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </details>
                }
            }
        </div>
    </div>
</div>

@section Busqueda{
    <div class="relative w-full max-w-md group" id="search-wrapper">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 group-focus-within:text-indigo-500 transition-colors z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" stroke-width="2"></path></svg>
        <input id="buscador" type="text" autocomplete="off" placeholder="Buscar por nombre, código o contenido..." 
               class="w-full pl-11 pr-9 py-2.5 rounded-xl bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 text-sm outline-none focus:border-indigo-500 focus:bg-white dark:focus:bg-black/20 transition-all shadow-sm">
        
        <div id="search-spinner" class="absolute right-4 top-1/2 -translate-y-1/2 hidden">
            <svg class="w-4 h-4 text-indigo-500 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4z"></path>
            </svg>
        </div>

        <div id="autocomplete-dropdown" 
             class="absolute top-full left-0 right-0 mt-1.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-white/10 rounded-xl shadow-xl z-50 overflow-hidden hidden">
            
            <div id="autocomplete-api-section" class="hidden">
                <div class="px-3 pt-2.5 pb-1">
                    <span class="text-[9px] font-bold uppercase tracking-widest text-slate-400">Índice documental — Aprobados & Obsoletos</span>
                </div>
                <div id="autocomplete-api-results"></div>
            </div>

            <div id="autocomplete-dom-section" class="hidden">
                <div class="px-3 pt-2.5 pb-1">
                    <span class="text-[9px] font-bold uppercase tracking-widest text-slate-400">En revisión & Borradores</span>
                </div>
                <div id="autocomplete-dom-results"></div>
            </div>

            <div id="autocomplete-empty" class="hidden px-4 py-5 text-center">
                <p class="text-xs font-medium text-slate-400">Sin resultados para tu búsqueda</p>
            </div>
        </div>
    </div>
}
@section DeptSelector {
    @if (Model.ContextosDisponibles != null && Model.ContextosDisponibles.Count > 1)
    {
        <div class="mt-4 pt-5 border-t border-slate-200/60 dark:border-white/5 shrink-0">
            <form method="get" asp-action="Index" id="deptSwitchForm" class="relative group">
                <select name="selectedDeptId" class="w-full appearance-none bg-white/60 dark:bg-black/20 border border-slate-200/60 dark:border-white/10 rounded-xl px-4 py-3 text-[11px] font-bold text-slate-700 dark:text-slate-200 outline-none cursor-pointer hover:border-indigo-500 focus:border-indigo-500 transition-all shadow-sm" onchange="document.getElementById('deptSwitchForm').submit();">
                    @foreach (var ctx in Model.ContextosDisponibles)
                    {
                        if (ctx.DepartamentoId == Model.DepartamentoActivoId)
                        {
                            <option value="@ctx.DepartamentoId" selected>@ctx.NombreDepartamento</option>
                        }
                        else
                        {
                            <option value="@ctx.DepartamentoId">@ctx.NombreDepartamento</option>
                        }
                    }
                </select>
                <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-indigo-500 pointer-events-none group-hover:translate-y-[-30%] transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2.5"></path></svg>
            </form>
        </div>
    }
}
 @section SidebarExtra {
                    <div class="mb-auto">
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3 pl-3">Filtros de Estado</p>
                        <div class="space-y-1">
                            <a href="#" onclick="filtrar('Aprobado')" class="nav-item group"><span
                                class="w-2 h-2 rounded-full bg-emerald-500"></span> Aprobados</a>
                                <a href="#" onclick="filtrar('Revision')" class="nav-item group"><span
                                    class="w-2 h-2 rounded-full bg-amber-500"></span> En Revisión</a>
                                    <a href="#" onclick="filtrar('Borrador')" class="nav-item group"><span
                                        class="w-2 h-2 rounded-full bg-slate-400"></span> Borradores</a>
                                        <a href="#" onclick="filtrar('Obsoleto')" class="nav-item group"><span
                                            class="w-2 h-2 rounded-full bg-red-500"></span> Obsoletos</a>
                                            <a href="#" onclick="filtrar(null)" class="nav-item group"><span
                                                class="w-2 h-2 rounded-full bg-slate-300"></span> Todos</a>
                                            </div>
                                        </div>
}

                                               @section Scripts {
    <script>
        // ─── Estado global ───────────────────────────────────────────────
        let estadoActivo = null;
        let searchDebounceTimer = null;
        let lastQuery = '';
        const DEPT_ID = '@Model.DepartamentoActivoId';
        const FASTAPI_BASE = 'http://fastapi-service:8000';

        // ─── Estados que van por FastAPI (indexados en MongoDB) ──────────
        const ESTADOS_API = new Set(['Aprobado', 'Obsoleto']);
        // Los estados Revision y Borrador se buscan por DOM

        // ────────────────────────────────────────────────────────────────
        // FILTRO DOM (estados no indexados + filtro de sidebar)
        // ────────────────────────────────────────────────────────────────
        function aplicarFiltrosDom(termino) {
            document.querySelectorAll('[data-nombre]').forEach(el => {
                const estado = el.dataset.estado ?? '';
                const nombreOk = !termino || (el.dataset.nombre ?? '').includes(termino) || (el.dataset.version ?? '').includes(termino);
                const estadoOk = !estadoActivo || estado === estadoActivo;
                el.style.display = (nombreOk && estadoOk) ? '' : 'none';
            });

            document.querySelectorAll('details.iso-folder').forEach(details => {
                details.style.display = '';
                const hayVisibles = [...details.querySelectorAll('[data-nombre]')]
                    .some(el => el.style.display !== 'none');
                details.style.display = hayVisibles ? '' : 'none';
            });
        }

        function aplicarFiltros() {
            const termino = document.getElementById('buscador').value.toLowerCase().trim();
            if (!termino && !estadoActivo) {
                document.querySelectorAll('[data-nombre]').forEach(el => el.style.display = '');
                document.querySelectorAll('details.iso-folder').forEach(d => d.style.display = '');
                return;
            }
            aplicarFiltrosDom(termino);
        }

        function filtrar(estado) {
            estadoActivo = estado;
            document.getElementById('buscador').value = '';
            ocultarDropdown();
            aplicarFiltros();
        }

        // ────────────────────────────────────────────────────────────────
        // BÚSQUEDA DOM para autocompletado (Revision + Borrador)
        // ────────────────────────────────────────────────────────────────
        function buscarEnDom(termino) {
            const resultados = [];
            document.querySelectorAll('[data-nombre][data-estado]').forEach(el => {
                const estado = el.dataset.estado ?? '';
                if (ESTADOS_API.has(estado)) return; // solo no-indexados

                const nombre = el.dataset.nombre ?? '';
                const version = el.dataset.version ?? '';

                if (nombre.includes(termino) || version.includes(termino)) {
                    // Buscar el nombre bonito y código del padre
                    const card = el.closest('.bg-white\\/80, [class*="bg-white"]');
                    const h4 = el.querySelector('.text-sm.font-bold');
                    const codigo = el.querySelector('.font-mono');

                    resultados.push({
                        nombre: h4 ? h4.textContent.trim() : nombre,
                        codigo: codigo ? codigo.textContent.trim() : '',
                        estado: estado,
                        version: version,
                        elemento: el
                    });
                }
            });
            return resultados.slice(0, 4);
        }

        // ────────────────────────────────────────────────────────────────
        // LLAMADA A FASTAPI (Aprobados + Obsoletos)
        // ────────────────────────────────────────────────────────────────
   // En buscarEnApi, normaliza el estado al recibirlo:
async function buscarEnApi(termino) {
    const params = new URLSearchParams({ q: termino, departamento: DEPT_ID });
    const resp = await fetch(`/Dashboard/Autocomplete?${params}`, {
        signal: AbortSignal.timeout(15000)
    });
    if (!resp.ok) throw new Error(`Proxy ${resp.status}`);
    const data = await resp.json();
    
    // Normalizar estado a PascalCase para consistencia con el DOM
    return (data.results ?? []).map(r => ({
        ...r,
        estado: r.estado
            ? r.estado.charAt(0).toUpperCase() + r.estado.slice(1).toLowerCase()
            : ''
    }));
}
        // ────────────────────────────────────────────────────────────────
        // RENDER DEL DROPDOWN
        // ────────────────────────────────────────────────────────────────
        const estadoBadge = {
            'Aprobado':  'bg-emerald-100 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400',
            'Obsoleto':  'bg-red-100 text-red-700 dark:bg-red-500/10 dark:text-red-400',
            'Revision':  'bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400',
            'Borrador':  'bg-slate-200 text-slate-700 dark:bg-white/10 dark:text-slate-300',
        };

        function highlight(text, termino) {
            if (!termino) return text;
            const re = new RegExp(`(${termino.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
            return text.replace(re, '<mark class="bg-indigo-100 dark:bg-indigo-500/20 text-indigo-700 dark:text-indigo-300 rounded px-0.5 not-italic font-bold">$1</mark>');
        }

        function renderApiResult(doc, termino) {
            const nombre = doc.display_name ?? '—';
            const codigo = doc.metadata?.codigo ?? '';
            const nivel  = doc.metadata?.nivel ?? '';
            const estado = doc.estado ?? '';
            const snippet = doc.snippet ?? '';
            const badgeClass = estadoBadge[estado] ?? 'bg-slate-100 text-slate-600';

            return `<div class="autocomplete-item px-4 py-3 hover:bg-slate-50 dark:hover:bg-white/5 cursor-pointer border-b border-slate-100 dark:border-white/5 last:border-0 transition-colors"
                        data-tipo="api" data-storage="${doc.storage_path ?? ''}">
                <div class="flex items-start justify-between gap-2 mb-1">
                    <p class="text-xs font-bold text-slate-800 dark:text-white leading-tight">${highlight(nombre, termino)}</p>
                    <span class="shrink-0 text-[9px] font-bold px-1.5 py-0.5 rounded ${badgeClass}">${estado}</span>
                </div>
                <div class="flex items-center gap-2 text-[10px] text-slate-500">
                    <span class="font-mono text-indigo-500">${highlight(codigo, termino)}</span>
                    ${nivel ? `<span class="text-slate-300 dark:text-slate-600">·</span><span>${nivel}</span>` : ''}
                </div>
                ${snippet ? `<p class="text-[10px] text-slate-400 mt-1 leading-snug line-clamp-2">${snippet}</p>` : ''}
            </div>`;
        }

        function renderDomResult(item, termino) {
            const badgeClass = estadoBadge[item.estado] ?? 'bg-slate-100 text-slate-600';
            return `<div class="autocomplete-item px-4 py-3 hover:bg-slate-50 dark:hover:bg-white/5 cursor-pointer border-b border-slate-100 dark:border-white/5 last:border-0 transition-colors"
                        data-tipo="dom" data-estado="${item.estado}">
                <div class="flex items-start justify-between gap-2">
                    <p class="text-xs font-bold text-slate-800 dark:text-white leading-tight">${highlight(item.nombre, termino)}</p>
                    <span class="shrink-0 text-[9px] font-bold px-1.5 py-0.5 rounded ${badgeClass}">${item.estado}</span>
                </div>
                ${item.codigo ? `<span class="font-mono text-[10px] text-indigo-500">${item.codigo}</span>` : ''}
                <p class="text-[10px] text-slate-400 mt-0.5">v${item.version}</p>
            </div>`;
        }

        function mostrarDropdown(apiResults, domResults, termino) {
            const dropdown = document.getElementById('autocomplete-dropdown');
            const apiSection = document.getElementById('autocomplete-api-section');
            const domSection = document.getElementById('autocomplete-dom-section');
            const emptyState = document.getElementById('autocomplete-empty');
            const apiContainer = document.getElementById('autocomplete-api-results');
            const domContainer = document.getElementById('autocomplete-dom-results');

            const hayApi = apiResults.length > 0;
            const hayDom = domResults.length > 0;

            if (!hayApi && !hayDom) {
                apiSection.classList.add('hidden');
                domSection.classList.add('hidden');
                emptyState.classList.remove('hidden');
            } else {
                emptyState.classList.add('hidden');

                if (hayApi) {
                    apiContainer.innerHTML = apiResults.map(r => renderApiResult(r, termino)).join('');
                    apiSection.classList.remove('hidden');
                } else {
                    apiSection.classList.add('hidden');
                }

                if (hayDom) {
                    domContainer.innerHTML = domResults.map(r => renderDomResult(r, termino)).join('');
                    domSection.classList.remove('hidden');
                } else {
                    domSection.classList.add('hidden');
                }
            }

            dropdown.classList.remove('hidden');

            // Clicks en resultados de API → scroll al primer doc o abrir path
            apiContainer.querySelectorAll('.autocomplete-item').forEach((el, i) => {
                el.addEventListener('click', () => {
                    const storage = el.dataset.storage;
                    ocultarDropdown();
                    document.getElementById('buscador').value = '';
                    // Aplicamos filtro de Aprobado/Obsoleto para resaltar en DOM
                    const estado = apiResults[i]?.estado;
                    if (estado) filtrar(estado);
                });
            });

            // Clicks en resultados DOM → scroll + abrir el details padre
            domContainer.querySelectorAll('.autocomplete-item').forEach((el, i) => {
                el.addEventListener('click', () => {
                    ocultarDropdown();
                    const item = domResults[i];
                    if (item?.elemento) {
                        const details = item.elemento.closest('details');
                        if (details) {
                            details.open = true;
                            details.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        }
                        item.elemento.style.outline = '2px solid #6366f1';
                        item.elemento.style.borderRadius = '12px';
                        setTimeout(() => { item.elemento.style.outline = ''; }, 2000);
                    }
                    document.getElementById('buscador').value = item.nombre;
                    aplicarFiltrosDom(item.nombre.toLowerCase());
                });
            });
        }

        function ocultarDropdown() {
            document.getElementById('autocomplete-dropdown').classList.add('hidden');
        }

        // ────────────────────────────────────────────────────────────────
        // ORQUESTADOR HÍBRIDO con debounce
        // ────────────────────────────────────────────────────────────────
        async function busquedaHibrida(termino) {
            if (!termino || termino.length < 2) {
                ocultarDropdown();
                aplicarFiltros();
                return;
            }

            const spinner = document.getElementById('search-spinner');
            spinner.classList.remove('hidden');

            // Búsqueda DOM (síncrona, inmediata)
            const domResults = buscarEnDom(termino);

            // Búsqueda API (asíncrona)
            let apiResults = [];
            try {
                // Solo llamamos a la API si no hay un filtro activo de DOM states
                const estadosFiltrados = estadoActivo ? [estadoActivo] : null;
                const necesitaApi = !estadosFiltrados || ESTADOS_API.has(estadosFiltrados[0]);
                if (necesitaApi) {
                    apiResults = await buscarEnApi(termino);
                    // Filtrar por estado activo si hay uno de tipo API
                    if (estadoActivo && ESTADOS_API.has(estadoActivo)) {
                        apiResults = apiResults.filter(r => r.estado === estadoActivo);
                    }
                }
            } catch (err) {
                console.warn('[NormaQ] FastAPI no disponible:', err.message);
                // Fallback silencioso: solo mostramos resultados DOM
            }

            spinner.classList.add('hidden');
            mostrarDropdown(apiResults, domResults, termino);

            // También aplicamos filtro visual en el árbol DOM
            aplicarFiltrosDom(termino);
        }

        // ────────────────────────────────────────────────────────────────
        // EVENT LISTENERS
        // ────────────────────────────────────────────────────────────────
        const buscador = document.getElementById('buscador');

        buscador.addEventListener('input', () => {
            const termino = buscador.value.toLowerCase().trim();
            if (termino === lastQuery) return;
            lastQuery = termino;

            clearTimeout(searchDebounceTimer);
            searchDebounceTimer = setTimeout(() => busquedaHibrida(termino), 280);
        });

        buscador.addEventListener('focus', () => {
            const termino = buscador.value.toLowerCase().trim();
            if (termino.length >= 2) busquedaHibrida(termino);
        });

        // Cerrar al hacer click fuera
        document.addEventListener('click', (e) => {
            if (!document.getElementById('search-wrapper').contains(e.target)) {
                ocultarDropdown();
            }
        });

        // Cerrar con Escape
        buscador.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                ocultarDropdown();
                buscador.blur();
            }
        });

        // ────────────────────────────────────────────────────────────────
        // CONTEO SIDEBAR (sin cambios)
        // ────────────────────────────────────────────────────────────────
        function actualizarConteo() {
            const conteos = { Aprobado: 0, Revision: 0, Borrador: 0, Obsoleto: 0 };
            document.querySelectorAll('[data-estado]').forEach(el => {
                const estado = el.dataset.estado;
                if (Object.prototype.hasOwnProperty.call(conteos, estado)) conteos[estado]++;
            });
            Object.entries(conteos).forEach(([estado, n]) => {
                const el = document.getElementById('conteo-' + estado.toLowerCase());
                if (el) el.textContent = n;
            });
        }

        document.addEventListener('DOMContentLoaded', actualizarConteo);
    </script>
}

@section SideDocCount {
    @{
        var snap       = Model.Snapshot;
        var aprobados  = snap?.Aprobados      ?? 0;
        var borradores = snap?.Borradores     ?? 0;
        var revision   = snap?.EnRevision     ?? 0;
        var obsoletos  = snap?.Obsoletos      ?? 0;
        var total      = snap?.TotalVersiones ?? 0;

        // Cálculo exacto de porcentajes para el SVG
        double pctAprobados  = total > 0 ? ((double)aprobados / total) * 100 : 0;
        double pctRevision   = total > 0 ? ((double)revision / total) * 100 : 0;
        double pctBorradores = total > 0 ? ((double)borradores / total) * 100 : 0;
        double pctObsoletos  = total > 0 ? ((double)obsoletos / total) * 100 : 0;

        var pctCentral = total > 0 ? (int)Math.Round(pctAprobados) : 0;

        // Offset acumulativo respetando el nuevo orden secuencial
        double offsetAprobados  = 0;
        double offsetRevision   = pctAprobados;
        double offsetBorradores = pctAprobados + pctRevision;
        double offsetObsoletos  = pctAprobados + pctRevision + pctBorradores;
    }

    <div class="flex flex-col gap-5 w-full">
        @* Gráfica de Dona Multicolor con tus colores exactos *@
        <div class="w-[100px] h-[100px] relative mx-auto shrink-0">
            <svg viewBox="0 0 36 36" class="circular-chart w-full h-full transform -rotate-90">
                <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"></path>
                
                @if (total > 0)
                {
                    <path class="circle transition-all duration-500" 
                          stroke="#10b981" 
                          stroke-dasharray="@pctAprobados.ToString("F2", System.Globalization.CultureInfo.InvariantCulture), 100" 
                          stroke-dashoffset="-@offsetAprobados.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"></path>

                    <path class="circle transition-all duration-500" 
                          stroke="#f59e0b" 
                          stroke-dasharray="@pctRevision.ToString("F2", System.Globalization.CultureInfo.InvariantCulture), 100" 
                          stroke-dashoffset="-@offsetRevision.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"></path>

                    <path class="circle transition-all duration-500" 
                          stroke="#94a3b8" 
                          stroke-dasharray="@pctBorradores.ToString("F2", System.Globalization.CultureInfo.InvariantCulture), 100" 
                          stroke-dashoffset="-@offsetBorradores.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"></path>

                    <path class="circle transition-all duration-500" 
                          stroke="#ef4444" 
                          stroke-dasharray="@pctObsoletos.ToString("F2", System.Globalization.CultureInfo.InvariantCulture), 100" 
                          stroke-dashoffset="-@offsetObsoletos.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"></path>
                }
            </svg>
            
            <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-xs font-bold text-slate-800 dark:text-white font-display">@pctCentral%</span>
            </div>
        </div>

        @* Leyenda original respetando tus clases de Tailwind e IDs *@
        <div class="text-[10px] space-y-1.5 font-medium text-slate-600 dark:text-slate-400 border-t border-slate-200/60 dark:border-white/5 pt-3.5">
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span> 
                <span id="conteo-aprobado" class="font-bold text-slate-900 dark:text-white">@aprobados</span> Aprobados
            </div>
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-amber-500 shrink-0"></span> 
                <span id="conteo-revision" class="font-bold text-slate-900 dark:text-white">@revision</span> En Revisión
            </div>
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-slate-400 shrink-0"></span> 
                <span id="conteo-borrador" class="font-bold text-slate-900 dark:text-white">@borradores</span> Borradores
            </div>
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-red-500 shrink-0"></span> 
                <span id="conteo-obsoleto" class="font-bold text-slate-900 dark:text-white">@obsoletos</span> Obsoletos
            </div>
        </div>
    </div>
}

