@model NormaQ.ViewModels.DashboardViewModel

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Dashboard Documental";
    ViewData["ActiveNav"] = "dashboard";
    ViewData["UsuarioNombre"] = Model.UsuarioNombre;
    ViewData["RolActivoNombre"] = Model.RolActivoNombre;
    ViewData["DepartamentoActivoId"] = Model.DepartamentoActivoId; // <- ¿está esto?
}

<div class="flex-1 flex flex-col p-8 overflow-hidden gap-5">
    <div class="shrink-0 bg-gradient-to-br from-indigo-600 to-indigo-700 dark:from-indigo-600 dark:to-indigo-900 rounded-[20px] p-6 text-white flex justify-between items-center shadow-lg shadow-indigo-500/20 animate-fade-in-up">
        <div class="flex-1">
            <span class="inline-block px-2 py-0.5 bg-white/20 backdrop-blur-md rounded border border-white/20 text-[9px] font-bold tracking-widest uppercase mb-2">Contexto Operativo</span>
            <h2 class="font-display text-2xl font-bold mb-1">¡Hola, @Model.UsuarioNombre!</h2>
            <p class="text-indigo-100 text-xs">Repositorio documental oficial de <strong>@Model.DepartamentoActivoNombre</strong>.</p>
        </div>

        <div class="flex gap-6 pr-4 border-l border-white/10 pl-6">
            <div class="text-center">
                <p class="text-2xl font-bold font-display leading-none">@(Model.ArbolDocumental?.Count ?? 0)</p>
                <p class="text-[9px] uppercase tracking-widest text-indigo-200 mt-1">Niveles ISO</p>
            </div>
            <div class="text-center">
                <p class="text-2xl font-bold font-display leading-none">0</p>
                <p class="text-[9px] uppercase tracking-widest text-indigo-200 mt-1">Alertas</p>
            </div>
        </div>
    </div>

    <div class="flex-1 flex flex-col min-h-0 animate-fade-in-up stagger-1">
        <div class="flex justify-between items-end mb-3 shrink-0">
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Estructura Documental ISO 9001</p>
        </div>

        <div class="flex-1 overflow-y-auto pr-2 pb-4">
            @if (Model.ArbolDocumental != null)
            {
                @foreach (var nivel in Model.ArbolDocumental)
                {
                    <details class="iso-folder group shadow-sm">
                        <summary class="flex items-center justify-between p-3.5 px-5 select-none hover:bg-slate-50/50 dark:hover:bg-white/5 transition-colors rounded-xl">
                            <div class="flex items-center gap-4">
                                <svg class="folder-arrow w-4 h-4 text-slate-400 dark:text-slate-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
                                <div class="w-9 h-9 rounded-lg bg-white dark:bg-black/20 flex items-center justify-center border border-slate-200 dark:border-white/5 shadow-sm">
                                    <svg class="folder-icon w-4 h-4 text-slate-400 transition-colors duration-200" fill="currentColor" viewBox="0 0 24 24"><path d="M3 7a2 2 0 012-2h4.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293h6.586a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"></path></svg>
                                </div>
                                <div>
                                    <h4 class="text-sm font-bold text-slate-800 dark:text-white">0@(nivel.Numero) - @nivel.Nombre</h4>
                                    <p class="text-[10px] font-medium text-slate-500">@(nivel.DocumentosLogicos?.Count ?? 0) documentos</p>
                                </div>
                            </div>
                        </summary>

                        <div class="p-5 pt-3 border-t border-slate-200/60 dark:border-white/5 ml-4 bg-slate-50/50 dark:bg-black/10 rounded-b-xl">
                            @if (Model.RolActivoNombre == "Administrador")
                            {
                                <div class="mb-4 pb-4 border-b border-slate-200/60 dark:border-white/5 flex justify-between items-center">
                                    <span class="text-[10px] text-slate-500 uppercase tracking-widest">Contenido del Nivel</span>
                                    <a asp-action="CrearDocumento" asp-route-departamentoId="@Model.DepartamentoActivoId" class="px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-bold shadow-md transition-transform hover:scale-105 flex items-center gap-1.5">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg> Añadir Documento
                                    </a>
                                </div>
                            }

                            @if (nivel.DocumentosLogicos == null || !nivel.DocumentosLogicos.Any())
                            {
                                <div class="py-6 text-center bg-white/50 dark:bg-white/5 rounded-xl border border-dashed border-slate-300 dark:border-white/10">
                                    <p class="text-xs font-medium text-slate-500">No hay documentos en este nivel.</p>
                                </div>
                            }
                            else
                            {
                                <div class="space-y-3">
                                    @foreach (var doc in nivel.DocumentosLogicos)
                                    {
                                        <div class="bg-white/80 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 rounded-xl p-4 shadow-sm">
                                            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-3">
                                                <div class="flex items-start gap-3">
                                                    <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shrink-0">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                                    </div>
                                                    <div>
                                                        <h4 class="text-sm font-bold text-slate-900 dark:text-white">@doc.Nombre</h4>
                                                        <span class="text-[9px] font-mono font-bold text-indigo-500 bg-indigo-50 dark:bg-indigo-500/10 px-2 py-0.5 rounded">@doc.Codigo</span>
                                                    </div>
                                                </div>

                                                @if (Model.RolActivoNombre == "Elaborador")
                                                {
                                                    <a asp-action="SubirVersion" asp-route-documentoId="@doc.Id" class="w-full sm:w-auto px-3 py-1.5 bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20 rounded-lg text-xs font-bold hover:bg-emerald-100 dark:hover:bg-emerald-500/20 transition-colors flex items-center justify-center gap-1.5">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg> Subir Versión
                                                    </a>
                                                }
                                            </div>

                                            @if (doc.VersionesFisicas.Any())
                                            {
                                                <div class="bg-slate-50/50 dark:bg-black/20 rounded-lg p-3 border border-slate-100 dark:border-white/5">
                                                    <div class="space-y-2">
                                                        @foreach (var version in doc.VersionesFisicas)
                                                        {
                                                            string badgeColors = version.Estado switch {
                                                                "Aprobado" => "bg-emerald-100 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400 border-emerald-200 dark:border-emerald-400/20",
                                                                "Revision" => "bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border-amber-200 dark:border-amber-400/20",
                                                                "Borrador" => "bg-slate-200 text-slate-700 dark:bg-white/10 dark:text-slate-300 border-slate-300 dark:border-slate-400/20",
                                                                "Obsoleto" => "bg-red-100 text-red-700 dark:bg-red-500/10 dark:text-red-400 border-red-200 dark:border-red-400/20",
                                                                _ => "bg-slate-100 text-slate-700 dark:bg-white/5 dark:text-slate-400"
                                                            };
                                                            string dotColor = version.Estado switch { "Aprobado" => "bg-emerald-500", "Revision" => "bg-amber-500", "Borrador" => "bg-slate-500", "Obsoleto" => "bg-red-500", _ => "bg-slate-500" };

                                                            string rowClasses = version.RequiereMiIntervencion 
                                                                ? "bg-amber-50/50 dark:bg-amber-500/5 border-amber-300/50 dark:border-amber-500/30 shadow-[0_0_8px_rgba(245,158,11,0.05)]" 
                                                                : "bg-white dark:bg-white/5 border-slate-200/60 dark:border-white/5";

                                                            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center p-2.5 rounded-lg border @rowClasses gap-3 transition-colors">
                                                                <div class="flex items-center gap-3">
                                                                    <span class="text-xs font-bold font-mono text-slate-700 dark:text-slate-200">v@(version.VersionMayor).@(version.VersionMenor)</span>
                                                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-wide border @badgeColors">
                                                                        <span class="w-1.5 h-1.5 rounded-full @dotColor"></span> @version.Estado
                                                                    </span>
                                                                </div>
                                                                <div class="flex items-center gap-2 w-full sm:w-auto">
                                                                    <a asp-action="VisualizarVersion" asp-route-versionId="@version.Id" asp-route-intervencion="@version.RequiereMiIntervencion" class="flex-1 sm:flex-none px-3 py-1.5 bg-slate-100 hover:bg-slate-200 dark:bg-white/5 dark:hover:bg-white/10 text-slate-700 dark:text-slate-300 rounded-lg text-[10px] font-bold transition-colors flex items-center justify-center gap-1.5">
                                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg> Abrir
                                                                    </a>

                                                                    @if ((Model.RolActivoNombre == "Revisor" || Model.RolActivoNombre == "Aprobador") && version.RequiereMiIntervencion)
                                                                    {
                                                                        <a asp-action="VisualizarVersion" asp-route-versionId="@version.Id" asp-route-intervencion="@version.RequiereMiIntervencion" class="flex-1 sm:flex-none px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-white rounded-lg text-[10px] font-bold shadow-md shadow-amber-500/20 transition-colors flex items-center justify-center gap-1.5">
                                                                            Acción Requerida
                                                                        </a>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </details>
                }
            }
        </div>
    </div>
</div>

@section DeptSelector {
    @if (Model.ContextosDisponibles != null && Model.ContextosDisponibles.Count > 1)
    {
        <div class="mt-4 pt-5 border-t border-slate-200/60 dark:border-white/5 shrink-0">
            <form method="get" asp-action="Index" id="deptSwitchForm" class="relative group">
                <select name="selectedDeptId" class="w-full appearance-none bg-white/60 dark:bg-black/20 border border-slate-200/60 dark:border-white/10 rounded-xl px-4 py-3 text-[11px] font-bold text-slate-700 dark:text-slate-200 outline-none cursor-pointer hover:border-indigo-500 focus:border-indigo-500 transition-all shadow-sm" onchange="document.getElementById('deptSwitchForm').submit();">
                    @foreach (var ctx in Model.ContextosDisponibles)
                    {
                        if (ctx.DepartamentoId == Model.DepartamentoActivoId)
                        {
                            <option value="@ctx.DepartamentoId" selected>@ctx.NombreDepartamento</option>
                        }
                        else
                        {
                            <option value="@ctx.DepartamentoId">@ctx.NombreDepartamento</option>
                        }
                    }
                </select>
                <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-indigo-500 pointer-events-none group-hover:translate-y-[-30%] transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2.5"></path></svg>
            </form>
        </div>
    }
}