@model NormaQ.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard Documental";
}

<!-- Navegación Superior -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
    <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold" href="#"><i class="bi bi-shield-check text-primary me-2"></i>NormaQ</a>
        
        <div class="d-flex align-items-center">
            <span class="text-light me-3 small">
                <i class="bi bi-person-circle me-1"></i> @Model.UsuarioNombre
            </span>
            <!-- Nota: Generalmente el cierre de sesión apunta a Logout, no a Login, para destruir la cookie -->
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                <button type="submit" class="btn btn-outline-light btn-sm">Cerrar Sesión</button>
            </form>
        </div>
    </div>
</nav>

<div class="container-fluid px-4">
    
    <!-- Hero Section: Contexto del Usuario -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="p-5 bg-white border rounded-3 shadow-sm d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="text-uppercase text-muted fw-bold mb-1 tracking-wide">Departamento Actual</h5>
                    <h1 class="display-4 fw-bolder text-dark mb-2">@Model.DepartamentoActivoNombre</h1>
                    <div class="d-flex align-items-center mt-3">
                        <span class="badge bg-primary fs-5 px-3 py-2 shadow-sm">
                            <i class="bi bi-person-badge me-2"></i>Rol: @Model.RolActivoNombre
                        </span>
                    </div>
                </div>
                
                <!-- Selector de Departamentos -->
                @if (Model.ContextosDisponibles.Count > 1)
                {
                    <div class="bg-light p-4 rounded border">
                        <label class="form-label text-muted small fw-bold mb-2">
                            <i class="bi bi-arrow-left-right me-1"></i> Cambiar de Departamento
                        </label>
                        <form method="get" asp-action="Index" id="deptSwitchForm">
                            <select name="selectedDeptId" class="form-select form-select-lg shadow-none border-secondary" onchange="document.getElementById('deptSwitchForm').submit();">
                                @foreach (var ctx in Model.ContextosDisponibles)
                                {
                                    if (ctx.DepartamentoId == Model.DepartamentoActivoId)
                                    {
                                        <option value="@ctx.DepartamentoId" selected>@ctx.NombreDepartamento (@ctx.NombreRol)</option>
                                    }
                                    else
                                    {
                                        <option value="@ctx.DepartamentoId">@ctx.NombreDepartamento (@ctx.NombreRol)</option>
                                    }
                                }
                            </select>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Estructura Documental ISO -->
    <div class="row mb-4">
        <div class="col-12">
            <h4 class="fw-bold mb-3"><i class="bi bi-folder-symlink me-2"></i>Estructura ISO 9001</h4>
            <p class="text-muted">Explora el repositorio documental normativo del departamento de <strong>@Model.DepartamentoActivoNombre</strong>.</p>
        </div>
    </div>

    <!-- ÁRBOL JERÁRQUICO -->
    <div class="accordion shadow-sm mb-5" id="accordionNiveles">
        @foreach (var nivel in Model.ArbolDocumental)
        {
            var targetId = $"collapseNivel_{nivel.Id}";
            var headerId = $"headingNivel_{nivel.Id}";

            <!-- CAPA 1: NIVEL ISO -->
            <div class="accordion-item border-0 border-bottom">
                <h2 class="accordion-header" id="@headerId">
                    <button class="accordion-button collapsed fw-bold bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#@targetId" aria-expanded="false" aria-controls="@targetId">
                        <i class="bi bi-folder-fill text-warning me-3 fs-5"></i>
                        0@(nivel.Numero) - @nivel.Nombre
                        <span class="badge bg-secondary ms-auto me-3 rounded-pill">@nivel.DocumentosLogicos.Count docs</span>
                    </button>
                </h2>
                <div id="@targetId" class="accordion-collapse collapse" aria-labelledby="@headerId" data-bs-parent="#accordionNiveles">
                    <div class="accordion-body bg-white p-4">
                        
                        <!-- RENDERIZADO UI: ADMINISTRADOR -->
                        @if (Model.RolActivoNombre == "Administrador")
                        {
                            <div class="mb-3 border-bottom pb-3">
                                <button class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">
                                    <i class="bi bi-plus-lg me-1"></i> Nuevo Documento Lógico
                                </button>
                                <span class="ms-2 text-muted small">Crea un registro maestro</span>
                            </div>
                        }

                        @if (!nivel.DocumentosLogicos.Any())
                        {
                            <div class="text-center p-4 border border-dashed rounded bg-light">
                                <i class="bi bi-inbox text-muted fs-3 d-block mb-2"></i>
                                <span class="text-muted small">Carpeta vacía.</span>
                            </div>
                        }
                        else
                        {
                            <!-- CAPA 2: DOCUMENTOS LÓGICOS -->
                            <div class="list-group list-group-flush border-start border-2 border-secondary ms-3">
                                @foreach (var doc in nivel.DocumentosLogicos)
                                {
                                    <div class="list-group-item border-0 py-3 ps-4 pe-0 position-relative">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div class="fw-bold text-dark">
                                                <i class="bi bi-file-earmark-text text-primary me-2"></i>
                                                <span class="text-primary">@doc.Codigo</span> — @doc.Nombre
                                            </div>

                                            <!-- RENDERIZADO UI: ELABORADOR -->
                                            @if (Model.RolActivoNombre == "Elaborador")
                                            {
                                                <button class="btn btn-outline-success btn-sm">
                                                    <i class="bi bi-cloud-upload me-1"></i> Subir Nueva Versión
                                                </button>
                                            }
                                        </div>

                                        <!-- CAPA 3: HISTORIAL DE VERSIONES -->
                                        @if (doc.VersionesFisicas.Any())
                                        {
                                            <div class="mt-2 ms-4 bg-light p-2 rounded border">
                                                <small class="text-uppercase fw-bold text-muted d-block mb-2" style="font-size: 0.7rem;">Historial de Versiones Físicas</small>
                                                <div class="d-flex flex-column gap-2">
                                                    @foreach (var version in doc.VersionesFisicas)
                                                    {
                                                        string badgeClass = version.Estado switch {
                                                            "Aprobado" => "bg-success",
                                                            "Revision" => "bg-warning text-dark",
                                                            "Borrador" => "bg-secondary",
                                                            "Obsoleto" => "bg-danger",
                                                            _ => "bg-light text-dark"
                                                        };

                                                        string filaBg = version.RequiereMiIntervencion ? "bg-warning bg-opacity-10 border border-warning" : "bg-white border";

                                                        <div class="d-flex justify-content-between align-items-center p-2 rounded @filaBg">
                                                            <div class="small">
                                                                <span class="fw-bold me-2">v@(version.VersionMayor).@(version.VersionMenor)</span>
                                                                <span class="badge @badgeClass">@version.Estado</span>
                                                            </div>
                                                            
                                                            <div class="d-flex gap-2">
                                                                <button class="btn btn-link btn-sm text-decoration-none p-0">
                                                                    <i class="bi bi-eye"></i> Ver (MinIO)
                                                                </button>

                                                                <!-- RENDERIZADO UI: REVISOR / APROBADOR -->
                                                                @if ((Model.RolActivoNombre == "Revisor" || Model.RolActivoNombre == "Aprobador") && version.RequiereMiIntervencion)
                                                                {
                                                                    <button class="btn btn-warning btn-sm ms-2 shadow-sm fw-bold">
                                                                        <i class="bi bi-pen me-1"></i> Revisar / Aprobar
                                                                    </button>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>