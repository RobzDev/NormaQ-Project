@model NormaQ.ViewModels.DashboardAnaliticasViewModel

@{
    ViewData["Title"] = "Analíticas";
    ViewData["ActiveNav"] = "analiticas";
    ViewData["UsuarioNombre"] = Model.UsuarioNombre;
    ViewData["RolActivoNombre"] = Model.RolActivoNombre;
    ViewData["Departamento"] = Model.DepartamentoActivoId;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["DepartamentoActivoId"] = Model.DepartamentoActivoId;
}

@* ── Serialización segura para JS + Configuración de Chart.js adaptativa ──────────────── *@
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        // Detectar si el layout está en modo oscuro para ajustar las fuentes de las gráficas
        const isDark = document.documentElement.classList.contains('dark');
        const textColor = isDark ? '#94a3b8' : '#64748b';
        const gridColor = isDark ? 'rgba(255, 255, 255, 0.05)' : 'rgba(0, 0, 0, 0.05)';

        // Configuración global por defecto para Chart.js
        Chart.defaults.color = textColor;
        Chart.defaults.font.family = "'Plus Jakarta Sans', sans-serif";
        Chart.defaults.plugins.legend.labels.boxWidth = 12;
        Chart.defaults.plugins.legend.labels.usePointStyle = true;

        const baseScales = {
        x: { grid: { color: gridColor }, ticks: { color: textColor } },
        y: { grid: { color: gridColor }, ticks: { color: textColor } }
        };

        // ── Actividad semanal ────────────────────────────────────────────────────────
        const actividadData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        Model.ActividadSemanal.Select(x => new
                        {
                            semana = x.InicioSemana.ToString("dd MMM"),
                            creadas = x.VersionesCreadas,
                            aprobadas = x.VersionesAprobadas,
                            rechazadas = x.VersionesRechazadas
                        })
                    ));

        const canvasActividad = document.getElementById('chartActividad');
        if (canvasActividad) {
        new Chart(canvasActividad, {
        type: 'bar',
        data: {
        labels: actividadData.map(x => x.semana),
        datasets: [
        { label: 'Creadas', data: actividadData.map(x => x.creadas), backgroundColor: '#6366f1', borderRadius: 6 },
        { label: 'Aprobadas', data: actividadData.map(x => x.aprobadas), backgroundColor: '#10b981', borderRadius: 6 },
        { label: 'Rechazadas', data: actividadData.map(x => x.rechazadas), backgroundColor: '#ef4444', borderRadius: 6 }
        ]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'top', align: 'end' } },
        scales: baseScales
        }
        });
        }

        // ── Documentos con más versiones ─────────────────────────────────────────────
        const versionesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        Model.DocumentosMasVersiones.Select(x => new
                        {
                            codigo = x.Codigo,
                            total = x.TotalVersiones,
                            conRechazo = x.VersionesConRechazo
                        })
                    ));

        const canvasVersiones = document.getElementById('chartVersiones');
        if (canvasVersiones) {
        new Chart(canvasVersiones, {
        type: 'bar',
        data: {
        labels: versionesData.map(x => x.codigo),
        datasets: [
        { label: 'Total versiones', data: versionesData.map(x => x.total), backgroundColor: '#818cf8', borderRadius: 6 },
        { label: 'Versiones rechazadas', data: versionesData.map(x => x.conRechazo), backgroundColor: '#f97316', borderRadius: 6 }
        ]
        },
        options: {
        indexAxis: 'y',
        responsive: true,
        plugins: { legend: { position: 'top', align: 'end' } },
        scales: baseScales
        }
        });
        }

        // ── Usuarios más activos ──────────────────────────────────────────────────────
        const activosData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        Model.UsuariosActivos.Select(x => new
                        {
                            nombre = x.Usuario,
                            aprobadas = x.FirmasAprobadas,
                            rechazadas = x.FirmasRechazadas
                        })
                    ));

        const canvasActivos = document.getElementById('chartActivos');
        if (canvasActivos) {
        new Chart(canvasActivos, {
        type: 'bar',
        data: {
        labels: activosData.map(x => x.nombre),
        datasets: [
        { label: 'Firmas aprobadas', data: activosData.map(x => x.aprobadas), backgroundColor: '#10b981', borderRadius: 6 },
        { label: 'Firmas rechazadas', data: activosData.map(x => x.rechazadas), backgroundColor: '#ef4444', borderRadius: 6 }
        ]
        },
        options: {
        responsive: true,
        plugins: { legend: { position: 'top', align: 'end' } },
        scales: baseScales
        }
        });
        }
        });
    </script>
}

@* ── Contenido de la Vista Integrado al Layout ────────────────────────────── *@
<div class="flex-1 overflow-y-auto p-8 space-y-8 max-h-[calc(100vh-5rem)]">

    @* Encabezado de la página *@
    <div class="animate-fade-in-up">
        <h2 class="text-2xl font-display font-bold text-slate-900 dark:text-white tracking-tight">
            Analíticas del Departamento <span
            class="text-indigo-600 dark:text-indigo-400">@Model.DepartamentoActivoNombre</span>
        </h2>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 uppercase tracking-wider font-semibold">Últimos 30
            días</p>
        </div>

        @* ── Fila 1: Actividad semanal ───────────────────────────────────────── *@
        <div
            class="animate-fade-in-up stagger-1 p-6 rounded-2xl bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 shadow-sm backdrop-blur-md">
            <h3 class="text-sm font-bold text-slate-900 dark:text-white font-display mb-4 uppercase tracking-wider">
                Actividad semanal</h3>
                @if (!Model.ActividadSemanal.Any())
                {
                    <p class="text-xs text-slate-400 dark:text-slate-500 py-4 text-center">Sin actividad registrada en este período.
                    </p>
                }
                else
                {
                    <div class="h-64 relative w-full">
                        <canvas id="chartActividad"></canvas>
                    </div>
                }
            </div>

            @* ── Fila 2: Rejilla Dual (Versiones + Usuarios) ──────────────────────── *@
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

                @* Documentos con más versiones *@
                <div
                    class="animate-fade-in-up stagger-2 p-6 rounded-2xl bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 shadow-sm backdrop-blur-md">
                    <h3 class="text-sm font-bold text-slate-900 dark:text-white font-display mb-4 uppercase tracking-wider">
                        Documentos críticos (Versiones)</h3>
                        @if (!Model.DocumentosMasVersiones.Any())
                        {
                            <p class="text-xs text-slate-400 dark:text-slate-500 py-8 text-center">No hay registros de versiones
                                acumuladas.</p>
                            }
            else
                            {
                                <canvas id="chartVersiones"></canvas>
                            }
                        </div>

                        @* Usuarios más activos *@
                        <div
                            class="animate-fade-in-up stagger-2 p-6 rounded-2xl bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 shadow-sm backdrop-blur-md">
                            <h3 class="text-sm font-bold text-slate-900 dark:text-white font-display mb-4 uppercase tracking-wider">
                                Flujo de Firmas por Usuario</h3>
                                @if (!Model.UsuariosActivos.Any())
                                {
                                    <p class="text-xs text-slate-400 dark:text-slate-500 py-8 text-center">Sin participación de firmas en los
                                        últimos 30 días.</p>
                                    }
            else
                                    {
                                        <canvas id="chartActivos"></canvas>
                                    }
                                </div>
                            </div>

                            @* ── Fila 3: Tabla de Firmas Pendientes ───────────────────────────────── *@
                            <div
                                class="animate-fade-in-up shadow-sm rounded-2xl bg-white/60 dark:bg-white/5 border border-slate-200/60 dark:border-white/10 backdrop-blur-md overflow-hidden">
                                <div class="p-6 border-b border-slate-200/60 dark:border-white/5 flex items-center justify-between">
                                    <h3 class="text-sm font-bold text-slate-900 dark:text-white font-display uppercase tracking-wider">Control
                                        de Firmas Pendientes</h3>
                                        @if (Model.FirmasPendientes.Any())
                                        {
                                            <span
                                                class="px-2.5 py-0.5 rounded-full bg-red-500/10 text-red-500 text-xs font-bold font-mono border border-red-500/20">
                                                @Model.FirmasPendientes.Count pendientes
                                            </span>
                                        }
                                    </div>

                                    @if (!Model.FirmasPendientes.Any())
                                    {
                                        <p class="text-xs text-slate-400 dark:text-slate-500 p-8 text-center">Todo al corriente. No hay firmas
                                            pendientes de revisión.</p>
                                        }
        else
                                        {
                                            <div class="overflow-x-auto">
                                                <table class="w-full text-left border-collapse text-xs">
                                                    <thead>
                                                        <tr
                                                            class="border-b border-slate-200/60 dark:border-white/5 text-slate-400 dark:text-slate-500 font-bold uppercase tracking-wider">
                                                            <th class="p-4">Usuario</th>
                                                            <th class="p-4">Rol en Sistema</th>
                                                            <th class="p-4">Operación</th>
                                                            <th class="p-4">Documento / Proceso</th>
                                                            <th class="p-4">Versión</th>
                                                            <th class="p-4 text-right">Tiempo de Espera</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody class="divide-y divide-slate-200/40 dark:divide-white/5 font-medium">
                                                        @foreach (var firma in Model.FirmasPendientes)
                                                        {
                                                            var diasEspera = (DateTime.Now - firma.VersionCreadaEn).Days;
                                                            <tr
                                                                class="hover:bg-slate-50/50 dark:hover:bg-white/[0.02] transition-colors @(diasEspera > 5 ? "bg-red-500/5 dark:bg-red-500/10" : "")">
                                                                <td class="p-4 text-slate-900 dark:text-white font-semibold">@firma.Usuario</td>
                                                                <td class="p-4 text-slate-500 dark:text-slate-400">@firma.Rol</td>
                                                                <td class="p-4">
                                                                    <span
                                                                        class="px-2 py-0.5 rounded-lg font-bold uppercase text-[10px] tracking-wider
                                                                        @(firma.TipoFirma == "Aprobó" ? "bg-emerald-500/10 text-emerald-500 border border-emerald-500/10" :
                                                                          firma.TipoFirma == "Revisó" ? "bg-indigo-500/10 text-indigo-500 border border-indigo-500/10" :
                                                                                                          "bg-slate-500/10 text-slate-400 border border-slate-500/10")">
                                                                        @firma.TipoFirma
                                                                    </span>
                                                                </td>
                                                                <td class="p-4 text-slate-700 dark:text-slate-300">
                                                                    <span
                                                                    class="font-mono text-[11px] font-bold text-indigo-600 dark:text-indigo-400 mr-1.5 px-1.5 py-0.5 rounded bg-indigo-500/5 border border-indigo-500/10">@firma.DocumentoCodigo</span>
                                                                    @firma.Documento
                                                                </td>
                                                                <td class="p-4 font-mono font-bold text-slate-600 dark:text-slate-400">v@firma.Version</td>
                                                                <td class="p-4 text-right font-semibold">
                                                                    @if (diasEspera == 0)
                                                                    {
                                                                        <span class="text-emerald-500">Hoy</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span
                                                                            class="@(diasEspera > 5 ? "text-red-500 font-bold" : "text-slate-500 dark:text-slate-400")">
                                                                            Hace @diasEspera día@(diasEspera == 1 ? "" : "s")
                                                                        </span>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </div>
                                </div>