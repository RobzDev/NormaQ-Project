@{
    ViewData["Title"] = "Solicitud Enviada";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen bg-gray-50 flex items-center justify-center py-12 px-4">

    <div class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

            <div class="bg-blue-600 px-8 pt-10 pb-8 text-center">
                <div class="mx-auto mb-4 h-16 w-16 rounded-full bg-white/20 flex items-center justify-center">
                    <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-white">Cuenta pendiente de aprobación</h1>
                <p class="mt-2 text-blue-100 text-sm">Tu solicitud ha sido recibida correctamente</p>
            </div>

            <div class="px-8 py-8 space-y-5">

                <div class="flex gap-3 p-4 bg-green-50 border border-green-200 rounded-xl">
                    <div class="flex-shrink-0 mt-0.5">
                        <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <p class="text-sm text-green-800">
                        Tus datos han sido registrados y el administrador de tu departamento ha sido notificado por
                        correo electrónico.
                    </p>
                </div>

                <div class="flex gap-3 p-4 bg-amber-50 border border-amber-200 rounded-xl">
                    <div class="flex-shrink-0 mt-0.5">
                        <svg class="h-5 w-5 text-amber-500" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd"
                                  d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                                  clip-rule="evenodd" />
                        </svg>
                    </div>
                    <p class="text-sm text-amber-800">
                        No podrás iniciar sesión hasta que tu acceso sea validado y aprobado. Recibirás una notificación
                        por correo cuando esto ocurra.
                    </p>
                </div>

                <div class="flex gap-3 items-start px-1">
                    <svg class="h-5 w-5 text-gray-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <p class="text-sm text-gray-500">
                        Revisa tu bandeja de entrada. El tiempo de aprobación depende del administrador de tu área.
                    </p>
                </div>

            </div>

            <div class="px-8 pb-8">
                <a asp-action="Login"
                   class="block w-full text-center py-3 px-4 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors duration-150">
                    Volver al inicio de sesión
                </a>
            </div>

        </div>

        <p class="text-center text-xs text-gray-400 mt-6">
            ¿Problemas con tu solicitud? Contacta a soporte técnico.
        </p>
    </div>

</body>

</html>