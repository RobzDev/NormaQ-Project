@model NormaQ.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Nueva Contraseña";
    ViewData["PageTitle"] = "Creación de Credenciales";
    ViewData["AuthType"] = "reset-password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<form asp-action="ResetPassword" method="post" style="display:flex;flex-direction:column;gap:1rem">

    <input type="hidden" asp-for="Token" />

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="val-summary"></div>
    }

    <div>
        <label asp-for="NewPassword" class="field-label">Nueva Contraseña</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                    stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <input asp-for="NewPassword" type="password" placeholder="Mínimo 8 caracteres" autocomplete="new-password">
        </div>
        <span asp-validation-for="NewPassword" class="val-error"></span>
    </div>

    <div>
        <label asp-for="ConfirmPassword" class="field-label">Confirmar Contraseña</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
            </div>
            <input asp-for="ConfirmPassword" type="password" placeholder="Repite la nueva contraseña"
                   autocomplete="new-password">
        </div>
        <span asp-validation-for="ConfirmPassword" class="val-error"></span>
    </div>

    <button type="submit" class="btn-main">
        Actualizar Contraseña
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
    </button>

</form>