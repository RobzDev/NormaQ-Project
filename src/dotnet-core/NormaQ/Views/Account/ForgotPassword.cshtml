@model NormaQ.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Recuperar Contraseña";
    ViewData["PageTitle"] = "Recuperación de Acceso";
    ViewData["AuthType"] = "forgot-password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<form asp-action="ForgotPassword" method="post" style="display:flex;flex-direction:column;gap:1rem">

    <p class="text-sm text-gray-500 mb-2 text-center"
       style="color: #6b7280; font-size: 0.875rem; text-align: center; margin-bottom: 0.5rem;">
        Ingresa tu correo institucional. Si la cuenta existe, te enviaremos un enlace seguro para restablecer tu acceso.
    </p>

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="val-summary"></div>
    }

    <div>
        <label asp-for="Email" class="field-label">Correo electrónico</label>
        <div class="input-row">
            <div class="input-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                    d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206"
                    stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <input asp-for="Email" type="email" placeholder="usuario@empresa.com" autocomplete="email">
        </div>
        <span asp-validation-for="Email" class="val-error"></span>
    </div>

    <button type="submit" class="btn-main">
        Enviar enlace de recuperación
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            stroke-linecap="round" stroke-linejoin="round" />
        </svg>
    </button>

    <div class="divider"><span>Opciones de acceso</span></div>

    <a asp-action="Login" class="btn-sso">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver al inicio de sesión
    </a>

</form>